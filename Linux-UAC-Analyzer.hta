  else add(PO,"NA",0,"System clock NTP-synchronized","No timedatectl output or process list collected.");
  // P21 /tmp mount hardening - CIS 1.1.2
  var mntT=readLines(firstFile(LASTROOT,["live_response/storage/mount.txt","live_response/storage/findmnt.txt","[root]/proc/mounts"]));
  if(!mntT.length) add(PO,"NA",0,"/tmp mounted with noexec/nosuid","No mount table collected.");
  else { var tmpLn=""; for(i2=0;i2<mntT.length;i2++){ if(/\s\/tmp\s/.test(mntT[i2])||/^\/tmp\s/.test(mntT[i2])){ tmpLn=mntT[i2]; break; } }
    if(!tmpLn) add(PO,"WARN",1,"/tmp mounted with noexec/nosuid","/tmp is not a separate mount - temp-path payloads (see TMPEXEC hits) execute from the root filesystem unrestricted.",{tab:"time"});
    else if(/noexec/.test(tmpLn)&&/nosuid/.test(tmpLn)) add(PO,"PASS",0,"/tmp mounted with noexec/nosuid","Separate /tmp with noexec+nosuid.");
    else add(PO,"WARN",2,"/tmp mounted with noexec/nosuid","/tmp is a separate mount but lacks "+(/noexec/.test(tmpLn)?"nosuid":"noexec")+" - dropped payloads still run from it: "+trunc(tmpLn,80),{tab:"time"}); }
  // P22 duplicate non-zero UIDs - CIS 6.2 (UID-0 clones are their own FAIL above)
  if(!have(USERS)) add(PO,"NA",0,"No duplicate UIDs","No /etc/passwd collected.");
  else { var uidSeen={}, dup=[];
    for(i2=0;i2<USERS.length;i2++){ var uU=USERS[i2]; if(uU.uid===0) continue;
      if(uidSeen[uU.uid]){ dup.push(uidSeen[uU.uid]+"/"+uU.user+" share uid "+uU.uid); } else uidSeen[uU.uid]=uU.user; }
    if(dup.length) add(PO,"WARN",2,"No duplicate UIDs",dup.join("; ")+" - shared identity defeats attribution.",{tab:"users"});
    else add(PO,"PASS",0,"No duplicate UIDs","Every non-root account has a unique UID.",{tab:"users"}); }
  // P23 additional sshd hardening - CIS 5.2 (beyond the root/password/empty checks above)
  if(!SSHD_DIRS) add(PO,"NA",0,"SSH hardening extras (X11/MaxAuthTries/UserEnvironment)","No sshd_config collected.");
  else { var sshBad=[];
    if(lc(SSHD_DIRS["x11forwarding"]||"")==="yes") sshBad.push("X11Forwarding yes");
    if(lc(SSHD_DIRS["permituserenvironment"]||"")==="yes") sshBad.push("PermitUserEnvironment yes (LD_PRELOAD-style injection over SSH)");
    var mat=parseInt(SSHD_DIRS["maxauthtries"]||"6",10); if(mat>4) sshBad.push("MaxAuthTries "+(SSHD_DIRS["maxauthtries"]||"(default 6)")+" (CIS: 4 or less)");
    if(sshBad.length) add(PO,"WARN",1,"SSH hardening extras (X11/MaxAuthTries/UserEnvironment)",sshBad.join("; ")+".",{tab:"persist"});
    else add(PO,"PASS",0,"SSH hardening extras (X11/MaxAuthTries/UserEnvironment)","X11 forwarding off, user environment off, MaxAuthTries within CIS bounds."); }
  // P24 patch recency (case-window-aware: PKGS is pre-filtered when /from /to is set)
  if(DFROM||DTO) add(PO,"NA",0,"Recent patching activity","A case window is active - package history is pre-filtered, recency not assessable (clear /from /to and re-Analyze).");
  else if(!PKGS.length) add(PO,"NA",0,"Recent patching activity","No package-manager history collected.");
  else { var mxPk=0; for(i2=0;i2<PKGS.length;i2++){ var pe2b=pkgEpoch(PKGS[i2]); if(pe2b>mxPk) mxPk=pe2b; }
    var capE=captureEpoch();
    if(!mxPk||!capE) add(PO,"NA",0,"Recent patching activity","Package timestamps or the collection time could not be normalized.");
    else { var ageD=Math.floor((capE-mxPk)/86400);
      if(ageD>90) add(PO,"WARN",1,"Recent patching activity","Latest package activity is "+nf(ageD)+" days before collection - patching looks stale (or logs rotated away).",{tab:"apps"});
      else add(PO,"PASS",0,"Recent patching activity","Package activity "+nf(ageD<0?0:ageD)+" day(s) before collection.",{tab:"apps"}); } }

  /* ======================= APACHE (CIS Apache HTTP Server 2.4-inspired) ======================= */
  var AP="apache";
  if(!APACHECFG||!APACHECFG.present){
    add(AP,"NA",0,"Apache configuration","No /etc/apache2 or /etc/httpd configuration in this capture - host is not an Apache web server, or /etc was not collected.");
  } else { var AC=APACHECFG;
    // A1 ServerTokens (CIS 3.2 / info-leak)
    if(lc(AC.tokens)==="prod") add(AP,"PASS",0,"ServerTokens Prod","Version banner minimized (ServerTokens Prod).",{tab:"web"});
    else add(AP,"WARN",1,"ServerTokens Prod","ServerTokens "+(AC.tokens||"(unset - defaults to Full)")+" leaks Apache/OS version in every response header (CIS: set Prod).",{tab:"web"});
    // A2 ServerSignature (CIS 3.3)
    if(lc(AC.signature)==="on") add(AP,"WARN",1,"ServerSignature Off","ServerSignature On - version footer on server-generated pages (error pages, listings).",{tab:"web"});
    else add(AP,"PASS",0,"ServerSignature Off","No version footer on server-generated pages.",{tab:"web"});
    // A3 TraceEnable (CIS 5.8 - XST)
    if(lc(AC.trace)==="off") add(AP,"PASS",0,"TraceEnable Off","HTTP TRACE disabled.",{tab:"web"});
    else add(AP,"WARN",2,"TraceEnable Off","TraceEnable "+(AC.trace||"(unset - defaults to On)")+" - cross-site-tracing surface (CIS: Off).",{tab:"web"});
    // A4 runs as dedicated account (CIS 3.1)
    var apU=lc(AC.user||"");
    if(!apU) add(AP,"WARN",1,"Runs as a dedicated non-root user","No User directive found - verify the effective account.",{tab:"web"});
    else if(apU==="root") add(AP,"FAIL",3,"Runs as a dedicated non-root user","Apache runs as root - any web-app compromise is instantly root.",{tab:"web"});
    else add(AP,"PASS",0,"Runs as a dedicated non-root user","User "+AC.user+".",{tab:"web"});
    // A5 directory listing (CIS 5.4)
    if(AC.indexes.length) add(AP,"WARN",2,"Directory listing disabled","'Options Indexes' active in: "+trunc(AC.indexes.join(", "),90)+" - directory contents are browsable (recon + dropped-file discovery for an attacker).",{tab:"web"});
    else add(AP,"PASS",0,"Directory listing disabled","No 'Options Indexes' in the enabled configuration.",{tab:"web"});
    // A6 mod_status exposure (CIS 2.4)
    if(AC.statusOn) add(AP,"WARN",1,"mod_status not exposed","mod_status / server-status handler is enabled - verify it is restricted to localhost (leaks URLs, client IPs and worker state).",{tab:"web"});
    else add(AP,"PASS",0,"mod_status not exposed","Status handler not enabled.",{tab:"web"});
    // A7 risky modules (CIS 2.x minimize modules)
    var risky=[], rk=["dav","dav_fs","userdir","info","cgi","cgid","autoindex","include"];
    for(i2=0;i2<rk.length;i2++){ if(contains(AC.modules,rk[i2])) risky.push(rk[i2]); }
    if(risky.length) add(AP,"WARN",1,"Only required modules enabled","Attack-surface modules enabled: "+risky.join(", ")+" (CIS ch.2: disable WebDAV/userdir/info/CGI/autoindex/SSI unless required).",{tab:"web"});
    else add(AP,"PASS",0,"Only required modules enabled","None of the CIS watchlist modules (dav/userdir/info/cgi/autoindex/include) are enabled.",{tab:"web"});
    // A8 TLS present + not-ancient protocols (CIS 7.x)
    if(!contains(AC.modules,"ssl") && !AC.sslOn) add(AP,"WARN",1,"TLS configured","No ssl module / SSLEngine in the enabled configuration - the site serves plain HTTP only (credentials and sessions in cleartext).",{tab:"web"});
    else if(AC.sslproto && /(^|\s)\+?(sslv3|tlsv1(\.0)?|tlsv1\.1)(\s|$)/i.test(AC.sslproto.replace(/-\S+/g,""))) add(AP,"WARN",2,"TLS configured","SSLProtocol '"+trunc(AC.sslproto,50)+"' permits deprecated protocols (CIS: TLS 1.2+ only).",{tab:"web"});
    else add(AP,"PASS",0,"TLS configured","ssl module enabled"+(AC.sslproto?(" (SSLProtocol "+trunc(AC.sslproto,40)+")"):"")+".",{tab:"web"});
    // A9 .htaccess override surface (CIS 5.5)
    if(AC.overrideAll.length) add(AP,"WARN",1,"AllowOverride restricted","'AllowOverride All' in: "+trunc(AC.overrideAll.join(", "),80)+" - a writable docroot lets an attacker drop .htaccess handlers/rewrites.",{tab:"web"});
    else add(AP,"PASS",0,"AllowOverride restricted","No 'AllowOverride All' in the enabled configuration.",{tab:"web"});
    // A10 logging configured (CIS 6.x)
    if(AC.logging) add(AP,"PASS",0,"Access/error logging configured","ErrorLog/CustomLog directives present (the Apache Web Server tab parses the collected logs).",{tab:"web"});
    else add(AP,"WARN",2,"Access/error logging configured","No ErrorLog/CustomLog in the enabled configuration - no web evidence trail.",{tab:"web"});
  }

  return F;
}
var SEC_STATUS_ORDER={FAIL:0,WARN:1,NA:2,PASS:3,INFO:2};
function secStatusTag(s){
  var cls=(s==="FAIL")?"ioc":(s==="WARN")?"sus":(s==="PASS")?"ok":"info";
  return '<span class="tag '+cls+'">'+esc(s)+'</span>'; }
function secRowCls(s){ return s==="FAIL"?"row-flag":(s==="WARN"?"row-warn":""); }
function secSort(a,b){ var x=SEC_STATUS_ORDER[a.status], y=SEC_STATUS_ORDER[b.status]; if(x!==y) return x-y; return (b.sev-a.sev); }
function secTableHtml(rows){
  var h='<thead><tr><th title="PASS / WARN / FAIL / N-A (source artifact not collected)">Result</th>'
    +'<th title="What was checked">Check</th>'
    +'<th title="What the check found - click a row with a timestamp to pivot the Timeline, or to jump to the source tab">Evidence</th></tr></thead><tbody>';
  if(!rows.length){ h+='<tr><td colspan="3" class="muted">(no checks in this category)</td></tr>'; return h+'</tbody>'; }
  rows.sort(secSort);
  for(var i=0;i<rows.length;i++){ var r=rows[i]; var rc=secRowCls(r.status);
    var jump=r.ep?(' data-ep="'+r.ep+'"'):(r.tab?(' data-gotab="'+esc(r.tab)+'"'):"");
    var cur=(r.ep||r.tab)?' style="cursor:pointer"':"";
    h+='<tr'+(rc?(' class="'+rc+'"'):'')+cur+jump+'><td>'+secStatusTag(r.status)+'</td>'
      +'<td class="mono">'+esc(r.name)+'</td>'
      +'<td class="mono muted" title="'+esc(r.evidence)+'">'+esc(trunc(r.evidence,150))+(r.ep?(' <span class="lnk">pivot →</span>'):(r.tab?' <span class="lnk">open →</span>':''))+'</td></tr>'; }
  return h+'</tbody>';
}
function renderSecurity(){
  if(!LASTROOT){ $("secBanner").innerHTML='<span class="muted">Analyze a capture first.</span>'; $("secCorrTbl").innerHTML=""; $("secPostTbl").innerHTML=""; $("secApacheTbl").innerHTML=""; return; }
  var F=computeSecurity();
  var corr=[], post=[], apache=[], nFail=0, nWarn=0, nPass=0, nNa=0, i;
  for(i=0;i<F.length;i++){ var f=F[i];
    if(f.status==="FAIL") nFail++; else if(f.status==="WARN") nWarn++; else if(f.status==="PASS") nPass++; else nNa++;
    if(f.cat==="correlation") corr.push(f); else if(f.cat==="apache") apache.push(f); else post.push(f); }
  $("secBanner").innerHTML=
     '<div class="secpill'+(nFail?' bad':'')+'"><span class="n">'+nFail+'</span><span class="l">Fail</span></div>'
    +'<div class="secpill'+(nWarn?' warn':'')+'"><span class="n">'+nWarn+'</span><span class="l">Warn</span></div>'
    +'<div class="secpill ok"><span class="n">'+nPass+'</span><span class="l">Pass</span></div>'
    +'<div class="secpill"><span class="n">'+nNa+'</span><span class="l">N/A</span></div>';
  $("secCorrTbl").innerHTML=secTableHtml(corr); setupColResizeFor($("secCorrTbl"),"sec_corr"); freezeById("secCorrTbl");
  $("secPostTbl").innerHTML=secTableHtml(post); setupColResizeFor($("secPostTbl"),"sec_post"); freezeById("secPostTbl");
  $("secApacheTbl").innerHTML=secTableHtml(apache); setupColResizeFor($("secApacheTbl"),"sec_apache"); freezeById("secApacheTbl");
}
function exportSecurity(){
  if(!LASTROOT){ setStatus("Analyze a capture first","err"); return; }
  var F=computeSecurity(); F.sort(function(a,b){ if(a.cat!==b.cat) return a.cat<b.cat?-1:1; return secSort(a,b); });
  var lines=["Category,Result,Severity,Check,Evidence,PivotTime_"+tzLabel()];
  for(var i=0;i<F.length;i++){ var f=F[i];
    lines.push([cq(f.cat),cq(f.status),cq(f.sev),cq(f.name),cq(f.evidence),cq(f.ep?fmtTime(f.ep,true):"")].join(",")); }
  var dir=LASTOUTDIR||$("outDir").value, path=dir+"\\security_checks_"+nowStamp()+".csv";
  try{ writeUtf8(path, lines.join("\r\n")); setStatus("Exported "+nf(F.length)+" security checks → "+path,"ok"); appendLog("Exported: "+path); }
  catch(e){ setStatus("Export failed: "+e.message,"err"); }
}

/* ---------- shared table rendering ---------- */
function tagsHtml(r){ var h=""; for(var i=0;i<r.tags.length;i++){ var t=r.tags[i];
  var cls=(t==="IOC")?"ioc":"sus"; h+='<span class="tag '+cls+'" title="'+esc(r.reasons.join("; "))+'">'+esc(t)+'</span>'; } return h; }
function scoreCell(r){ return '<td class="first"><span class="sc '+scClass(r.score)+'">'+r.score+'</span>'+tagsHtml(r)+'</td>'; }
function rowCls(r){ var c=""; if(r.score>=5) c="row-flag"; else if(r.score>=3) c="row-warn"; if(hasIocTag(r)) c+=(c?" ":"")+"ioc"; return c; }
function hasIocTag(r){ for(var i=0;i<r.tags.length;i++) if(r.tags[i]==="IOC") return true; return false; }
function hasTag(r,t){ for(var i=0;i<r.tags.length;i++) if(r.tags[i]===t) return true; return false; }
function passQ(r){ if(SUSONLY && r.score<3) return false;
  if(SCOREMIN>0 && SCORE_TABS[TAB] && (r.score||0)<SCOREMIN) return false;   // v1.5.1: min-score filter
  if(QUERY && r.blob.indexOf(QUERY)<0) return false; return true; }
function sortRows(rows, cols, st){
  var sk=cols[st.k].sk, dir=st.d;
  rows.sort(function(a,b){ var x=sk(a),y=sk(b);
    if(typeof x==="number"&&typeof y==="number") return (x-y)*dir;
    x=String(x); y=String(y); return x<y?-dir:(x>y?dir:0); });
}
/* v1.6: one consistent, prominent truncation warning for every capped table. total = rows the
   current filters produced; cap = rows actually rendered. Returned only when truncated. The tooltip
   points at the two UNCAPPED escape hatches: the on-screen filters (which narrow the set) and the
   CSV export (which writes every filtered row, not just the shown cap). `how` overrides the export
   hint for tabs whose completeness path is different (e.g. packages: a case window). */
function capWarnHtml(total, cap, how){
  if(!total || total<=cap) return "";
  var esc2=(typeof esc==="function")?esc:function(s){return s;};
  var tip="This view matched "+nf(total)+" rows but only the first "+nf(cap)+" are rendered (performance cap). "
    +"Narrow it with the search box and the filters above (score / date range / type / user), "
    +(how||("or use Export → CSV to write all "+nf(total)+" rows to file."));
  return ' <span class="tag ioc" style="cursor:help" title="'+esc2(tip)+'">⚠ Maximum Rows Exceeded</span>'; }
function drawTable(cols, rows, st, tabkey){
  var shown=rows.length>MAXROWS?MAXROWS:rows.length;
  var html="<thead><tr>";
  for(var c=0;c<cols.length;c++){ var arrow=(st.k===c)?(st.d>0?" ▲":" ▼"):"";
    // v0.13: every heading carries a tooltip (col.tip, falling back to the sort/resize hint)
    html+='<th data-k="'+c+'" title="'+esc((cols[c].tip?cols[c].tip+" · ":"")+"Click to sort; drag the right edge to resize")+'">'+esc(cols[c].h)+arrow+'</th>'; }
  html+="</tr></thead><tbody>";
  for(var i=0;i<shown;i++){ var r=rows[i]; var rc=rowCls(r);
    html+='<tr data-i="'+i+'"'+(rc?(' class="'+rc+'"'):'')+' style="cursor:pointer">';
    for(var k=0;k<cols.length;k++){ html+=cols[k].cell(r); }
    html+="</tr>";
  }
  html+="</tbody>";
  $("tbl").innerHTML=html;
  $("count").innerHTML=nf(rows.length)+" row"+(rows.length===1?"":"s")+(shown<rows.length?(" (showing "+nf(shown)+")"+capWarnHtml(rows.length,MAXROWS)):"");
  var ths=$("tbl").getElementsByTagName("th");
  for(var j=0;j<ths.length;j++){ ths[j].onclick=function(e){ e=e||window.event; var t=e.target||e.srcElement;
    if(t && /\bcgrip\b/.test(t.className+"")) return;
    var kk=parseInt(this.getAttribute("data-k"),10);
    if(st.k===kk) st.d*=-1; else { st.k=kk; st.d=1; } render(); }; }
  applyFreeze(); setupColResize();
  window.__viewRows=rows.slice(0,shown);
  window.__fullRows=rows;
}

/* processes table */
function procBase(r){ var t=firstToken(r.exe||r.cmd||""); var b=t.substring(t.lastIndexOf("/")+1); b=b.replace(/^[\[(]|[\])]$/g,""); return b||t; }
var PCOLS=[
  {h:"Score / tags", tip:"Suspicion score (>=3 is flagged) plus scoring tags - hover a tag for the full reasons", sk:function(r){return r.score;}, cell:function(r){return scoreCell(r);}},
  {h:"Name", tip:"Process basename (from exe path or first command token)", sk:function(r){return lc(procBase(r));}, cell:function(r){return '<td class="mono" title="'+esc(r.exe||r.cmd)+'">'+esc(trunc(procBase(r),24))+'</td>';}},
  {h:"User", tip:"Account the process runs as", sk:function(r){return lc(r.user);}, cell:function(r){return '<td class="mono">'+esc(r.user)+'</td>';}},
  {h:"PID", tip:"Process id ('hidden' = present in /proc but missing from ps)", sk:function(r){return parseInt(r.pid,10)||0;}, cell:function(r){return '<td class="mono" style="text-align:center">'+esc(r.pid)+(r.hidden?' <span class="tag ioc">hidden</span>':'')+'</td>';}},
  {h:"PPID", tip:"Parent process id - the detail pane shows full ancestry", sk:function(r){return parseInt(r.ppid,10)||0;}, cell:function(r){return '<td class="mono" style="text-align:center">'+esc(r.ppid)+'</td>';}},
  {h:"Start", tip:"Start time/date column as ps reported it (host-local)", sk:function(r){return lc(r.start);}, cell:function(r){return '<td class="mono muted">'+esc(r.start)+'</td>';}},
  {h:"CPU/Mem %", tip:"%CPU / %MEM at collection instant (from top -b -n1; '-' = not seen by top)", sk:function(r){return r.cpu!=null?r.cpu:-1;}, cell:function(r){return '<td class="mono" style="text-align:center">'+(r.cpu>=0?(r.cpu.toFixed(1)+' / '+r.mem.toFixed(1)):'<span class="muted">-</span>')+'</td>';}},
  {h:"Command", tip:"Full command line as collected", sk:function(r){return lc(r.cmd);}, cell:function(r){return '<td class="mono" title="'+esc(r.cmd)+'">'+esc(trunc(r.cmd,140))+'</td>';}}
];
/* when a dataset is empty because the collection profile didn't gather it, say so instead of
   showing a blank grid (a logs-only capture legitimately has no processes/network/timeline). */
function profileEmptyMsg(n, what){ if(n>0) return false;
  var msg = PROFILE.logsOnly ? ("Not collected in this profile - "+what+" need a live_response / ir_triage collection. uac.log command line: "+trunc(PROFILE.cmd||"(unknown)",90))
                             : ("No "+what+" in this capture.");
  // v0.15: on logs-only captures, point the empty Processes tab at the nearest substitute
  if(PROFILE.logsOnly && SYSLOGSVC.length && String(what).indexOf("processes")>=0)
    msg+=" Nearest substitute: Logs -> Service inventory ("+nf(SYSLOGSVC.length)+" programs seen writing to syslog).";
  $("tbl").innerHTML='<thead><tr><th>'+esc(what)+'</th></tr></thead><tbody><tr><td class="muted">'+esc(msg)+'</td></tr></tbody>';
  $("count").innerHTML="0 rows"; return true; }
var PROC_TREE=false, PTREE_COLLAPSED={};
/* v0.16/v0.17: suspicion-category multiselect (by scoring tag, with counts) - orthogonal to "flagged only" */
function populateProcSus(){
  var cnt={}, i, t2;
  for(i=0;i<PROC.length;i++){ var tg=PROC[i].tags||[]; for(t2=0;t2<tg.length;t2++){ cnt[tg[t2]]=(cnt[tg[t2]]||0)+1; } }
  mdPopulate("procSus", cnt);
}
function procPass(r){
  if(!passQ(r)) return false;
  return mdPassAny("procSus", r.tags||[]);   // v0.17: row passes if ANY of its tags is ticked
}
function renderProc(){
  populateProcSus();
  if(PROC_TREE){ renderProcTree(); return; }
  var rows=[]; for(var i=0;i<PROC.length;i++) if(procPass(PROC[i])) rows.push(PROC[i]);
  sortRows(rows,PCOLS,SORT.proc); drawTable(PCOLS,rows,SORT.proc,"proc"); profileEmptyMsg(PROC.length,"processes"); }
/* collapsible parent/child tree. Roots = rows whose ppid isn't itself a listed process (or ppid 0).
   passQ (search / flagged-only) hides non-matching LEAVES but keeps ancestors of any match so the
   path to a hit stays visible. */
function renderProcTree(){
  if(profileEmptyMsg(PROC.length,"processes")) return;
  // which pids to show: a row passes if it matches passQ OR any descendant does
  var show={}, i;
  function anyMatch(pid, guard){ if(guard>200) return false; var r=PROCBYPID[pid];
    var self=r?procPass(r):false; var kids=PROCKIDS[pid]||[]; var kid=false;   // v0.16: suspicion filter applies in tree view too
    for(var k=0;k<kids.length;k++){ if(anyMatch(kids[k], guard+1)) kid=true; }
    if(self||kid) show[pid]=1; return self||kid; }
  // roots
  var roots=[]; for(i=0;i<PROC.length;i++){ var r=PROC[i]; var pp=r.ppid;
    if(!pp || pp==="0" || !PROCBYPID[pp] || pp===r.pid) roots.push(r.pid); }
  for(i=0;i<roots.length;i++) anyMatch(roots[i], 0);
  var html='<div class="ptree" id="ptreeRoot">', shown={count:0};
  roots.sort(function(a,b){ return (parseInt(a,10)||0)-(parseInt(b,10)||0); });
  for(i=0;i<roots.length;i++){ if(show[roots[i]]) html+=treeNode(roots[i], 0, show, shown); }
  html+='</div>';
  $("tbl").innerHTML='<thead><tr><th>Process tree ('+nf(PROC.length)+' processes; click a row for detail, ▸/▾ to fold)</th></tr></thead><tbody><tr><td style="padding:0">'+html+'</td></tr></tbody>';
  $("count").innerHTML=nf(shown.count)+" shown";
  window.__viewRows=[]; window.__fullRows=[];
  applyFreeze();
}
function treeNode(pid, depth, show, shown){
  var r=PROCBYPID[pid]; if(!r) return ""; shown.count++;
  var kids=PROCKIDS[pid]||[], vis=[]; for(var k=0;k<kids.length;k++){ if(show[kids[k]]) vis.push(kids[k]); }
  vis.sort(function(a,b){ return (parseInt(a,10)||0)-(parseInt(b,10)||0); });
  var collapsed=PTREE_COLLAPSED[pid], tw= vis.length ? ('<span class="tw" data-fold="'+esc(pid)+'">'+(collapsed?"▸":"▾")+'</span>') : '<span class="tw">·</span>';
  var cls= r.score>=5?"pnode pn-flag":(r.score>=3?"pnode pn-warn":"pnode");
  var pad= (depth*18)+"px";
  var sc= r.score>0 ? '<span class="sc '+scClass(r.score)+'">'+r.score+'</span> ' : '';
  var h='<div class="'+cls+'" style="margin-left:'+pad+'">'+tw
      +'<span class="pn" data-pid="'+esc(pid)+'">'+sc+esc(procBase(r))
      +' <span class="ppid">('+esc(pid)+(r.user?(" "+esc(r.user)):"")+(r.cpu>=0?(" "+r.cpu.toFixed(0)+"%cpu"):"")+')</span>'
      + (r.tags.length?(" "+tagsHtml(r)):"")
      +'</span></div>';
  if(vis.length && !collapsed){ for(var v=0;v<vis.length;v++) h+=treeNode(vis[v], depth+1, show, shown); }
  return h;
}

/* network table */
var NCOLS=[
  {h:"Score / tags", tip:"Suspicion score (>=3 is flagged) plus scoring tags - hover a tag for the full reasons", sk:function(r){return r.score;}, cell:function(r){return scoreCell(r);}},
  {h:"Proto", tip:"tcp / udp (v6 sockets decoded too)", sk:function(r){return r.proto;}, cell:function(r){return '<td class="mono">'+esc(r.proto)+'</td>';}},
  {h:"State", tip:"Socket state (LISTEN / ESTAB / ...)", sk:function(r){return r.state;}, cell:function(r){return '<td class="mono">'+esc(r.state)+'</td>';}},
  {h:"Type", tip:"Service type derived from well-known ports (SSH/HTTP/SMB/RDP/... ; blank = no well-known port involved)", sk:function(r){return netSvcOf(r);}, cell:function(r){var sv=netSvcOf(r);return '<td class="mono muted">'+esc(sv||"-")+'</td>';}},
  {h:"Local", tip:"Local address:port", sk:function(r){return lc(r.local);}, cell:function(r){return '<td class="mono" title="'+esc(r.local)+'">'+esc(r.local)+'</td>';}},
  {h:"Remote", tip:"Remote address:port - click a PUBLIC IP to open it in VirusTotal (launches your browser)", sk:function(r){return lc(r.peer);}, cell:function(r){var pub=(r.peerAddr && !ipIsLocal(r.peerAddr));
    return '<td class="mono" title="'+esc(r.peer)+(pub?"  ·  click the IP for VirusTotal":"")+'">'+(pub?('<span class="lnk" data-vt="'+esc(r.peerAddr)+'">'+esc(r.peer)+'</span>'):esc(r.peer))+'</td>';}},
  {h:"Location", tip:"Country + ASN/org of the remote address (online geo/ASN enrichment; blank = local address, lookup off/offline, or still resolving)", sk:function(r){return geoTip(r.peerAddr);}, cell:function(r){return '<td class="mono muted" title="'+esc(geoTip(r.peerAddr))+'">'+esc(trunc(geoTip(r.peerAddr)||"-",38))+'</td>';}},
  {h:"Process", tip:"Owning process (recovered from /proc/net uid + fd inodes on non-root captures)", sk:function(r){return lc(r.procName);}, cell:function(r){return '<td class="mono muted">'+esc(r.procName?(r.procName+(r.procPid?(" ("+r.procPid+")"):"")):trimStr(r.procRaw))+'</td>';}}
];
function netLocOf(r){ if(!r.peerAddr || ipIsLocal(r.peerAddr)) return "";
  var g=GEO[r.peerAddr]; return g&&g.country?g.country:"(unresolved)"; }
/* v0.17: location population lives in populateNetFilters (checkbox multiselect) */
function populateNetFilters(){   // v0.17: checkbox multiselects with counts
  var locs={}, types={}, i;
  for(i=0;i<NET.length;i++){ var lv=netLocOf(NET[i]); if(lv) locs[lv]=(locs[lv]||0)+1;
    var sv=netSvcOf(NET[i]); if(sv) types[sv]=(types[sv]||0)+1; }
  mdPopulate("netLoc", locs); mdPopulate("netType", types);
}
function renderNet(){
  try{ $("netChart").innerHTML=netChartHtml(); }catch(enc){}   // v1.5
  var pub=false; try{ pub=$("netPubOnly").checked; }catch(enp){}
  populateNetFilters();
  var rows=[]; for(var i=0;i<NET.length;i++){ var r=NET[i];
    if(!passQ(r)) continue;
    // v0.13: "public IPs only" - rows whose remote end is a routable public address
    if(pub && !(r.peerAddr && !ipIsLocal(r.peerAddr))) continue;
    if(!mdPass("netLoc", netLocOf(r))) continue;    // v0.17: multiselect location filter
    if(!mdPass("netType", netSvcOf(r))) continue;   // v0.17: multiselect service-type filter
    rows.push(r); }
  sortRows(rows,NCOLS,SORT.net); drawTable(NCOLS,rows,SORT.net,"net");
  var fl2=[]; if(pub) fl2.push("public-remote"); if(mdSet("netLoc")) fl2.push("location: "+mdDesc("netLoc")); if(mdSet("netType")) fl2.push("type: "+mdDesc("netType"));
  if(fl2.length && NET.length) $("count").innerHTML+=" · "+esc(fl2.join(" · "))+" only";
  profileEmptyMsg(NET.length,"network connections"); }

/* logon table (v0.2) */
function logonDay(ep){ if(!ep) return 0; var d=new Date(ep*1000);
  return Number(d.getUTCFullYear()+""+p2n(d.getUTCMonth()+1)+p2n(d.getUTCDate())); }
function logonWhenCell(r){ return r.epoch?fmtTime(r.epoch,true):(r.when||"-"); }
function logonMethodCell(r){ var m=r.method||""; if(r.cmd) m+=(m?" · ":"")+trunc(r.cmd,60); if(r.line && r.result!=="last-login") m+=(m?" · ":"")+r.line; return m; }
function logonSrcType(r){ return String(r.src||"").split(":")[0]; }
/* best-effort raw-file path for a logon row's source, for the clickable link */
function logonSrcPath(r){ if(!LASTROOT) return ""; var st=logonSrcType(r), p="";
  if(st==="auth.log") p=firstFile(LASTROOT,["[root]/var/log/auth.log","[root]/var/log/secure"]);
  else if(st==="wtmp") p=jp(LASTROOT,"[root]/var/log/wtmp");
  else if(st==="btmp") p=jp(LASTROOT,"[root]/var/log/btmp");
  else if(st==="lastlog") p=jp(LASTROOT,"[root]/var/log/lastlog");
  else p=firstFile(LASTROOT,["live_response/system/"+st,"live_response/system/last.txt"]);
  return (p && fileExists(p))?p:""; }
function logonSrcCell(r){ var p=logonSrcPath(r);
  return p ? '<td class="mono"><span class="lnk" data-open="'+esc(p)+'" title="Open the raw source file in Explorer">'+esc(r.src)+'</span></td>'
           : '<td class="mono muted">'+esc(r.src)+'</td>'; }
var LCOLS=[
  {h:"Score / tags", tip:"Suspicion score (>=3 is flagged) plus scoring tags - hover a tag for the full reasons", sk:function(r){return r.score;}, cell:function(r){return scoreCell(r);}},
  {h:"When", tip:"Event time (UTC unless host TZ is ticked); classic-syslog rows carry the capture year", sk:function(r){return r.epoch;}, cell:function(r){return '<td class="mono">'+esc(logonWhenCell(r))+'</td>';}},
  {h:"Result", tip:"accepted / failed / session / sudo / pkexec / acctchg / su / last-login", sk:function(r){return r.result;}, cell:function(r){return '<td class="mono">'+esc(r.result)+'</td>';}},
  {h:"User", tip:"Account involved ((invalid) = user does not exist on the host)", sk:function(r){return lc(r.user);}, cell:function(r){return '<td class="mono">'+esc(r.user)+'</td>';}},
  {h:"Source", tip:"Source IP ((local) = console/tty or no address recorded) - geo chip when enrichment is on", sk:function(r){return lc(r.ip);}, cell:function(r){return '<td class="mono" title="'+esc(r.ip)+(geoTip(r.ip)?("  ·  "+esc(geoTip(r.ip))):"")+'">'+esc(r.ip||"(local)")+geoTag(r.ip)+'</td>';}},
  {h:"Method / cmd", tip:"Auth method / elevated command / tty or key fingerprint", sk:function(r){return r.method;}, cell:function(r){return '<td class="mono muted" title="'+esc(r.method+(r.cmd?("  "+r.cmd):""))+'">'+esc(trunc(logonMethodCell(r),70))+'</td>';}},
  {h:"Source", tip:"Artifact this row came from - click to open the raw file", sk:function(r){return r.src;}, cell:function(r){return logonSrcCell(r);}}
];
/* fill a <select> with distinct sorted values, preserving the current selection */
function fillSelect(id, label, values){ var el=$(id); if(!el) return; var cur=el.value;
  var opts=['<option value="">'+label+': all</option>']; values.sort();
  for(var i=0;i<values.length;i++){ var v=values[i]; opts.push('<option value="'+esc(v)+'"'+(v===cur?" selected":"")+'>'+esc(trunc(v,28))+'</option>'); }
  el.innerHTML=opts.join(""); if(cur){ el.value=cur; } }
function populateLogonFilters(){   // v0.17: checkbox multiselects with counts
  var us={}, ss={}, rs={}, i;
  for(i=0;i<LOGON.length;i++){ var r=LOGON[i];
    var un=trimStr(r.user); if(un) us[un]=(us[un]||0)+1;
    var st=logonSrcType(r); if(st) ss[st]=(ss[st]||0)+1;
    if(r.result) rs[r.result]=(rs[r.result]||0)+1; }
  mdPopulate("logfUser", us); mdPopulate("logfSrc", ss); mdPopulate("logfResult", rs);
}
function keysOf(o){ var a=[],k; for(k in o){ if(o.hasOwnProperty(k)&&k) a.push(k); } return a; }
/* v1.5: logon activity over time - accepted/session (green) vs failed (red) auth events per day */
function fmtDayKey(x){ x=String(x); return x.substring(0,4)+"-"+x.substring(4,6)+"-"+x.substring(6,8); }
function logonChartHtml(){
  try{
    var by={}, i, any=false;
    for(i=0;i<LOGON.length;i++){ var r=LOGON[i]; if(!r.epoch) continue;
      if(r.result!=="accepted" && r.result!=="failed" && r.result!=="session") continue;
      var d=logonDay(r.epoch); if(!d) continue;
      if(!by[d]) by[d]={succ:0, fail:0};
      if(r.result==="failed") by[d].fail++; else by[d].succ++;
      any=true; }
    if(!any) return "";
    var days=[]; for(var k in by){ if(by.hasOwnProperty(k)) days.push(k); }
    days.sort();
    var max=1; for(i=0;i<days.length;i++){ var t=by[days[i]].succ+by[days[i]].fail; if(t>max) max=t; }
    var H=70, bars=[];
    for(i=0;i<days.length && i<400;i++){ var b=by[days[i]];
      var fp=b.fail?Math.max(2,Math.round(b.fail/max*H)):0, sp=b.succ?Math.max(2,Math.round(b.succ/max*H)):0;
      bars.push('<span class="vbar" title="'+esc(fmtDayKey(days[i]))+': '+b.succ+' success, '+b.fail+' failed">'
        +'<i style="bottom:0;height:'+fp+'px;background:#f85149"></i>'
        +'<i style="bottom:'+fp+'px;height:'+sp+'px;background:#3fb950"></i></span>'); }
    return '<div class="chart"><div class="ct">Logon Activity Over Time</div>'
      +'<div class="cd">Accepted / session (green) vs failed (red) authentication events per day - a tall red column is a brute-force day. Hover a bar for the counts.</div>'
      +'<div class="bars">'+bars.join("")+'</div>'
      +'<div class="lg">'+esc(fmtDayKey(days[0]))+' &rarr; '+esc(fmtDayKey(days[days.length-1]))+' &middot; '+nf(days.length)+' day(s) &middot; <span style="color:#3fb950">■</span> success &nbsp;<span style="color:#f85149">■</span> failed</div></div>';
  }catch(e){ return ""; }
}
/* v1.5: network distribution - ss is a point-in-time snapshot (no per-connection timestamps),
   so this is a distribution (by remote country / service type / socket state), not a time series */
function netChartHtml(){
  try{
    var cnt={}, i, mode="country", any=false;
    for(i=0;i<NET.length;i++){ var r=NET[i]; if(!r.peerAddr||ipIsLocal(r.peerAddr)) continue;
      var g=GEO[r.peerAddr]; if(g&&g.country){ cnt[g.country]=(cnt[g.country]||0)+1; any=true; } }
    if(!any){ mode="type"; for(i=0;i<NET.length;i++){ var sv=netSvcOf(NET[i]); if(sv){ cnt[sv]=(cnt[sv]||0)+1; any=true; } } }
    if(!any){ mode="state"; for(i=0;i<NET.length;i++){ var st=NET[i].state; if(st){ cnt[st]=(cnt[st]||0)+1; any=true; } } }
    if(!any) return "";
    var arr=[]; for(var k in cnt){ if(cnt.hasOwnProperty(k)) arr.push({k:k, n:cnt[k]}); }
    arr.sort(function(a,b){ return b.n-a.n; });
    var max=arr[0].n, rows=[];
    for(i=0;i<arr.length && i<10;i++){ var w=Math.max(3,Math.round(arr[i].n/max*300));
      rows.push('<div class="hbar"><span class="hl" title="'+esc(arr[i].k)+'">'+esc(arr[i].k)+'</span>'
        +'<span class="ht" style="width:'+w+'px"></span><span class="hn">'+nf(arr[i].n)+'</span></div>'); }
    var label=mode==="country"?"remote country":(mode==="type"?"service type":"socket state");
    return '<div class="chart"><div class="ct">Connections by '+label+'</div>'
      +'<div class="cd">Network artifacts are a point-in-time snapshot - ss has no per-connection timestamps, so this is a distribution, not a time series'+(mode!=="country"?" (enable Online Geo/ASN lookups for country grouping)":"")+'.</div>'
      +rows.join("")+'</div>';
  }catch(e){ return ""; }
}
function renderLogon(){
  try{ $("logonChart").innerHTML=logonChartHtml(); }catch(elc){}   // v1.5
  renderLateral();   // v0.14: outbound-SSH evidence panel sits above the logon table
  // v0.11: aggregate-by-source-IP view (brute-force triage) - same table chrome, different columns
  var brute=false; try{ brute=$("bruteOnly").checked; }catch(eb){}
  if(LOGON_BYIP){
    // v1.6: NBH aggregates only the out-of-hours events, so first/last/counts reflect the filter
    var arows=[], agg=buildLogonByIp(NBHONLY?nbhLogonSubset():null);
    for(var a2=0;a2<agg.length;a2++){ if(!passQ(agg[a2])) continue;
      if(brute && agg[a2].fails<BRUTE_THRESH) continue;   // v1.3: brute sources = 5+ failures
      arows.push(agg[a2]); }
    sortRows(arows,LIPCOLS,SORT.logonip); drawTable(LIPCOLS,arows,SORT.logonip,"logonip");
    if(!agg.length){ $("tbl").innerHTML='<thead><tr><th>Logons by source IP</th></tr></thead><tbody><tr><td class="muted">No logon rows carry a source IP in this capture.</td></tr></tbody>'; $("count").innerHTML="0 rows"; }
    else $("count").innerHTML+=(brute?" · brute-force sources only (5+ failures)":"")+" · aggregated from "+nf(NBHONLY?nbhLogonSubset().length:LOGON.length)+" logon rows - click a row for detail, By source IP again for the flat view"+(NBHONLY?nbhNote():"");
    return;
  }
  populateLogonFilters();
  var hideLL=true; try{ hideLL=$("logfHideLastlog").checked; }catch(ehl){}
  var frSel=mdSet("logfResult"), llHidden=0;
  var rows=[]; for(var i=0;i<LOGON.length;i++){ var r=LOGON[i];
    if(!passQ(r)) continue;
    if(brute && !isBruteLogon(r)) continue;                 // v1.3: brute-force-only
    if(!mdPass("logfUser", trimStr(r.user))) continue;      // v0.17 multiselects
    if(!mdPass("logfSrc", logonSrcType(r))) continue;
    if(!mdPass("logfResult", r.result)) continue;
    // v0.15: lastlog rows are per-account STATE (shown on Users) - hidden here by default,
    // unless the result filter explicitly includes last-login
    if(hideLL && r.result==="last-login" && !(frSel && frSel["last-login"])){ llHidden++; continue; }
    if((DFROM||DTO) && r.epoch){ if(!inDay(logonDay(r.epoch))) continue; }   // case window filters logons too
    if(NBHONLY && !(r.epoch && isNbh(r.epoch))) continue;   // v1.6: non-business hours
    rows.push(r); }
  sortRows(rows,LCOLS,SORT.logon); drawTable(LCOLS,rows,SORT.logon,"logon");
  if(NBHONLY && LOGON.length) $("count").innerHTML+=nbhNote();
  if(brute && LOGON.length) $("count").innerHTML+=' · <span class="tag sus">brute-force only</span> (failures + the eventual success from any IP with '+BRUTE_THRESH+'+ failures)';
  if(llHidden && !brute) $("count").innerHTML+=' · '+nf(llHidden)+' lastlog state rows hidden <span class="muted">(Users tab shows them; untick "hide lastlog rows" to mix them in)</span>';
  if(!LOGON.length){ $("tbl").innerHTML='<thead><tr><th>Logons</th></tr></thead><tbody><tr><td class="muted">No auth.log / wtmp / btmp / lastlog / last / lastb events in this capture. Empty on hosts with no interactive logins (e.g. WSL); on a server this view fills with SSH, sudo, pkexec, pam session and account-change events.</td></tr></tbody>'; $("count").innerHTML="0 rows"; }
  else if(CRON_SESSIONS>0){ $("count").innerHTML+=' · '+nf(CRON_SESSIONS)+' root-cron pam sessions hidden as noise'; }
}

/* timeline table */
/* single TZ-aware formatter: tzAdj() shifts the epoch, then getUTC* reads the shifted wall clock.
   Default is UTC; the Logs/table "host TZ" toggle flips TZVIEW. */
function fmtTime(sec, withSecs){ if(!sec) return "-"; var d=new Date(tzAdj(sec)*1000);
  var s=d.getUTCFullYear()+"-"+p2n(d.getUTCMonth()+1)+"-"+p2n(d.getUTCDate())+" "+p2n(d.getUTCHours())+":"+p2n(d.getUTCMinutes());
  if(withSecs) s+=":"+p2n(d.getUTCSeconds()); return s; }
function epochShort(sec){ return fmtTime(sec,false); }
var TCOLS=[
  {h:"Score / tags", tip:"Suspicion score (>=3 is flagged) plus scoring tags - hover a tag for the full reasons", sk:function(r){return r.score;}, cell:function(r){return scoreCell(r);}},
  {h:"mtime (UTC)", tip:"Content-modified time (bodyfile epoch; detail pane shows atime/crtime too)", sk:function(r){return r.mtime;}, cell:function(r){return '<td class="mono">'+esc(epochShort(r.mtime))+'</td>';}},
  {h:"ctime (UTC)", tip:"Inode-changed time (metadata: permissions/owner/link changes)", sk:function(r){return r.ctime;}, cell:function(r){return '<td class="mono muted">'+esc(epochShort(r.ctime))+'</td>';}},
  {h:"Size", tip:"File size", sk:function(r){return r.size;}, cell:function(r){return '<td class="mono" style="text-align:center">'+esc(fmtSize(r.size))+'</td>';}},
  {h:"Mode", tip:"Unix mode string (s = setuid/setgid bit, scored)", sk:function(r){return r.mode;}, cell:function(r){return '<td class="mono">'+esc(r.mode)+'</td>';}},
  {h:"UID", tip:"Owner uid", sk:function(r){return parseInt(r.uid,10)||0;}, cell:function(r){return '<td class="mono" style="text-align:center">'+esc(r.uid)+'</td>';}},
  {h:"Path", tip:"Full path on the collected host", sk:function(r){return lc(r.path);}, cell:function(r){return '<td class="mono" title="'+esc(r.path)+'">'+esc(trunc(r.path,150))+'</td>';}}
];
function renderTime(){ var rows=[]; for(var i=0;i<TIMEL.length;i++){ var r=TIMEL[i];
    if(!passQ(r)) continue;
    // v0.11 pivot window: any timestamp inside ±15 min of the anchor keeps the row
    if(PIVOT){ if(!((r.mtime>=PIVOT.from&&r.mtime<=PIVOT.to)||(r.ctime>=PIVOT.from&&r.ctime<=PIVOT.to)
                  ||(r.crtime>=PIVOT.from&&r.crtime<=PIVOT.to)||(r.atime>=PIVOT.from&&r.atime<=PIVOT.to))) continue; }
    if(NBHONLY && !nbhTimeRow(r)) continue;   // v1.6: non-business hours (any of the four times)
    rows.push(r); }
  sortRows(rows,TCOLS,SORT.time); drawTable(TCOLS,rows,SORT.time,"time");
  if(NBHONLY && TIMEL.length) $("count").innerHTML+=nbhNote();
  if(PIVOT && TIMEL.length) $("count").innerHTML+=' · <span class="tag sus">pivot ±15 min @ '+esc(fmtTime(PIVOT.center,true))+' '+esc(tzLabel())+'</span> <span class="lnk" onclick="clearPivot()">clear</span>';
  profileEmptyMsg(TIMEL.length,"filesystem timeline (bodyfile)"); }

/* inventory table (v0.3) - catalog map of key artifacts; click "open folder" to see the raw file */
function renderInventory(){
  var rows=[]; for(var i=0;i<INVENTORY.length;i++){ var it=INVENTORY[i];
    if(QUERY && it.blob.indexOf(QUERY)<0) continue;
    rows.push(it); }
  var present=0; for(i=0;i<INVENTORY.length;i++) if(INVENTORY[i].present) present++;
  var html='<thead><tr><th title="Artifact category (processes / network / logons / logs / ...)">Category</th>'
    +'<th title="The specific collected artifact">Artifact</th>'
    +'<th title="What this artifact is used for in triage">Description</th>'
    +'<th title="Whether this capture contains it (absent is normal for narrower profiles)">Present</th>'
    +'<th title="Size, or file count for directory artifacts">Size / files</th>'
    +'<th title="Open the raw file in Explorer">Raw file</th></tr></thead><tbody>';
  for(i=0;i<rows.length;i++){ var r=rows[i];
    var pres = r.present ? '<span class="pgood">present</span>' : '<span class="pmiss">absent</span>';
    var sz = r.present ? ((r.kind==="dir"||r.kind==="userfile") ? (nf(r.count)+" file(s)"+(r.size?(", "+fmtSize(r.size)):"")) : fmtSize(r.size)) : "-";
    var open = r.present && r.path ? '<span class="lnk" data-open="'+esc(r.path)+'" title="Open the containing folder in Explorer (file selected)">open folder</span>' : '<span class="muted">-</span>';
    html+='<tr'+(r.present?"":' style="opacity:.55"')+'><td class="mono muted">'+esc(r.cat)+'</td><td>'+esc(r.name)+'</td>'
      +'<td class="muted">'+esc(r.desc)+'</td><td>'+pres+'</td><td class="mono">'+esc(sz)+'</td><td class="mono">'+open+'</td></tr>'; }
  html+="</tbody>"; $("tbl").innerHTML=html;
  $("count").innerHTML=nf(present)+" of "+nf(INVENTORY.length)+" key artifacts present"+(QUERY?(" ("+nf(rows.length)+" match filter)"):"");
  applyFreeze(); setupColResizeFor($("tbl"),"inv");
  window.__fullRows=[];   // inventory has no scored rows to export via the standard path
}

/* ---------- Logs tab (v0.4) ---------- */
function sevCls(s){ return s>=3?"sc5":(s>=2?"sc3":(s>=1?"sc1":"sc0")); }
function renderLogs(){
  $("logsHint").innerHTML=(PROFILE.logsOnly?"logs-only collection":"")+(JOURNALX.loaded?("  ·  "+esc(JOURNALX.note)):(resolveWsl()?"  ·  WSL detected - click to read journal contents":"  ·  WSL not found (journal content ingestion unavailable)"));
  var H=[];
  // v0.15: the cloud-init provisioning baseline moved to the Overview tab (cloudInitHtml)
  // log integrity
  H.push('<div class="card"><h3 title="Tamper and coverage checks across the logs: utmp record alignment, broken rotation chains, out-of-order timestamps, zero-byte critical logs, journal rotation anomalies and hostname consistency.">Log integrity <span class="muted" style="font-weight:400;text-transform:none">- Tamper / rotation / alignment / coverage checks</span></h3>');
  if(!INTEGRITY.length){ H.push('<div class="ok" style="font-size:12px">No integrity anomalies detected (utmp record alignment, log rotation chain, timestamp ordering, journal coverage, hostname consistency all clean).</div>'); }
  else { H.push('<div class="scroll" style="max-height:26vh"><table><thead><tr><th>Sev</th><th>Check</th><th>Detail</th></tr></thead><tbody>');
    for(var i=0;i<INTEGRITY.length;i++){ var it=INTEGRITY[i];
      H.push('<tr'+(it.sev>=3?' class="row-flag"':(it.sev>=2?' class="row-warn"':''))+'><td class="first"><span class="sc '+sevCls(it.sev)+'">'+(it.sev||0)+'</span></td><td class="mono muted">'+esc(it.check)+'</td><td class="mono">'+esc(it.detail)+'</td></tr>'); }
    H.push('</tbody></table></div>'); }
  H.push('</div>');
  // systemd journal coverage
  H.push('<div class="card"><h3>systemd journal coverage <span class="muted" style="font-weight:400;text-transform:none">- Decoded from journal filenames; a long gap + generation change can mean the journal was vacuumed/cleared</span></h3>');
  if(!JOURNAL){ H.push('<div class="muted" style="font-size:12px">No systemd journal files in this capture.</div>'); }
  else { var J=JOURNAL;
    H.push('<div>'+statCard(nf(J.sysCount+J.userCount),"journal files","")
      +statCard(nf(J.generations),"generations", J.generations>1?"warn":"")
      +statCard(J.median?J.median.toFixed(1)+"d":"-","median rotation","")
      +statCard(nf(J.flagged.length),"flagged gaps", J.flagged.length?"flag":"")+'</div>');
    if(J.span) H.push('<div class="muted mono" style="font-size:12px;margin:4px 0">Archived coverage '+esc(fmtUsec(J.span.from))+' → '+esc(fmtUsec(J.span.to))
      +(J.activeSys?('  ·  '+J.activeSys+' active/live journal(s) extend coverage to collection time'):'')+'</div>');
    if(J.flagged.length){ H.push('<div class="scroll" style="max-height:20vh"><table><thead><tr><th>Gap (days)</th><th>From</th><th>To</th><th>Note</th></tr></thead><tbody>');
      for(i=0;i<J.flagged.length;i++){ var g=J.flagged[i];
        H.push('<tr'+(g.genChange?' class="row-flag"':' class="row-warn"')+'><td class="mono first">'+g.days.toFixed(1)+'</td><td class="mono">'+esc(fmtUsec(g.from))+'</td><td class="mono">'+esc(fmtUsec(g.to))+'</td><td class="mono">'+(g.genChange?'<span class="tag sus">generation change</span>':'—')+'</td></tr>'); }
      H.push('</tbody></table></div>'); }
  }
  // v0.14: the journalctl --list-boots table moved to the Overview tab (bootsHtml)
  H.push('</div>');
  // syslog service inventory
  H.push('<div class="cards3"><div class="col3" style="width:49%"><div class="card"><h3>Service inventory <span class="muted" style="font-weight:400;text-transform:none">- programs writing to syslog (a poor-man\'s process list when live_response wasn\'t collected)</span></h3>');
  if(!SYSLOGSVC.length){ H.push('<div class="muted" style="font-size:12px">No syslog / messages in this capture.</div>'); }
  else { H.push('<div class="scroll" style="max-height:30vh"><table><thead><tr><th>Program</th><th>Lines</th></tr></thead><tbody>');
    for(i=0;i<SYSLOGSVC.length && i<40;i++){ var sv=SYSLOGSVC[i]; var flag=/tailscal|ngrok|teamviewer|anydesk|nc\b|socat|xmrig|miner|cloudflared|frpc|chisel/i.test(sv.prog);
      H.push('<tr'+(flag?' class="row-warn"':'')+'><td class="mono'+(flag?' first':'')+'">'+esc(sv.prog)+(flag?' <span class="tag sus">remote/exposure</span>':'')+'</td><td class="mono" style="text-align:right">'+nf(sv.n)+'</td></tr>'); }
    H.push('</tbody></table></div>'); }
  H.push('</div></div>');
  // notable events
  H.push('<div class="col3" style="width:49%"><div class="card"><h3 title="High-signal one-off events pulled from syslog / kern.log: OOM kills, promiscuous-mode (sniffer) interfaces, USB attaches, kernel module / taint events, cron execution and new-unit summaries.">Notable log events <span class="muted" style="font-weight:400;text-transform:none">- OOM / promisc / USB / modules / cron / units</span></h3>');
  if(!LOGEVENTS.length){ H.push('<div class="muted" style="font-size:12px">No notable events (OOM kills, promiscuous mode, USB/module loads, cron/unit summaries).</div>'); }
  else { H.push('<div class="scroll" style="max-height:30vh"><table><thead><tr><th>Kind</th><th>Detail</th></tr></thead><tbody>');
    var ev=LOGEVENTS.slice(0); ev.sort(function(a,b){ return (b.sev||0)-(a.sev||0); });
    for(i=0;i<ev.length && i<60;i++){ var e=ev[i];
      H.push('<tr'+(e.sev>=3?' class="row-flag"':(e.sev>=2?' class="row-warn"':''))+'><td class="mono muted'+(e.sev>=2?' first':'')+'">'+esc(e.kind)+'</td><td class="mono">'+esc(e.detail)+'</td></tr>'); }
    H.push('</tbody></table></div>'); }
  H.push('</div></div></div>');
  // v0.13: the sar CPU summary moved to the TOP of the Overview tab (sarSummaryHtml)
  $("logsBody").innerHTML=H.join("");
  var tbls=$("logsBody").getElementsByTagName("table");
  for(var t=0;t<tbls.length;t++){ setupColResizeFor(tbls[t],"logs"+t); }
  bindFreezeAll($("logsBody"));   // frozen headers on Service inventory / Notable events / etc.
}

/* ---------- Events tab (v0.6: unified timeline) ---------- */
var EVFROM=0, EVTO=0, EVQ="";
/* v0.14: the "notable" event kinds (the Logs-tab notable-events set + boots/journal anomalies) */
var NOTABLE_KINDS={ oom:1, promisc:1, usb:1, module:1, hosts:1, cron:1, units:1, boot:1, "journal-gap":1, attribution:1 };
function populateEvKind(){ var ks={}, i; for(i=0;i<EVENTS.length;i++){ ks[EVENTS[i].kind]=(ks[EVENTS[i].kind]||0)+1; } mdPopulate("evKind", ks); }
function renderEvents(){
  populateEvKind();
  var minSc=parseInt($("evMinScore").value,10)||0;
  var toolOnly=false, notable=false, nbhE=false; try{ toolOnly=$("evToolOnly").checked; notable=$("evNotable").checked; nbhE=$("evNbh").checked; }catch(eht){}
  var rows=[], i;
  for(i=0;i<EVENTS.length;i++){ var e=EVENTS[i];
    if(e.score<minSc) continue;
    if(!mdPass("evKind", e.kind)) continue;   // v0.17 multiselect
    if(notable && !NOTABLE_KINDS[e.kind]) continue; // v0.14: notable-events filter
    if(toolOnly && !hasTag(e,"TOOLING")) continue;  // v1.4: TOOLING only - spot recently installed dual-use tools
    if(nbhE && !(e.epoch && isNbh(e.epoch))) continue;  // v1.6: non-business hours
    if(EVQ && e.blob.indexOf(EVQ)<0) continue;
    if(EVFROM||EVTO){ var d=eventDay(e.epoch); if(EVFROM && d<EVFROM) continue; if(EVTO && d>EVTO) continue; }
    rows.push(e);
  }
  var shown=rows.length>MAXROWS?MAXROWS:rows.length;
  var html='<thead><tr><th title="Event time - click a cell to pivot the Timeline ±15 min">When ('+esc(tzLabel())+')</th>'
    +'<th title="Event kind: logon / package / boot / journal-gap / web / audit / history / ...">Kind</th>'
    +'<th title="Suspicion score carried over from the source row">Score</th>'
    +'<th title="Event summary - hover for the full text">Event</th>'
    +'<th title="Which parser/artifact produced this event">Source</th></tr></thead><tbody>';
  if(!EVENTS.length) html+='<tr><td colspan="5" class="muted">No time-stamped events yet. Analyze a capture; on the Logs tab, "Load journal contents (WSL)" adds journal events.</td></tr>';
  for(i=0;i<shown;i++){ var r=rows[i]; var rc=r.score>=5?"row-flag":(r.score>=3?"row-warn":"");
    html+='<tr'+(rc?(' class="'+rc+'"'):'')+'><td class="mono lnk" data-ep="'+r.epoch+'" title="Click: pivot the Timeline tab to ±15 min around this event">'+esc(fmtTime(r.epoch,true))+'</td>'
      +'<td class="mono muted">'+esc(r.kind)+'</td>'
      +'<td class="mono"><span class="sc '+scClass(r.score)+'">'+r.score+'</span></td>'
      +'<td class="mono" title="'+esc(r.label)+'">'+esc(trunc(r.label,110))+'</td>'
      +'<td class="mono muted">'+esc(r.src)+'</td></tr>'; }
  html+='</tbody>'; $("evTbl").innerHTML=html;
  $("evCount").innerHTML=nf(rows.length)+" event"+(rows.length===1?"":"s")+(shown<rows.length?(" (showing "+nf(shown)+")"+capWarnHtml(rows.length,MAXROWS)):"")
    +(nbhE?nbhNote():"")
    +(JOURNALX.loaded?"":' · <span class="lnk" onclick="loadJournalWsl()">load journal (WSL)</span> for more');
  setupColResizeFor($("evTbl"),"events");
  bindFreeze($("evScroll"), $("evTbl"));   // frozen header
}
function eventDay(ep){ if(!ep) return 0; var d=new Date(ep*1000);
  return Number(d.getUTCFullYear()+""+p2n(d.getUTCMonth()+1)+p2n(d.getUTCDate())); }
function exportEvents(){
  if(!EVENTS.length){ setStatus("No events to export","err"); return; }
  var lines=["When_"+tzLabel()+",Epoch,Kind,Score,Tags,Event,Source"];
  for(var i=0;i<EVENTS.length;i++){ var e=EVENTS[i];
    lines.push([cq(fmtTime(e.epoch,true)),cq(e.epoch),cq(e.kind),cq(e.score),cq((e.tags||[]).join(";")),cq(e.label),cq(e.src)].join(",")); }
  var dir=LASTOUTDIR||$("outDir").value, path=dir+"\\events_timeline_"+nowStamp()+".csv";
  try{ writeUtf8(path, lines.join("\r\n")); setStatus("Exported "+nf(EVENTS.length)+" events → "+path,"ok"); }
  catch(e){ setStatus("Export failed: "+e.message,"err"); }
}

/* ioc hits table */
var ICOLS=[
  {h:"File", tip:"Capture-relative path of the file the IOC term matched in", sk:function(r){return lc(r.file);}, cell:function(r){return '<td class="mono first" title="'+esc(r.file)+'">'+esc(trunc(r.file,80))+'</td>';}},
  {h:"Line", tip:"Line number of the match (0 = hash_executables SHA1 match)", sk:function(r){return r.line;}, cell:function(r){return '<td class="mono" style="text-align:right">'+esc(r.line)+'</td>';}},
  {h:"IOC", tip:"The operator-supplied IOC/keyword term that matched", sk:function(r){return r.ioc;}, cell:function(r){return '<td class="mono"><span class="tag ioc">'+esc(r.ioc)+'</span></td>';}},
  {h:"Excerpt", tip:"The matching line (truncated to 300 chars at sweep time)", sk:function(r){return lc(r.excerpt);}, cell:function(r){return '<td class="mono" title="'+esc(r.excerpt)+'">'+esc(trunc(r.excerpt,140))+'</td>';}}
];
function renderIoc(){
  var rows=[]; for(var i=0;i<IOCHITS.length;i++){ var r=IOCHITS[i];
    if(QUERY){ var bl=lc(r.file+" "+r.ioc+" "+r.excerpt); if(bl.indexOf(QUERY)<0) continue; }
    rows.push(r); }
  var st=SORT.ioc, sk=ICOLS[st.k].sk, dir=st.d;
  rows.sort(function(a,b){ var x=sk(a),y=sk(b);
    if(typeof x==="number"&&typeof y==="number") return (x-y)*dir;
    x=String(x); y=String(y); return x<y?-dir:(x>y?dir:0); });
  var shown=rows.length>MAXROWS?MAXROWS:rows.length;
  var html="<thead><tr>";
  for(var c=0;c<ICOLS.length;c++){ var arrow=(st.k===c)?(st.d>0?" ▲":" ▼"):"";
    html+='<th data-k="'+c+'" title="'+esc((ICOLS[c].tip?ICOLS[c].tip+" · ":"")+"Click to sort; drag the right edge to resize")+'">'+esc(ICOLS[c].h)+arrow+'</th>'; }
  html+="</tr></thead><tbody>";
  if(!IOCS.length){ html+='<tr><td colspan="4" class="muted">No IOC / keyword terms loaded - add some via "IOC / keywords…" then re-Analyze to sweep the tree.</td></tr>'; }
  else if(!rows.length){ html+='<tr><td colspan="4" class="ok">No IOC hits in the swept tree.</td></tr>'; }
  for(var i2=0;i2<shown;i2++){ var rr=rows[i2]; html+='<tr class="ioc">';
    for(var k=0;k<ICOLS.length;k++){ html+=ICOLS[k].cell(rr); } html+="</tr>"; }
  html+="</tbody>"; $("tbl").innerHTML=html;
  $("count").innerHTML=nf(rows.length)+" hit"+(rows.length===1?"":"s")+(shown<rows.length?(" (showing "+nf(shown)+")"+capWarnHtml(rows.length,MAXROWS)):"");
  var ths=$("tbl").getElementsByTagName("th");
  for(var j=0;j<ths.length;j++){ ths[j].onclick=function(e){ e=e||window.event; var t=e.target||e.srcElement;
    if(t && /\bcgrip\b/.test(t.className+"")) return;
    var kk=parseInt(this.getAttribute("data-k"),10);
    if(st.k===kk) st.d*=-1; else { st.k=kk; st.d=1; } render(); }; }
  applyFreeze(); setupColResize();
  window.__viewRows=rows.slice(0,shown); window.__fullRows=rows;
}

/* ---------- detail pane ---------- */
function detField(k,v){ return '<div><span class="kv">'+esc(k)+':</span> '+esc(v||"-")+'</div>'; }
function openRowDetail(idx){
  var rows=window.__viewRows||[]; if(idx<0||idx>=rows.length) return;
  var r=rows[idx]; DETREC=r; DETKIND=TAB;
  var h="";
  if(TAB==="proc"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(trunc(r.cmd,120))+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("PID", r.pid+(r.hidden?"  (HIDDEN from ps)":""));
    h+=detField("PPID", r.ppid);
    h+=detField("User", r.user);
    h+=detField("Started", r.start);
    if(r.cpu>=0) h+=detField("CPU / Mem at collection", r.cpu.toFixed(1)+"% / "+r.mem.toFixed(1)+"%  (top -b -n1)");
    if(r.sshFrom) h+=detField("SSH origin (environ)", r.sshFrom);
    h+=detField("Executable", r.exe+(r.deleted?"  (DELETED from disk while running)":""));
    h+=detField("SHA1", r.sha1);
    h+=detField("Command", r.cmd);
    h+='</div>';
    // process tree: parent chain + children
    var anc=ancestry(r);
    if(anc.length){ var ap=[]; for(var ai=anc.length-1;ai>=0;ai--) ap.push(procName(anc[ai])+"("+anc[ai].pid+")");
      h+='<div class="dl"><span class="kv">Ancestry:</span> '+esc(ap.join("  ->  "))+"  ->  <b>"+esc(procName(r))+"("+esc(r.pid)+")</b>"; }
    else h+='<div class="dl"><span class="kv">Ancestry:</span> <b>'+esc(procName(r))+"("+esc(r.pid)+")</b>";
    var kids=PROCKIDS[r.pid]||[];
    if(kids.length){ var kl=[]; for(var ki=0;ki<kids.length && ki<20;ki++){ var kr=PROCBYPID[kids[ki]]; kl.push((kr?procName(kr):"?")+"("+kids[ki]+")"); }
      h+='<br><span class="kv">Children ('+kids.length+'):</span> '+esc(kl.join(", "))+(kids.length>20?" …":""); }
    h+='</div>';
    if(r.lsofNet && r.lsofNet.length){ h+='<div class="dl"><span class="kv">Open sockets (lsof):</span><br>'; for(var li=0;li<r.lsofNet.length && li<12;li++) h+=esc(r.lsofNet[li])+"<br>"; h+='</div>'; }
    if(r.lsofDel && r.lsofDel.length){ h+='<div class="dl"><span class="kv">Deleted files held open (lsof):</span><br>'; for(var di=0;di<r.lsofDel.length && di<10;di++) h+=esc(r.lsofDel[di])+"<br>"; h+='</div>'; }
  } else if(TAB==="net"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.proto+" "+r.local+" → "+r.peer)+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Protocol", r.proto);
    h+=detField("State", r.state);
    h+=detField("Local", r.local);
    h+=detField("Remote", r.peer+(r.peerAddr&&!ipIsLocal(r.peerAddr)?"  (public)":""));
    h+=detField("Process", r.procName+(r.procPid?(" (pid "+r.procPid+")"):"")+(r.procRaw?("  "+r.procRaw):""));
    h+='</div>';
  } else if(TAB==="time"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(trunc(r.path,120))+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Path", r.path);
    h+=detField("Mode", r.mode);
    h+=detField("Size", fmtSize(r.size)+" ("+nf(r.size)+" bytes)");
    h+=detField("UID / GID", r.uid);
    h+=detField("mtime (UTC)", epochFull(r.mtime));
    h+=detField("atime (UTC)", epochFull(r.atime));
    h+=detField("ctime (UTC)", epochFull(r.ctime));
    h+=detField("crtime (UTC)", epochFull(r.crtime));
    h+='</div>';
  } else if(TAB==="logon" && r.kind==="logonip"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.ip)+'</b> '+tagsHtml(r)+geoTag(r.ip)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Geo / ASN", geoTip(r.ip)||"(not resolved - online geo/ASN off, offline mode, or lookup pending)");
    h+=detField("First seen ("+tzLabel()+")", r.first?fmtTime(r.first,true):"-");
    h+=detField("Last seen ("+tzLabel()+")", r.last?fmtTime(r.last,true):"-");
    h+=detField("Failures / successes", nf(r.fails)+" / "+nf(r.okc)+(r.fails>=5&&r.okc?"   (SUCCESS AFTER BRUTE-FORCE VOLUME)":""));
    h+=detField("Users tried ("+r.userN+")", r.userList);
    h+='</div>';
    if(r.last) h+='<div class="dl"><span class="lnk" onclick="pivotTimeline('+r.last+')">Open Timeline ±15 min around the last event from this IP</span></div>';
  } else if(TAB==="logon"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.result+" - "+r.user)+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("When ("+tzLabel()+")", logonWhenCell(r));
    h+=detField("Result", r.result);
    h+=detField("User", r.user);
    h+=detField("Source", (r.ip||"(local)")+(r.ip&&!ipIsLocal(r.ip)?"  (public)":(r.ip?"  (local/RFC1918)":""))+(geoTip(r.ip)?("  ·  "+geoTip(r.ip)):""));
    h+=detField("Method", r.method);
    if(r.cmd) h+=detField("Command", r.cmd);
    if(r.line) h+=detField(r.result==="last-login"?"Terminal":"tty / key", r.line);
    h+=detField("Source artifact", r.src);
    h+='</div>';
    if(r.epoch) h+='<div class="dl"><span class="lnk" onclick="pivotTimeline('+r.epoch+')" title="What changed on disk around this logon?">Open Timeline ±15 min around this logon</span></div>';
  } else if(TAB==="web"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.method+" "+trunc(r.uri,100))+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("When ("+tzLabel()+")", r.epoch?fmtTime(r.epoch,true):"-");
    h+=detField("Client IP", r.ip+(geoTip(r.ip)?("  ·  "+geoTip(r.ip)):""));
    h+=detField("Request", r.method+" "+r.uri);
    h+=detField("Status / bytes", r.status+" / "+r.bytes);
    if(r.ref && r.ref!=="-") h+=detField("Referer", r.ref);
    h+=detField("User-Agent", r.ua);
    h+=detField("Log file", r.src);
    h+='</div>';
    if(r.epoch) h+='<div class="dl"><span class="lnk" onclick="pivotTimeline('+r.epoch+')" title="What changed on disk around this request (web-shell plant)?">Open Timeline ±15 min around this request</span></div>';
  } else if(TAB==="users" && r.kind==="group"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.group)+' (gid '+esc(r.gid)+')</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Members ("+r.userN+")", r.users.join(", ")||"(none)");
    h+='</div>';
  } else if(TAB==="users"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.user)+' (uid '+r.uid+')</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Shell", r.shell+(r.interactive?"":"  (non-interactive)"));
    h+=detField("Home", r.home);
    h+=detField("Groups", r.groups.join(", ")||"-");
    h+=detField("Enabled", (function(){ var e=userEnabled(r); return e===true?"yes - interactive shell with usable password or SSH keys":(e===false?"no - non-interactive shell, or locked with no keys":"unknown - shadow not collected and no SSH keys to prove access"); })());
    h+=detField("Password", r.locked===null?"shadow not collected":(r.locked?"locked/disabled":(r.hasPw?"hash set":"EMPTY - passwordless login")));
    h+=detField("authorized_keys entries", String(r.keys));
    h+=detField("Shell-history lines", nf(r.hist));
    h+=detField("Last login", r.lastEp?(fmtTime(r.lastEp,true)+" "+tzLabel()+(r.lastIp?(" from "+r.lastIp):"")):"(none recorded)");
    h+='</div>';
  } else if(TAB==="actions"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.user)+' <span class="muted">('+esc(r.shell)+')</span></b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("When ("+tzLabel()+")", r.epoch?fmtTime(r.epoch,true):"(no timestamp in history - order only)");
    h+=detField("User", r.user);
    h+=detField("Shell history", r.shell);
    h+='</div>';
    h+='<div class="dl"><span class="kv">Command:</span><br><span class="mono" style="white-space:pre-wrap;word-break:break-all">'+esc(r.cmd)+'</span></div>';
    if(r.epoch) h+='<div class="dl"><span class="lnk" onclick="pivotTimeline('+r.epoch+')" title="What changed on disk around this command?">Open Timeline ±15 min around this command</span></div>';
  } else if(TAB==="ssh"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.kind+" - "+r.scope)+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("Kind", r.kind);
    h+=detField("Scope", r.scope);
    h+=detField("Algorithm", r.algo+(r.rawAlgo&&r.rawAlgo!==r.algo?("  ("+r.rawAlgo+")"):""));
    if(r.comment) h+=detField("Comment", r.comment);
    if(r.id) h+=detField("Key id (short)", r.id);
    if(r.priv){ h+=detField("Passphrase", r.nullpass===true?"NONE - UAC verified this key is usable without a passphrase":(r.encrypted===true?"encrypted (passphrase-protected)":"unknown - private-key body present but passphrase state not determinable from headers")); }
    if(r.kind==="authorized_keys"){
      h+=detField("Source restriction", r.restricted?"yes (from=/restrict/no-pty present)":"NONE - this key may connect from anywhere");
      if(r.forced) h+=detField("Forced command", r.forced);
      if(r.options) h+=detField("Options", r.options);
    }
    h+=detField("File", r.file);
    if(r.blob) h+=detField("Key material (base64)", trunc(r.blob,120)+(r.blob.length>120?" …":""));
    h+='</div>';
    var sshp=sshRawPath(r);
    if(sshp) h+='<div class="dl"><span class="lnk" data-open="'+esc(sshp)+'" title="Open the containing folder in Explorer">open source file</span></div>';
  } else if(TAB==="audit"){
    h+='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(r.typ+(r.user?(" - "+r.user):""))+'</b> '+tagsHtml(r)+'</div>';
    h+=reasonsBlock(r);
    h+='<div class="dl">';
    h+=detField("When ("+tzLabel()+")", r.epoch?fmtTime(r.epoch,true):"-");
    h+=detField("Type", r.typ);
    h+=detField("User", r.user);
    if(r.ip) h+=detField("Source IP", r.ip+(geoTip(r.ip)?("  ·  "+geoTip(r.ip)):""));
    if(r.res) h+=detField("Result", r.res);
    h+=detField("Detail", r.detail);
    h+=detField("Audit event id", r.id);
    h+='</div>';
    if(r.epoch) h+='<div class="dl"><span class="lnk" onclick="pivotTimeline('+r.epoch+')">Open Timeline ±15 min around this record</span></div>';
  }
  $("detBody").innerHTML=h; $("detCopy").style.display=""; showEl("detailCard",true);
}
function reasonsBlock(r){
  var tech=techsForTags(r.tags||[]), tl="";
  if(tech.length){ var a=[]; for(var t=0;t<tech.length;t++) a.push(tech[t].id+" ("+tech[t].name+")"); tl='<div style="font-size:11px;color:#8b949e;margin-bottom:6px">ATT&CK: '+esc(a.join(" · "))+'</div>'; }
  if(!r.reasons||!r.reasons.length) return '<div class="muted" style="font-size:12px;margin-bottom:6px">Not flagged (score '+r.score+').</div>'+tl;
  var h='<div style="font-size:12px;color:#ff9b9b;margin-bottom:6px">Score '+r.score+':<br>'; for(var i=0;i<r.reasons.length;i++) h+="&bull; "+esc(r.reasons[i])+"<br>"; return h+'</div>'+tl; }
function epochFull(sec){ if(!sec) return "-"; return fmtTime(sec,true)+" "+tzLabel()+" ("+sec+")"; }
function openPersistFile(idx){
  var it=PERSIST[idx]; if(!it||!it.path) return;
  DETREC=null; DETKIND="persist";
  var body="";
  try{ if(it.size>1048576) body="(file is "+fmtSize(it.size)+" - too large to preview inline; open it in the output folder)";
    else body=readUtf8(it.path); }catch(e){ body="(could not read: "+e.message+")"; }
  var h='<div style="font-size:14px;margin-bottom:6px"><b>'+esc(it.label)+'</b> <span class="muted mono">'+esc(it.rel)+'</span></div>';
  h+='<div class="dl">'+esc(body)+'</div>';
  $("detBody").innerHTML=h; $("detCopy").style.display="none"; showEl("detailCard",true);
}
function closeDetail(){ DETREC=null; showEl("detailCard",false); $("detBody").innerHTML=""; }
function copyDetail(){
  if(!DETREC){ setStatus("Nothing to copy","err"); return; }
  var r=DETREC, out=[];
  if(DETKIND==="proc"){ out.push("PROCESS | score "+r.score+" | "+r.tags.join(","));
    out.push("pid "+r.pid+" ppid "+r.ppid+" user "+r.user+" started "+r.start);
    out.push("exe "+r.exe); if(r.sha1) out.push("sha1 "+r.sha1); out.push("cmd "+r.cmd); }
  else if(DETKIND==="net"){ out.push("CONNECTION | score "+r.score+" | "+r.tags.join(","));
    out.push(r.proto+" "+r.state+" "+r.local+" -> "+r.peer); out.push("process "+r.procName+" "+r.procRaw); }
  else if(DETKIND==="time"){ out.push("TIMELINE | score "+r.score+" | "+r.tags.join(","));
    out.push(r.path); out.push("mode "+r.mode+" size "+r.size+" uid "+r.uid);
    out.push("mtime "+epochFull(r.mtime)+" ctime "+epochFull(r.ctime)+" crtime "+epochFull(r.crtime)); }
  else if(DETKIND==="logon"){ out.push("LOGON | score "+r.score+" | "+r.tags.join(","));
    out.push(r.when+" (UTC) "+r.result+" "+r.user+" from "+(r.ip||"local")+" via "+r.method+" ["+r.src+"]"); }
  for(var i=0;i<r.reasons.length;i++) out.push("  - "+r.reasons[i]);
  try{ window.clipboardData.setData("Text", out.join("\r\n")); setStatus("Copied to clipboard","ok"); }
  catch(e){ setStatus("Copy failed: "+e.message,"err"); }
}

/* ---------- resizable columns (family verbatim, keyed per tab) ---------- */
function colwKey(){ return TAB; }
function colwFile(){ var d=htaFolder(); return d?(d+"\\UAC-Triage-Tool.colw.txt"):""; }
var COLW={}, DRAG=null;
function saveColw(){ var p=colwFile(); if(!p) return; var out=[],k;
  for(k in COLW){ if(COLW.hasOwnProperty(k)&&COLW[k]&&COLW[k].length) out.push(k+"="+COLW[k].join(",")); }
  try{ if(out.length) writeUtf8(p,out.join("\r\n")); else if(fileExists(p)) new ActiveXObject("Scripting.FileSystemObject").DeleteFile(p); }catch(e){} }
function loadColw(){ var p=colwFile(); if(!p||!fileExists(p)) return;
  try{ var lines=readUtf8(p).split(/\r?\n/);
    for(var i=0;i<lines.length;i++){ var ln=trimStr(lines[i]); if(!ln) continue; var eq=ln.indexOf("="); if(eq<1) continue;
      var key=ln.substring(0,eq), parts=ln.substring(eq+1).split(","), a=[], ok=true;
      for(var j=0;j<parts.length;j++){ var n=parseInt(parts[j],10); if(!(n>=40&&n<=1600)){ ok=false; break; } a.push(n); }
      if(ok&&a.length) COLW[key]=a; } }catch(e){} }
function curZoom(){ try{ var el=$("content"); var z=parseFloat(el.style.zoom||(el.currentStyle&&el.currentStyle.zoom)||"");
    if(!z && window.getComputedStyle) z=parseFloat(getComputedStyle(el).zoom); return (z&&z>0)?z:1; }catch(e){ return 1; } }
/* Generic per-table resize: works on ANY table (main data grid + every Overview table + Inventory).
   Each table carries its own persisted-width key in data-colwkey; grips find their table by DOM
   walk so one set of handlers serves them all. */
function setupColResizeFor(tbl, key){
  if(!tbl) return; var ths=tbl.getElementsByTagName("th"); if(!ths.length) return;
  tbl.setAttribute("data-colwkey", key);
  var w=COLW[key];
  if(w && w.length===ths.length){ tbl.style.tableLayout="fixed"; tbl.style.width="auto";
    for(var j=0;j<ths.length;j++) ths[j].style.width=w[j]+"px"; }
  else { tbl.style.tableLayout=""; tbl.style.width=""; }
  for(var i=0;i<ths.length;i++){ var g=document.createElement("div"); g.className="cgrip"; g.setAttribute("data-ci",String(i));
    g.title="Drag to resize this column - double-click to reset"; g.onmousedown=gripDown; g.ondblclick=gripReset; ths[i].appendChild(g); }
}
function setupColResize(){ setupColResizeFor($("tbl"), colwKey()); }
function gripTable(el){ var n=el; while(n && String(n.tagName).toUpperCase()!=="TABLE"){ n=n.parentNode; } return n; }
function gripDown(e){ e=e||window.event; var ci=parseInt(this.getAttribute("data-ci"),10);
  var tbl=gripTable(this); if(!tbl) return false; var ths=tbl.getElementsByTagName("th"); if(isNaN(ci)||ci<0||ci>=ths.length) return false;
  var key=tbl.getAttribute("data-colwkey")||colwKey();
  if(!COLW[key] || COLW[key].length!==ths.length){ var w=[]; for(var i=0;i<ths.length;i++) w.push(ths[i].offsetWidth);
    COLW[key]=w; tbl.style.tableLayout="fixed"; tbl.style.width="auto"; for(var j=0;j<ths.length;j++) ths[j].style.width=w[j]+"px"; }
  DRAG={key:key, ci:ci, x:(e.clientX||0), w:COLW[key][ci], th:ths[ci], z:curZoom()};
  document.onmousemove=gripMove; document.onmouseup=gripUp; document.onselectstart=function(){ return false; };
  if(e.preventDefault) e.preventDefault(); e.returnValue=false; if(e.stopPropagation) e.stopPropagation(); e.cancelBubble=true; return false; }
function gripMove(e){ e=e||window.event; if(!DRAG) return false; var w=Math.round(DRAG.w+((e.clientX||0)-DRAG.x)/DRAG.z);
  if(w<40) w=40; if(w>1600) w=1600; COLW[DRAG.key][DRAG.ci]=w; DRAG.th.style.width=w+"px"; return false; }
function gripUp(){ document.onmousemove=null; document.onmouseup=null; document.onselectstart=null; if(DRAG){ DRAG=null; try{ saveColw(); }catch(e){} } }
function gripReset(e){ e=e||window.event; document.onmousemove=null; document.onmouseup=null; document.onselectstart=null; DRAG=null;
  var tbl=gripTable(this); var key=tbl?(tbl.getAttribute("data-colwkey")||colwKey()):colwKey();
  COLW[key]=null; try{ saveColw(); }catch(er){} if(tbl){ tbl.style.tableLayout=""; tbl.style.width=""; } render();
  setStatus("Column widths reset","ok"); if(e){ if(e.stopPropagation) e.stopPropagation(); e.cancelBubble=true; } return false; }
function applyFreeze(){ var sc=$("tblScroll"); if(!sc) return; var ths=$("tbl").getElementsByTagName("th"); var y=sc.scrollTop;
  for(var i=0;i<ths.length;i++){ ths[i].style.top=y+"px"; } }
/* generic frozen-header: HTA/IE has no position:sticky, so on scroll we push each th down by the
   container's scrollTop (th is position:relative;z-index:3 globally). Works for any scroll+table. */
function freezeHeads(sc, tbl){ if(!sc||!tbl) return; var ths=tbl.getElementsByTagName("th"), y=sc.scrollTop;
  for(var i=0;i<ths.length;i++) ths[i].style.top=y+"px"; }
function bindFreeze(sc, tbl){ if(!sc||!tbl) return; sc.onscroll=function(){ freezeHeads(sc, tbl); }; freezeHeads(sc, tbl); }
/* freeze every table living inside a container's .scroll children (used for the Logs tab) */
function bindFreezeAll(container){ if(!container) return; var divs=container.getElementsByTagName("div");
  for(var i=0;i<divs.length;i++){ if(/\bscroll\b/.test(divs[i].className+"")){ var tb=divs[i].getElementsByTagName("table");
    if(tb.length) bindFreeze(divs[i], tb[0]); } } }
/* freeze a table by id, walking up to its nearest scrollable (.scroll) ancestor */
function freezeById(id){ var tb=$(id); if(!tb) return; var n=tb.parentNode;
  while(n && n.className!==undefined){ if(/\bscroll\b/.test(n.className+"")){ bindFreeze(n, tb); return; } n=n.parentNode; } }

/* ---------- export / copy ---------- */
function cq(v){ v=(v==null)?"":String(v);
  // v0.10 CSV formula-injection guard: captured strings are attacker-controlled; a leading = + - @
  // executes as a formula when the export opens in Excel. Excel's own text-literal prefix (') is
  // prepended unless the cell is a plain number or a unix mode string (data fidelity for those).
  if(/^[=+\-@]/.test(v) && !/^-?\d+(\.\d+)?$/.test(v) && !/^[-dlcbsp][-rwxsStT]{9}/.test(v)) v="'"+v;
  return /[",\r\n]/.test(v)?('"'+v.replace(/"/g,'""')+'"'):v; }
function fmtSize(n){ if(!n) return "0 B"; var u=["B","KB","MB","GB"], i=0; while(n>=1024&&i<u.length-1){n/=1024;i++;} return n.toFixed(i?1:0)+" "+u[i]; }
function exportView(){
  if(TAB==="inv"){ var il=["Category,Artifact,Description,Present,SizeBytes,Files,Path"];
    for(var iv=0;iv<INVENTORY.length;iv++){ var it=INVENTORY[iv];
      il.push([cq(it.cat),cq(it.name),cq(it.desc),cq(it.present?"present":"absent"),cq(it.size),cq(it.count),cq(it.path)].join(",")); }
    var idir=LASTOUTDIR||$("outDir").value, ipath=idir+"\\inventory_"+nowStamp()+".csv";
    try{ writeUtf8(ipath, il.join("\r\n")); setStatus("Exported inventory ("+nf(INVENTORY.length)+" artifacts) → "+ipath,"ok"); }catch(e){ setStatus("Export failed: "+e.message,"err"); }
    return; }
  var rows=window.__fullRows||[]; if(!rows.length){ setStatus("Nothing to export","err"); return; }
  var lines, head;
  if(TAB==="logon" && LOGON_BYIP){ head=["SourceIP","Geo","ASN","FirstSeen_"+tzLabel(),"LastSeen_"+tzLabel(),"Failures","Successes","UsersTried","UserList","Score","Tags"]; lines=[head.join(",")];
    for(var bi=0;bi<rows.length;bi++){ var br=rows[bi]; var bg=GEO[br.ip]||{};
      lines.push([cq(br.ip),cq(bg.country||""),cq(bg.asn||""),cq(br.first?fmtTime(br.first,true):""),cq(br.last?fmtTime(br.last,true):""),cq(br.fails),cq(br.okc),cq(br.userN),cq(br.userList),cq(br.score),cq(br.tags.join(";"))].join(",")); } }
  else if(TAB==="web"){ head=["Score","Tags","When_"+tzLabel(),"ClientIP","Geo","ASN","Method","Status","Bytes","URI","Referer","UserAgent","Log"]; lines=[head.join(",")];
    for(var wi=0;wi<rows.length;wi++){ var wr=rows[wi]; var wg=GEO[wr.ip]||{};
      lines.push([cq(wr.score),cq(wr.tags.join(";")),cq(wr.epoch?fmtTime(wr.epoch,true):""),cq(wr.ip),cq(wg.country||""),cq(wg.asn||""),cq(wr.method),cq(wr.status),cq(wr.bytes),cq(wr.uri),cq(wr.ref),cq(wr.ua),cq(wr.src)].join(",")); } }
  else if(TAB==="users" && USERS_BYGRP){ head=["Group","GID","Members","Users"]; lines=[head.join(",")];
    for(var gi2=0;gi2<rows.length;gi2++){ var gr2=rows[gi2];
      lines.push([cq(gr2.group),cq(gr2.gid),cq(gr2.userN),cq(gr2.users.join("; "))].join(",")); } }
  else if(TAB==="users"){ head=["Score","Tags","UID","User","Shell","Enabled","Groups","Password","SSHKeys","HistoryLines","LastLogin_"+tzLabel(),"LastIP"]; lines=[head.join(",")];
    for(var ui=0;ui<rows.length;ui++){ var ur=rows[ui]; var ue2=userEnabled(ur);
      lines.push([cq(ur.score),cq(ur.tags.join(";")),cq(ur.uid),cq(ur.user),cq(ur.shell),cq(ue2===true?"yes":(ue2===false?"no":"?")),cq(ur.groups.join(";")),cq(ur.locked===null?"":(ur.locked?"locked":(ur.hasPw?"set":"EMPTY"))),cq(ur.keys),cq(ur.hist),cq(ur.lastEp?fmtTime(ur.lastEp,true):""),cq(ur.lastIp)].join(",")); } }
  else if(TAB==="audit"){ head=["Score","Tags","When_"+tzLabel(),"Type","User","SourceIP","Result","Detail","AuditId"]; lines=[head.join(",")];
    for(var xi=0;xi<rows.length;xi++){ var xr=rows[xi];
      lines.push([cq(xr.score),cq(xr.tags.join(";")),cq(xr.epoch?fmtTime(xr.epoch,true):""),cq(xr.typ),cq(xr.user),cq(xr.ip),cq(xr.res),cq(xr.detail),cq(xr.id)].join(",")); } }
  else if(TAB==="actions"){ head=["Score","Tags","When_"+tzLabel(),"Epoch","User","Shell","Command"]; lines=[head.join(",")];
    for(var ai2=0;ai2<rows.length;ai2++){ var ar=rows[ai2];
      lines.push([cq(ar.score),cq(ar.tags.join(";")),cq(ar.epoch?fmtTime(ar.epoch,true):""),cq(ar.epoch||""),cq(ar.user),cq(ar.shell),cq(ar.cmd)].join(",")); } }
  else if(TAB==="ssh"){ head=["Score","Tags","Kind","Scope","Algorithm","Comment","KeyId","Restricted","ForcedCommand","Passphrase","Options","File","KeyMaterial"]; lines=[head.join(",")];
    for(var ki=0;ki<rows.length;ki++){ var kr=rows[ki]; var pp=kr.priv?(kr.nullpass===true?"none":(kr.encrypted===true?"encrypted":"unknown")):"";
      lines.push([cq(kr.score),cq(kr.tags.join(";")),cq(kr.kind),cq(kr.scope),cq(kr.algo),cq(kr.comment),cq(kr.id),cq(kr.kind==="authorized_keys"?(kr.restricted?"yes":"no"):""),cq(kr.forced),cq(pp),cq(kr.options),cq(kr.file),cq(kr.blob)].join(",")); } }
  else if(TAB==="proc"){ head=["Score","Tags","User","PID","PPID","Start","Exe","SHA1","Command"]; lines=[head.join(",")];
    for(var i=0;i<rows.length;i++){ var r=rows[i]; lines.push([cq(r.score),cq(r.tags.join(";")),cq(r.user),cq(r.pid),cq(r.ppid),cq(r.start),cq(r.exe),cq(r.sha1),cq(r.cmd)].join(",")); } }
  else if(TAB==="net"){ head=["Score","Tags","Proto","State","Local","Remote","ProcName","ProcPid"]; lines=[head.join(",")];
    for(i=0;i<rows.length;i++){ r=rows[i]; lines.push([cq(r.score),cq(r.tags.join(";")),cq(r.proto),cq(r.state),cq(r.local),cq(r.peer),cq(r.procName),cq(r.procPid)].join(",")); } }
  else if(TAB==="logon"){ head=["Score","Tags","When_"+tzLabel(),"Result","User","Source","Method","Command","SourceArtifact"]; lines=[head.join(",")];
    for(i=0;i<rows.length;i++){ r=rows[i]; lines.push([cq(r.score),cq(r.tags.join(";")),cq(logonWhenCell(r)),cq(r.result),cq(r.user),cq(r.ip),cq(r.method),cq(r.cmd),cq(r.src)].join(",")); } }
  else if(TAB==="time"){ head=["Score","Tags","mtime_UTC","atime_UTC","ctime_UTC","crtime_UTC","Size","Mode","UID","Path"]; lines=[head.join(",")];
    for(i=0;i<rows.length;i++){ r=rows[i]; lines.push([cq(r.score),cq(r.tags.join(";")),cq(epochFull(r.mtime)),cq(epochFull(r.atime)),cq(epochFull(r.ctime)),cq(epochFull(r.crtime)),cq(r.size),cq(r.mode),cq(r.uid),cq(r.path)].join(",")); } }
  else if(TAB==="ioc"){ head=["File","Line","IOC","Excerpt"]; lines=[head.join(",")];
    for(i=0;i<rows.length;i++){ r=rows[i]; lines.push([cq(r.file),cq(r.line),cq(r.ioc),cq(r.excerpt)].join(",")); } }
  else { setStatus("Nothing to export on this tab","err"); return; }
  var dir=LASTOUTDIR||$("outDir").value;
  var path=dir+"\\"+TAB+"_export_"+nowStamp()+".csv";
  // v0.10: say so when a timeline export is incomplete because the bodyfile parse cap was hit
  var capNote=(TAB==="time" && TIMECAP.total>TIMECAP.shown)?(" (INCOMPLETE: bodyfile cap - "+nf(TIMECAP.shown)+" of "+nf(TIMECAP.total)+" rows parsed; narrow /from /to)"):"";
  try{ writeUtf8(path, lines.join("\r\n")); setStatus("Exported "+nf(lines.length-1)+" rows → "+path+capNote, capNote?"err":"ok"); appendLog("Exported: "+path+capNote); }
  catch(e){ setStatus("Export failed: "+e.message,"err"); }
}
/* Logs-tab export: integrity findings + syslog service inventory + notable events in one CSV */
function exportLogs(){
  var lines=["section,a,b,c"];
  var i;
  for(i=0;i<INTEGRITY.length;i++){ var it=INTEGRITY[i]; lines.push(["integrity",cq(it.sev),cq(it.check),cq(it.detail)].join(",")); }
  for(i=0;i<SYSLOGSVC.length;i++){ lines.push(["service",cq(SYSLOGSVC[i].n),cq(SYSLOGSVC[i].prog),""].join(",")); }
  for(i=0;i<LOGEVENTS.length;i++){ var e=LOGEVENTS[i]; lines.push(["event",cq(e.sev||0),cq(e.kind),cq(e.detail)].join(",")); }
  if(JOURNAL){ for(i=0;i<JOURNAL.flagged.length;i++){ var g=JOURNAL.flagged[i];
    lines.push(["journal-gap",cq(g.days.toFixed(1)),cq(fmtUsec(g.from)+" -> "+fmtUsec(g.to)),cq(g.genChange?"generation change":"")].join(",")); } }
  if(lines.length<=1){ setStatus("Nothing to export on the Logs tab","err"); return; }
  var dir=LASTOUTDIR||$("outDir").value, path=dir+"\\logs_export_"+nowStamp()+".csv";
  try{ writeUtf8(path, lines.join("\r\n")); setStatus("Exported "+nf(lines.length-1)+" log rows → "+path,"ok"); appendLog("Exported: "+path); }
  catch(e){ setStatus("Export failed: "+e.message,"err"); }
}
function copyNotes(){
  var rows=(window.__fullRows||[]).slice(0,500); if(!rows.length){ setStatus("Nothing to copy","err"); return; }
  var out=[];
  for(var i=0;i<rows.length;i++){ var r=rows[i];
    if(TAB==="proc") out.push(r.score+" | pid "+r.pid+" | "+r.user+" | "+r.cmd+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="net") out.push(r.score+" | "+r.proto+" "+r.state+" | "+r.local+" -> "+r.peer+(r.procName?(" | "+r.procName):"")+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="logon") out.push(r.score+" | "+logonWhenCell(r)+" | "+r.result+" | "+r.user+" from "+(r.ip||"local")+(r.cmd?(" | "+r.cmd):"")+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="time") out.push(r.score+" | "+epochShort(r.mtime)+" | "+r.mode+" | "+r.path+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="ioc") out.push(r.file+":"+r.line+" | "+r.ioc+" | "+r.excerpt);
    // v0.17: the newer tabs copy too
    else if(TAB==="users" && r.kind==="group") out.push(r.group+" (gid "+r.gid+") | "+r.userN+" member(s) | "+r.users.join(", "));
    else if(TAB==="users") out.push(r.score+" | uid "+r.uid+" | "+r.user+" | "+r.shell+" | enabled:"+(function(){var e=userEnabled(r);return e===true?"yes":(e===false?"no":"?");})()+" | keys:"+r.keys+" | last:"+(r.lastEp?fmtTime(r.lastEp,false):"-")+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="web") out.push(r.score+" | "+(r.epoch?fmtTime(r.epoch,true):"-")+" | "+r.ip+" | "+r.method+" "+r.status+" | "+r.uri+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="audit") out.push(r.score+" | "+fmtTime(r.epoch,true)+" | "+r.typ+" | "+r.user+" | "+r.detail+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="ssh") out.push(r.score+" | "+r.kind+" | "+r.scope+" | "+r.algo+(r.comment?(" | "+r.comment):"")+(r.priv?(" | passphrase:"+(r.nullpass===true?"NONE":(r.encrypted===true?"encrypted":"unknown"))):(r.kind==="authorized_keys"?(" | "+(r.restricted?"restricted":"unrestricted")+(r.forced?(" forced:"+r.forced):"")):""))+(r.tags.length?(" | "+r.tags.join(",")):""));
    else if(TAB==="actions") out.push(r.score+" | "+(r.epoch?fmtTime(r.epoch,true):"-")+" | "+r.user+" | "+r.cmd+(r.tags.length?(" | "+r.tags.join(",")):""));
  }
  try{ window.clipboardData.setData("Text", out.join("\r\n")); setStatus("Copied "+out.length+" lines to clipboard","ok"); }
  catch(e){ setStatus("Copy failed: "+e.message,"err"); }
}

/* ---------- IOC list ---------- */
function applyIocs(){
  IOCS=parseTerms($("iocBox").value);
  $("iocInfo").innerHTML=IOCS.length?(nf(IOCS.length)+" term(s) active - re-sweeping"):"no terms";
  if(LASTROOT){ if(IOCS.length){ setStatus("Re-sweeping tree for "+IOCS.length+" IOC term(s)…","muted");
      window.setTimeout(function(){ sweepIocs(LASTROOT); rescoreAll(); buildPersistence(LASTROOT); render(); patchRunInfoSummary(buildRunSummary());
        setStatus("IOC list applied - "+IOCS.length+" term(s); "+nf(IOCHITS.length)+" tree hit(s).","ok"); }, 40);
    } else { IOCHITS=[]; rescoreAll(); render(); setStatus("IOC list cleared.","ok"); }
  } else setStatus(IOCS.length?("IOC list set - "+IOCS.length+" term(s). Analyze a capture to apply."):"IOC list cleared","ok");
}

/* ---------- command-line invocation (family) ----------
   mshta.exe "Linux-UAC-Analyzer.hta" "<archiveOrFolder>" ["<outDir>"] [/auto] [/from:yyyy-MM-dd] [/to:yyyy-MM-dd] */
function getCommandLine(){
  try{ var cl=uacHta.commandLine+""; if(cl && cl!=="undefined") return cl; }catch(e){}
  try{
    var lp=decodeURIComponent(location.pathname+"").replace(/^\//,"").replace(/\//g,"\\");
    var fn=lp.substring(lp.lastIndexOf("\\")+1).toLowerCase(); if(!fn) return "";
    var loc=new ActiveXObject("WbemScripting.SWbemLocator");
    var svc=loc.ConnectServer(".","root\\cimv2");
    var q=svc.ExecQuery("SELECT CommandLine,CreationDate FROM Win32_Process WHERE Name='mshta.exe'");
    var best="", bestDate=""; var en=new Enumerator(q);
    for(; !en.atEnd(); en.moveNext()){ var pr=en.item(); var pcl=(pr.CommandLine==null?"":pr.CommandLine+"");
      if(pcl.toLowerCase().indexOf(fn)<0) continue; var cd=(pr.CreationDate==null?"":pr.CreationDate+"");
      if(!best || cd>bestDate){ best=pcl; bestDate=cd; } }
    return best;
  }catch(e2){}
  return "";
}
function tokenizeCmdTail(){
  var cl=getCommandLine(); if(!cl) return [];
  var m=cl.match(/\.hta"?/i); var tail = m ? cl.substring(m.index+m[0].length) : cl;
  var toks=[], i=0, n=tail.length, cur="", inq=false;
  while(i<n){ var c=tail.charAt(i);
    if(inq){ if(c==='"'){ inq=false; } else cur+=c; i++; continue; }
    if(c==='"'){ inq=true; i++; continue; }
    if(c===' '||c==='\t'){ if(cur!==""){ toks.push(cur); cur=""; } i++; continue; }
    cur+=c; i++; }
  if(cur!=="") toks.push(cur); return toks;
}
var CASE_FROM="", CASE_TO="";
function applyCaseWindow(from,to){
  if(from){ if(/^\d{4}-\d{2}-\d{2}$/.test(from)){ CASE_FROM=from; try{ $("dfrom").value=from; DFROM=dayNum(from); }catch(e){} } else appendLog("CLI: ignoring invalid /from '"+from+"'"); }
  if(to){ if(/^\d{4}-\d{2}-\d{2}$/.test(to)){ CASE_TO=to; try{ $("dto").value=to; DTO=dayNum(to); }catch(e2){} } else appendLog("CLI: ignoring invalid /to '"+to+"'"); }
  if(CASE_FROM||CASE_TO) appendLog("CLI: case window "+(CASE_FROM||"…")+" .. "+(CASE_TO||"…")+" - prefilled the timeline date filter (filter only, never scored)");
}
function parseCli(){
  var toks=tokenizeCmdTail();
  var cli={input:"", outDir:"", auto:false, from:"", to:""};
  for(var i=0;i<toks.length;i++){ var t=toks[i];
    // mshta passes its own window GUID ("{1E460BD7-...}", sometimes doubled) as a phantom argument
    // when launched from Explorer - it is NOT an input path, so ignore GUID-shaped tokens.
    if(/\{[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}\}/.test(t)) continue;
    if(/^[\/\-]{1,2}auto$/i.test(t)){ cli.auto=true; continue; }
    var fm=t.match(/^[\/\-]{1,2}from[:=](\d{4}-\d{2}-\d{2})$/i); if(fm){ cli.from=fm[1]; continue; }
    var tm=t.match(/^[\/\-]{1,2}to[:=](\d{4}-\d{2}-\d{2})$/i); if(tm){ cli.to=tm[1]; continue; }
    if(/^[\/\-]/.test(t)) continue;
    if(!cli.input) cli.input=t; else if(!cli.outDir) cli.outDir=t;
  }
  return cli;
}
function applyCli(cli){
  if(!cli.input) return false;
  var fso=new ActiveXObject("Scripting.FileSystemObject");
  applyCaseWindow(cli.from, cli.to);
  if(fso.FolderExists(cli.input) || fso.FileExists(cli.input)){ $("inPath").value=cli.input; }
  else { setStatus("CLI input not found: "+cli.input,"err"); appendLog("CLI input not found: "+cli.input); return false; }
  if(cli.outDir){ $("outDir").value=cli.outDir; OUT_TOUCHED=true; hostGuessFrom(cli.outDir); }
  else hostGuessFrom(cli.input);
  if(cli.auto){ appendLog("CLI: /auto - analyzing "+cli.input); window.setTimeout(function(){ analyze(); }, 250); }
  else setStatus("CLI: input prefilled. Click 'Analyze capture' to run.","muted");
  return true;
}
function dayNum(s){ if(!s) return 0; var m=String(s).match(/(\d{4})-(\d{1,2})-(\d{1,2})/); if(!m) return 0;
  function p(x){ x=String(x); return x.length<2?("0"+x):x; } return Number(m[1]+p(m[2])+p(m[3])); }

/* ---------- self-update (family) ---------- */
var SELF_REPO="bpmorris22/Linux-UAC-Capture-Analyzer", SELF_HTA="Linux-UAC-Analyzer.hta", SELF_LATEST="", SELF_ASSET_URL="";
function selfVerNewer(r,l){ var a=String(r).split("."),b=String(l).split("."),n=Math.max(a.length,b.length);
  for(var i=0;i<n;i++){ var x=parseInt(a[i],10)||0,y=parseInt(b[i],10)||0; if(x!==y) return x>y; } return false; }
function selfPath(){ try{ var p=decodeURIComponent(location.pathname+"").replace(/^\//,"").replace(/\//g,"\\");
  if(/\.hta$/i.test(p) && fileExists(p)) return p; }catch(e){} return (htaFolder()||"")+"\\"+SELF_HTA; }
function checkSelfUpdate(){
  if(offlineMode()) return;   // v0.10: offline.txt next to the app disables all outbound requests
  try{
    var x=new ActiveXObject("MSXML2.XMLHTTP.6.0");
    x.open("GET","https://api.github.com/repos/"+SELF_REPO+"/releases/latest",true);
    try{ x.setRequestHeader("User-Agent",SELF_HTA); }catch(eh){}
    x.onreadystatechange=function(){ if(x.readyState!==4) return;
      try{ if(x.status!==200) return; var t=x.responseText+"";
        var m=t.match(/"tag_name"\s*:\s*"v?([0-9.]+)"/i); if(!m) return;
        var latest=m[1]; if(!selfVerNewer(latest,APP_VERSION)) return;
        var url="", re=/"browser_download_url"\s*:\s*"([^"]+\.hta)"/ig, mm;
        while((mm=re.exec(t))){ if(mm[1].toLowerCase().indexOf(SELF_HTA.toLowerCase())>=0){ url=mm[1]; break; } if(!url) url=mm[1]; }
        if(!url) url="https://github.com/"+SELF_REPO+"/releases/download/v"+latest+"/"+SELF_HTA;
        SELF_LATEST=latest; SELF_ASSET_URL=url;
        var b=$("selfUpd"); if(b){ b.innerHTML="Update to v"+latest; b.className="btn primary";
          b.title="A newer "+SELF_HTA+" (v"+latest+") is on GitHub - click to download & replace this file"; }
      }catch(e){} };
    x.send();
  }catch(e){}
}
function doSelfUpdate(){
  if(offlineMode()){ setStatus("Offline mode (offline.txt is present next to the app) - self-update disabled.","muted"); return; }
  if(!SELF_ASSET_URL){ setStatus("No update available (or offline).","muted"); return; }
  var target=selfPath(); if(!target || !/\.hta$/i.test(target)){ setStatus("Can't locate this app's own file to update in place.","err"); return; }
  if(!confirm("Download "+SELF_HTA+" v"+SELF_LATEST+" and replace this file?\n\n"+target+"\n\nThe app will close automatically once the new version is in place - just reopen it to run v"+SELF_LATEST+".")) return;
  setStatus("Downloading v"+SELF_LATEST+"…","muted");
  var fso=new ActiveXObject("Scripting.FileSystemObject"), tmp=fso.GetSpecialFolder(2)+"";
  var ps1=tmp+"\\selfupd_"+uid()+".ps1";
  var tq=String(target).replace(/'/g,"''"), uq=String(SELF_ASSET_URL).replace(/'/g,"''");
  var L=["$ErrorActionPreference='Stop'","[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12",
    "$u='"+uq+"'","$t='"+tq+"'","$tmp=Join-Path $env:TEMP ('selfupd_'+[guid]::NewGuid().ToString('N')+'.hta')",
    "Invoke-WebRequest -Uri $u -OutFile $tmp -Headers @{ 'User-Agent'='"+SELF_HTA+"' }",
    "if((Get-Item $tmp).Length -lt 2000){ throw 'downloaded file too small' }",
    "Copy-Item $tmp $t -Force","Remove-Item $tmp -Force -ErrorAction SilentlyContinue","Write-Output 'SELFUPD_OK'"];
  try{ var f=fso.CreateTextFile(ps1,true); f.Write(L.join("\r\n")); f.Close(); }catch(ew){ setStatus("Self-update stage failed: "+ew.message,"err"); return; }
  try{ var r=runBat(['powershell -NoProfile -ExecutionPolicy Bypass -File "'+ps1+'" > "__LOG__" 2>&1']);
    try{ fso.DeleteFile(ps1); }catch(e0){}
    if((r.log+"").indexOf("SELFUPD_OK")>=0){ var b=$("selfUpd"); if(b) b.className="btn primary hide";
      setStatus("Updated to v"+SELF_LATEST+" - closing so you can reopen the new version…","ok");
      // The update ran synchronously (runBat blocks), so the .hta on disk is already the new version.
      // Auto-close the now-stale running instance after the user acknowledges (family: HTAs close via window.close()).
      try{ alert("Update installed (v"+SELF_LATEST+").\n\nClick OK to close "+SELF_HTA+" - reopen it to run the new version."); }catch(e){}
      try{ window.close(); }catch(ec){}
    } else { appendLog("--- self-update ---\n"+r.log); setStatus("Self-update failed - see log.","err"); }
  }catch(e){ setStatus("Self-update failed: "+e.message,"err"); }
}

/* ---------- help ---------- */
var GITHUB="https://github.com/bpmorris22/Linux-UAC-Capture-Analyzer";
function openUrl(u){ try{ new ActiveXObject("WScript.Shell").Run('"'+u+'"',1,false); }catch(e){ setStatus("Could not open browser: "+e.message,"err"); } }
function openHelp(){ try{ $("helpVer").innerHTML="v"+APP_VERSION; }catch(e){} showEl("helpModal",true); }
function closeHelp(){ showEl("helpModal",false); }
/* ---------- field guide (Instructions) ---------- */
var MANUAL_URL="https://raw.githubusercontent.com/bpmorris22/Linux-UAC-Capture-Analyzer/main/UAC-Triage-Manual.html";
var MANUAL_FILE="UAC-Triage-Manual.html";
function openManualFile(path){ try{ new ActiveXObject("WScript.Shell").Run('explorer.exe "'+path+'"',1,false); return true; } catch(e){ setStatus("Downloaded the field guide, but could not open it: "+e.message,"err"); return false; } }
function openInstructions(){ var fso=new ActiveXObject("Scripting.FileSystemObject"); var dest=fso.GetSpecialFolder(2)+"\\"+MANUAL_FILE;
  if(offlineMode()){ if(fileExists(dest)){ if(openManualFile(dest)) setStatus("Offline mode - opened the previously downloaded field guide.","muted"); }
    else { var loc=htaFolder()?(htaFolder()+"\\"+MANUAL_FILE):""; if(loc && fileExists(loc)){ if(openManualFile(loc)) setStatus("Offline mode - opened the local field guide.","muted"); }
      else setStatus("Offline mode (offline.txt) - field-guide download disabled and no local copy found. Open UAC-Triage-Manual.html from the repo folder.","err"); }
    return; }
  setStatus("Downloading the field guide from GitHub...","muted"); var ps1=fso.GetSpecialFolder(2)+"\\man_"+uid()+".ps1"; var dq=String(dest).replace(/'/g,"''"); var L=[]; L.push("$ErrorActionPreference='Stop'"); L.push("[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12"); L.push("Invoke-WebRequest -UseBasicParsing -Uri '"+MANUAL_URL+"' -OutFile '"+dq+"' -Headers @{ 'User-Agent'='Linux-UAC-Analyzer' }"); L.push("if((Get-Item '"+dq+"').Length -lt 2000){ throw 'downloaded file too small' }"); L.push("Write-Output 'MAN_OK'"); try{ var f=fso.CreateTextFile(ps1,true); f.Write(L.join("\r\n")); f.Close(); } catch(ew){ setStatus("Could not stage the field-guide download: "+ew.message,"err"); return; } var r=runBat(['powershell -NoProfile -ExecutionPolicy Bypass -File "'+ps1+'" > "__LOG__" 2>&1']); try{ fso.DeleteFile(ps1); }catch(e0){} if((r.log+"").indexOf("MAN_OK")>=0 && fileExists(dest)){ if(openManualFile(dest)) setStatus("Field guide downloaded and opened in your browser.","ok"); appendLog("Field guide: downloaded latest -> "+dest); } else { appendLog("--- field-guide download ---\n"+r.log); if(fileExists(dest)){ if(openManualFile(dest)) setStatus("Download failed (offline?) - opened the previously downloaded copy.","muted"); } else { setStatus("Field-guide download failed (offline, or the file moved). See log; or open it from the GitHub repo.","err"); } } }
function openDir(){ var d=$("outDir").value; if(!d){ setStatus("No output directory set","err"); return; }
  try{ new ActiveXObject("WScript.Shell").Run('explorer.exe "'+d+'"',1,false); }catch(e){ setStatus("Could not open folder: "+e.message,"err"); } }
/* open the containing folder in Explorer with the file pre-selected (or just the folder for a dir) */
function openInExplorer(path){
  try{ var fso=new ActiveXObject("Scripting.FileSystemObject");
    if(fso.FileExists(path)) new ActiveXObject("WScript.Shell").Run('explorer.exe /select,"'+path+'"',1,false);
    else if(fso.FolderExists(path)) new ActiveXObject("WScript.Shell").Run('explorer.exe "'+path+'"',1,false);
    else setStatus("Path no longer exists: "+path,"err");
  }catch(e){ setStatus("Could not open Explorer: "+e.message,"err"); }
}

/* ---------- wiring ---------- */
/* ---------- v0.13: Generate report - self-contained HTML with a navigation pane ----------
   One file, no external assets, safe to attach to a case. Scored tables are capped at the
   highest-signal rows (score-sorted) with the cap disclosed; full data stays in the app/CSVs. */
var REPORT_ROWCAP=500;
function repRows(arr, cap, mapFn, scoreSort){
  var a=arr.slice(0);
  if(scoreSort) a.sort(function(x,y){ return (y.score||0)-(x.score||0); });
  var out=[], n=a.length>cap?cap:a.length;
  for(var i=0;i<n;i++){ out.push(mapFn(a[i])); }
  return {rows:out, total:arr.length, shown:n};
}
function repTable(heads, rr, note){
  var h=['<table><thead><tr>'];
  for(var i=0;i<heads.length;i++) h.push('<th>'+esc(heads[i])+'</th>');
  h.push('</tr></thead><tbody>');
  if(!rr.rows.length) h.push('<tr><td colspan="'+heads.length+'" class="muted">(none in this capture)</td></tr>');
  for(var r=0;r<rr.rows.length;r++){ var row=rr.rows[r];
    h.push('<tr'+(row.cls?(' class="'+row.cls+'"'):'')+'>');
    for(var c=0;c<row.cells.length;c++) h.push('<td>'+esc(String(row.cells[c]==null?"":row.cells[c]))+'</td>');
    h.push('</tr>');
  }
  h.push('</tbody></table>');
  if(rr.shown<rr.total) h.push('<p class="muted">showing the '+nf(rr.shown)+' highest-signal of '+nf(rr.total)+' rows - the full set is in the app / CSV exports.</p>');
  if(note) h.push('<p class="muted">'+esc(note)+'</p>');
  return h.join("");
}
function repCls(sc){ return sc>=5?"flag":(sc>=3?"warn":""); }
function repScore(r){ return r.score+(r.tags&&r.tags.length?(" ["+r.tags.join(",")+"]"):""); }
/* v0.14: describe every UI filter currently narrowing a view (drives the full-vs-filtered prompt) */
function activeFilterDesc(){
  var f=[];
  if(QUERY) f.push('search "'+QUERY+'"');
  if(SUSONLY) f.push("suspicious-only (score >= 3)");
  if(SCOREMIN>0) f.push("score >= "+SCOREMIN+" (processes/network/timeline/apache/actions)");
  if(DFROM||DTO) f.push("case window "+($("dfrom").value||"…")+" to "+($("dto").value||"…"));
  if(mdSet("logfUser")) f.push("logon user in ["+mdDesc("logfUser")+"]");
  if(mdSet("logfSrc")) f.push("logon source in ["+mdDesc("logfSrc")+"]");
  if(mdSet("logfResult")) f.push("logon result in ["+mdDesc("logfResult")+"]");
  try{ if($("netPubOnly").checked) f.push("network: public IPs only"); }catch(e2){}
  if(mdSet("netLoc")) f.push("network location in ["+mdDesc("netLoc")+"]");
  if(mdSet("netType")) f.push("network type in ["+mdDesc("netType")+"]");
  if(mdSet("procSus")) f.push("process suspicion in ["+mdDesc("procSus")+"]");
  try{ if($("pfMinScore").value!=="1") f.push("persistence score >= "+$("pfMinScore").value); }catch(e2c){}
  if(usersSelSet()) f.push("selected accounts only (Users tab)");
  try{ if((parseInt($("evMinScore").value,10)||0)>0) f.push("events score >= "+$("evMinScore").value);
    if($("evNotable").checked) f.push("notable events only");
    if($("evToolOnly").checked) f.push("TOOLING only"); }catch(e3){}
  if(mdSet("evKind")) f.push("events kind in ["+mdDesc("evKind")+"]");
  if(mdSet("actUser")) f.push("actions user in ["+mdDesc("actUser")+"]");
  try{ if($("bruteOnly").checked) f.push("brute-force only (Logons/Audit)"); }catch(ebd){}
  if(NBHONLY) f.push("non-business hours only - outside 08:00-18:00 host-local (Logons/Actions/Apache/Timeline)");   // v1.6
  try{ if($("evNbh").checked) f.push("events: non-business hours only"); }catch(en9){}
  if(EVQ) f.push('events search "'+EVQ+'"');
  if(EVFROM||EVTO) f.push("events window");
  if(PIVOT) f.push("timeline pivot ±15 min @ "+fmtTime(PIVOT.center,true));
  return f;
}
function generateReport(){
  if(!LASTROOT){ setStatus("Analyze a capture first - the report renders what the app has parsed.","err"); return; }
  try{
    // v0.14: when UI filters are active, offer a filtered report mirroring exactly what's on screen
    var afl=activeFilterDesc(), useFilters=false;
    if(afl.length){
      useFilters=confirm("Filters are currently active in the app:\n\n  - "+afl.join("\n  - ")
        +"\n\nOK      = FILTERED report (only rows matching the current filters)\nCancel = FULL report (everything parsed)");
    }
    setStatus("Generating "+(useFilters?"FILTERED":"full")+" HTML report…","muted");
    function F(arr){ if(!useFilters) return arr; var a=[],i9; for(i9=0;i9<arr.length;i9++){ if(passQ(arr[i9])) a.push(arr[i9]); } return a; }
    var _P=F(PROC), _T=F(TIMEL), _W=F(WEBLOG), _A=F(AUDITX), _PF=F(PERSFIND), _K=F(PKGS), _C=F(CONTAINERS), _LA=F(LATERAL), _E=EVENTS, _N=F(NET), _L=F(LOGON), _U=F(USERS), _AC=F(ACTIONS);
    if(useFilters){
      var b1=[],i7,r7;
      var pub=false; try{ pub=$("netPubOnly").checked; }catch(en2){}
      if(pub||mdSet("netLoc")||mdSet("netType")){ for(i7=0;i7<_N.length;i7++){ r7=_N[i7];
        if(pub && !(r7.peerAddr && !ipIsLocal(r7.peerAddr))) continue;
        if(!mdPass("netLoc", netLocOf(r7))) continue;
        if(!mdPass("netType", netSvcOf(r7))) continue; b1.push(r7); } _N=b1; }
      if(mdSet("procSus")){ b1=[]; for(i7=0;i7<_P.length;i7++){ if(mdPassAny("procSus",_P[i7].tags||[])) b1.push(_P[i7]); } _P=b1; }
      if(SCOREMIN>0){ var scf=function(a){ var o=[],z; for(z=0;z<a.length;z++){ if((a[z].score||0)>=SCOREMIN) o.push(a[z]); } return o; };
        _P=scf(_P); _N=scf(_N); _T=scf(_T); _W=scf(_W); _AC=scf(_AC); }
      if(mdSet("actUser")||(DFROM||DTO)){ b1=[]; for(i7=0;i7<_AC.length;i7++){ var ar7=_AC[i7];
        if(!mdPass("actUser", ar7.user)) continue;
        if((DFROM||DTO) && ar7.epoch && !inDay(logonDay(ar7.epoch))) continue; b1.push(ar7); } _AC=b1; }
      b1=[]; for(i7=0;i7<_L.length;i7++){ r7=_L[i7];
        if(!mdPass("logfUser", trimStr(r7.user))) continue;
        if(!mdPass("logfSrc", logonSrcType(r7))) continue;
        if(!mdPass("logfResult", r7.result)) continue;
        if((DFROM||DTO) && r7.epoch && !inDay(logonDay(r7.epoch))) continue;
        b1.push(r7); } _L=b1;
      var us2=usersSelSet();
      if(us2){ b1=[]; for(i7=0;i7<_U.length;i7++){ if(us2[_U[i7].user]) b1.push(_U[i7]); } _U=b1; }
      if(PIVOT){ b1=[]; for(i7=0;i7<_T.length;i7++){ r7=_T[i7];
        if((r7.mtime>=PIVOT.from&&r7.mtime<=PIVOT.to)||(r7.ctime>=PIVOT.from&&r7.ctime<=PIVOT.to)
         ||(r7.crtime>=PIVOT.from&&r7.crtime<=PIVOT.to)||(r7.atime>=PIVOT.from&&r7.atime<=PIVOT.to)) b1.push(r7); } _T=b1; }
      // v1.6: non-business-hours filter, applied only to the datasets whose tabs carry it
      if(NBHONLY){
        b1=[]; for(i7=0;i7<_L.length;i7++){ if(_L[i7].epoch && isNbh(_L[i7].epoch)) b1.push(_L[i7]); } _L=b1;
        b1=[]; for(i7=0;i7<_AC.length;i7++){ if(_AC[i7].epoch && isNbh(_AC[i7].epoch)) b1.push(_AC[i7]); } _AC=b1;
        b1=[]; for(i7=0;i7<_W.length;i7++){ if(_W[i7].epoch && isNbh(_W[i7].epoch)) b1.push(_W[i7]); } _W=b1;
        b1=[]; for(i7=0;i7<_T.length;i7++){ if(nbhTimeRow(_T[i7])) b1.push(_T[i7]); } _T=b1; }
      var mS=0,noT=false,toO=false,nbhE7=false; try{ mS=parseInt($("evMinScore").value,10)||0; noT=$("evNotable").checked; toO=$("evToolOnly").checked; nbhE7=$("evNbh").checked; }catch(ee2){}
      b1=[]; for(i7=0;i7<EVENTS.length;i7++){ var e7=EVENTS[i7];
        if(e7.score<mS) continue;
        if(!mdPass("evKind", e7.kind)) continue;
        if(noT && !NOTABLE_KINDS[e7.kind]) continue;
        if(toO && !hasTag(e7,"TOOLING")) continue;   // v1.6 fix: was `hiT` (undefined leftover of the old hide-TOOLING filter) - threw and killed the filtered report
        if(nbhE7 && !(e7.epoch && isNbh(e7.epoch))) continue;   // v1.6: non-business hours
        if(EVQ && e7.blob.indexOf(EVQ)<0) continue;
        if(EVFROM||EVTO){ var d7=eventDay(e7.epoch); if(EVFROM&&d7<EVFROM) continue; if(EVTO&&d7>EVTO) continue; }
        b1.push(e7); } _E=b1;
      if((DFROM||DTO)){ b1=[]; for(i7=0;i7<_W.length;i7++){ if(!_W[i7].epoch || inDay(logonDay(_W[i7].epoch))) b1.push(_W[i7]); } _W=b1;
        b1=[]; for(i7=0;i7<_A.length;i7++){ if(!_A[i7].epoch || inDay(logonDay(_A[i7].epoch))) b1.push(_A[i7]); } _A=b1; }
    }
    var host=META.host||sanitHost($("hostName").value)||"host";
    var S=[], NAV=[];
    function section(id, title, html){ NAV.push('<a href="#sec-'+id+'">'+esc(title)+'</a>');
      S.push('<section id="sec-'+id+'"><h2>'+esc(title)+'</h2>'+html+'</section>'); }
    // --- Overview ---
    var ov=[];
    ov.push('<table class="kv">');
    function kv(k,v){ if(v) ov.push('<tr><th>'+esc(k)+'</th><td>'+esc(v)+'</td></tr>'); }
    kv("Host", META.host); kv("OS / arch", (META.os||"")+(META.arch?(" / "+META.arch):""));
    kv("Distribution", META.distro); kv("Kernel", META.kernel);
    kv("UAC version", META.uacVer); kv("Collected (host TZ)", META.started+(META.tz?("  "+META.tz):""));
    kv("Boot time (host local)", META.bootTime); kv("Uptime", META.uptime);
    kv("Collected as", META.runAs); kv("Collection command", META.cmdLine);
    kv("Collection profile", CAPPROF?CAPPROF.label:"");
    kv("Analyzed by", "Linux UAC Capture Analyzer v"+APP_VERSION);
    kv("Report generated (UTC)", (function(){ var d=new Date(); return d.getUTCFullYear()+"-"+p2n(d.getUTCMonth()+1)+"-"+p2n(d.getUTCDate())+" "+p2n(d.getUTCHours())+":"+p2n(d.getUTCMinutes())+"Z"; })());
    kv("Case window", (CASE_FROM||CASE_TO)?((CASE_FROM||"…")+" to "+(CASE_TO||"…")):"");
    // v0.15: identity + activity context
    var aw2=activityWindow();
    if(aw2) kv("Observable activity", fmtTime(aw2.from,false)+" to "+fmtTime(aw2.to,false)+" "+tzLabel());
    for(var ni2=0;ni2<NETIDENT.length && ni2<6;ni2++){ kv("iface "+NETIDENT[ni2].iface, (NETIDENT[ni2].ips.join(", ")||"-")+(NETIDENT[ni2].mac?("  ·  "+NETIDENT[ni2].mac):"")); }
    if(CLOUDINIT) kv("Cloud-init", (CLOUDINIT.ds?("datasource "+CLOUDINIT.ds+"; "):"")+"first boot "+(CLOUDINIT.firstBoot||"?")+(CLOUDINIT.userData?"; USER-DATA SCRIPTS RAN":"")+(CLOUDINIT.keys?("; "+CLOUDINIT.keys+" SSH-key injection event(s)"):""));
    ov.push('</table>');
    var tk2=topTalkers();
    if(tk2.length){ var ts2=[]; for(var t8=0;t8<tk2.length;t8++){ ts2.push(tk2[t8].ip+(geoTip(tk2[t8].ip)?(" ["+geoTip(tk2[t8].ip)+"]"):"")+" ("+nf(tk2[t8].n)+")"); }
      ov.push('<p><b>Top external IPs:</b> '+esc(ts2.join(" · "))+'</p>'); }
    var fl=buildRunSummary();
    if(fl) ov.push('<p>'+nf(fl.entries)+' parsed entries; <b>'+nf(fl.flagged)+' flagged</b> (score ≥ 3 / IOC). Datasets: '
      +nf(PROC.length)+' processes, '+nf(NET.length)+' connections, '+nf(LOGON.length)+' logons, '+nf(USERS.length)+' accounts, '
      +nf(TIMEL.length)+' timeline rows, '+nf(EVENTS.length)+' events, '+nf(WEBCAP.total)+' web requests, '+nf(AUDITCAP.total)+' audit records, '
      +nf(PERSFIND.length)+' persistence lines, '+nf(PKGS.length)+' package actions, '+nf(CONTAINERS.length)+' containers, '+nf(IOCHITS.length)+' IOC hits.</p>');
    // possible ATT&CK mappings (same derivation as the Overview tab)
    var tSeen={}, tList=[];
    function coll(arr,thr){ for(var z=0;z<arr.length;z++){ if(arr[z].score>=thr){ var tt=techsForTags(arr[z].tags||[]);
      for(var y=0;y<tt.length;y++){ if(!tSeen[tt[y].id]){ tSeen[tt[y].id]=1; tList.push(tt[y]); } } } } }
    coll(PROC,3); coll(NET,3); coll(LOGON,3); coll(PERSFIND,2); coll(CONTAINERS,2);
    if(tList.length){ tList.sort(function(a,b){ return a.id<b.id?-1:1; });
      var ts=[]; for(var q3=0;q3<tList.length;q3++) ts.push(tList[q3].id+" ("+tList[q3].name+")");
      ov.push('<p><b>Possible ATT&CK technique mappings ('+tList.length+', heuristic):</b> '+esc(ts.join(" · "))+'</p>'); }
    if(SARSUM && SARSUM.busy.length) ov.push('<p class="warn-t"><b>sar:</b> '+nf(SARSUM.busy.length)+' interval(s) at ≥80% user CPU (peak '+SARSUM.maxUsr.toFixed(0)+'%) - review for cryptomining.</p>');
    ov.push(repTable(["Sev","Check","Detail"],
      repRows(INTEGRITY, 100, function(r){ return {cls:(r.sev>=3?"flag":(r.sev>=2?"warn":"")), cells:[r.sev, r.check, r.detail]}; }),
      "Log-integrity findings (tamper / rotation / layout checks)."));
    if(_LA.length) ov.push('<h3>Lateral movement evidence</h3>'+repTable(["Evidence","User","Destination","Detail"],
      repRows(_LA, 200, function(r){ return {cls:repCls(r.score)||(r.corrob?"warn":""), cells:[r.kind+(r.corrob?" CORROB":""), r.user, r.dest+(geoTip(r.dest)?(" ["+geoTip(r.dest)+"]"):""), r.evidence]}; }, true)));
    if(BOOTS.length) ov.push('<h3>Boot history (journalctl --list-boots)</h3>'+repTable(["Idx","Boot ID","First entry","Last entry"],
      repRows(BOOTS, 60, function(r){ return {cls:"", cells:[r.idx, r.id.substring(0,12)+"…", r.first, r.last]}; })));
    section("overview","Overview", ov.join(""));
    // --- Security assessment (v1.6) ---
    var SECF=computeSecurity();
    var secCorr=[], secPost=[], secApache=[], sF=0,sW=0,sP=0,sN=0, si;
    for(si=0;si<SECF.length;si++){ var sf2=SECF[si];
      if(sf2.status==="FAIL") sF++; else if(sf2.status==="WARN") sW++; else if(sf2.status==="PASS") sP++; else sN++;
      (sf2.cat==="correlation"?secCorr:(sf2.cat==="apache"?secApache:secPost)).push(sf2); }
    secCorr.sort(secSort); secPost.sort(secSort); secApache.sort(secSort);
    function secRep(arr){ return repTable(["Result","Check","Evidence"],
      {rows:(function(){ var o=[]; for(var q=0;q<arr.length;q++){ var r=arr[q];
        o.push({cls:(r.status==="FAIL"?"flag":(r.status==="WARN"?"warn":"")), cells:[r.status, r.name, r.evidence+(r.ep?("  ["+fmtTime(r.ep,true)+"]"):"")]}); } return o; })(), total:arr.length, shown:arr.length}); }
    section("security","Security assessment",
      '<p><b>'+sF+'</b> fail · <b>'+sW+'</b> warn · '+sP+' pass · '+sN+' n/a. Heuristic leads over everything parsed - confirm each FAIL against the underlying data.</p>'
      +'<h3>Compromise indicators &amp; correlations</h3>'+secRep(secCorr)
      +'<h3>OS hardening posture</h3>'+secRep(secPost)
      +'<h3>Apache hardening posture</h3>'+secRep(secApache));
    // --- Inventory ---
    section("inventory","Inventory", repTable(["Category","Artifact","Present","Size / files"],
      repRows(INVENTORY, 400, function(r){ return {cls:"", cells:[r.cat, r.name, r.present?"present":"absent", r.present?((r.kind==="dir"||r.kind==="userfile")?(nf(r.count)+" file(s)"):fmtSize(r.size)):"-"]}; })));
    // --- Processes ---
    section("processes","Processes", repTable(["Score","User","PID","PPID","CPU%","Command"],
      repRows(_P, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.user, r.pid, r.ppid, (r.cpu>=0?r.cpu.toFixed(1):"-"), trunc(r.cmd,180)]}; }, true)));
    // --- Network ---
    section("network","Network", repTable(["Score","Proto","State","Local","Remote","Location","Process"],
      repRows(_N, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.proto, r.state, r.local, r.peer, geoTip(r.peerAddr), (r.procName||"")+(r.procPid?(" ("+r.procPid+")"):"")]}; }, true)));
    // --- Logons ---
    var lg=[];
    lg.push('<h3>By source IP</h3>'+repTable(["Source IP","Geo/ASN","First seen","Last seen","Failures","Successes","Users tried"],
      repRows(buildLogonByIp(_L), 300, function(r){ return {cls:(r.fails>=5&&r.okc?"flag":repCls(r.score)), cells:[r.ip, geoTip(r.ip), r.first?fmtTime(r.first,true):"-", r.last?fmtTime(r.last,true):"-", r.fails, r.okc, r.userN+(r.userList?(" ("+trunc(r.userList,60)+")"):"")]}; }, true)));
    lg.push('<h3>Highest-signal logon events</h3>'+repTable(["Score","When ("+tzLabel()+")","Result","User","Source","Method / cmd","Artifact"],
      repRows(_L, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), logonWhenCell(r), r.result, r.user, (r.ip||"(local)")+(geoTip(r.ip)?(" ["+geoTip(r.ip)+"]"):""), trunc(logonMethodCell(r),90), r.src]}; }, true)));
    if(_LA.length) lg.push('<h3>Lateral movement</h3><p class="muted">See the Overview section - rendered there.</p>');
    section("logons","Logons", lg.join(""));
    // --- Users ---
    section("users","Users", repTable(["Score","UID","User","Shell","Groups","Password","SSH keys","History","Last login"],
      repRows(_U, 300, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.uid, r.user, r.shell, r.groups.join(", "), (r.locked===null?"-":(r.locked?"locked":(r.hasPw?"set":"EMPTY"))), r.keys||"-", r.hist||"-", r.lastEp?(fmtTime(r.lastEp,false)+(r.lastIp?(" "+r.lastIp):"")):"-"]}; })));
    // --- SSH keys ---
    section("sshkeys","SSH keys", repTable(["Score","Kind","Scope","Algorithm","Comment","Key id","Access / passphrase","File"],
      repRows(F(SSHKEYS), 300, function(r){ var acc=r.priv?(r.nullpass===true?"NO passphrase":(r.encrypted===true?"encrypted":"unknown")):(r.kind==="authorized_keys"?((r.restricted?"restricted":"unrestricted")+(r.forced?(" · forced: "+trunc(r.forced,60)):"")):"-");
        return {cls:repCls(r.score), cells:[repScore(r), r.kind, r.scope, r.algo, r.comment, r.id, acc, r.file]}; }, true),
      "authorized_keys entries are inbound access; identity keys are per-user; host keys are the server's /etc/ssh identity."));
    // --- Persistence ---
    var pe2=[];
    pe2.push(repTable(["Score","When","Source","Kind","Command line"],
      repRows((function(){ var a=[]; for(var i4=0;i4<_PF.length;i4++){ if(_PF[i4].score>=1) a.push(_PF[i4]); } return a; })(), REPORT_ROWCAP,
        function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.epoch?fmtTime(r.epoch,true):"-", r.src, r.detail, trunc(r.cmd,160)]}; }, true),
      "Scored persistence command lines (benign score-0 lines are omitted)."));
    pe2.push('<h3>Persistence &amp; config inventory</h3>'+repTable(["Artifact","Present","Size / files","Path"],
      repRows(PERSIST, 100, function(r){ return {cls:(r.ioc?"flag":""), cells:[r.label, r.present?(r.ioc?"present, IOC":"present"):"absent", r.present?((r.dir||r.userfile)?(nf(r.count)+" file(s)"):fmtSize(r.size)):"-", r.rel]}; })));
    section("persistence","Persistence", pe2.join(""));
    // --- Timeline ---
    section("timeline","Timeline", repTable(["Score","mtime (UTC)","ctime (UTC)","Size","Mode","UID","Path"],
      repRows((function(){ var a=[]; for(var i5=0;i5<_T.length;i5++){ if(_T[i5].score>=1||(useFilters&&PIVOT)) a.push(_T[i5]); } return a; })(), REPORT_ROWCAP,
        function(r){ return {cls:repCls(r.score), cells:[repScore(r), epochShort(r.mtime), epochShort(r.ctime), fmtSize(r.size), r.mode, r.uid, trunc(r.path,180)]}; }, true),
      (useFilters&&PIVOT)?("Pivot window rows ("+nf(_T.length)+" in ±15 min)."):("Scored bodyfile rows only ("+nf(TIMEL.length)+" rows loaded in-app"+(TIMECAP.total>TIMECAP.shown?(" of "+nf(TIMECAP.total)+" total - parse cap"):"")+").")));
    // --- Events ---
    section("events","Events", repTable(["When ("+tzLabel()+")","Kind","Score","Event","Source"],
      repRows((function(){ var a=[]; for(var i6=0;i6<_E.length;i6++){ if(_E[i6].score>=1||useFilters) a.push(_E[i6]); } return a; })(), 1000,
        function(r){ return {cls:repCls(r.score), cells:[fmtTime(r.epoch,true), r.kind, r.score, trunc(r.label,160), r.src]}; }),
      useFilters?"Events matching the active filters, chronological.":"Scored events in chronological order (score-0 context rows omitted)."));
    // --- Apache Web Server (v1.6: config summary + logs) ---
    var wb=[];
    if(APACHECFG&&APACHECFG.present){ var AC2=APACHECFG;
      wb.push('<h3>Apache configuration</h3>'+repTable(["Directive","Value"],
        {rows:[
          {cls:"", cells:["Source", AC2.base+" ("+AC2.flavor+") · "+nf(AC2.files)+" enabled file(s)"]},
          {cls:(lc(AC2.user||"")==="root"?"flag":""), cells:["Runs as", (AC2.user||"(no User directive)")+(AC2.group?(" / "+AC2.group):"")]},
          {cls:(lc(AC2.tokens)==="prod"?"":"warn"), cells:["ServerTokens", AC2.tokens||"(unset - default Full)"]},
          {cls:(lc(AC2.signature)==="on"?"warn":""), cells:["ServerSignature", AC2.signature||"(unset - default Off)"]},
          {cls:(lc(AC2.trace)==="off"?"":"warn"), cells:["TraceEnable", AC2.trace||"(unset - default On)"]},
          {cls:"", cells:["Listen", AC2.listen.join(", ")||"-"]},
          {cls:"", cells:["DocumentRoot", AC2.docroots.join(", ")||"-"]},
          {cls:((contains(AC2.modules,"ssl")||AC2.sslOn)?"":"warn"), cells:["TLS", (contains(AC2.modules,"ssl")||AC2.sslOn)?("ssl enabled"+(AC2.sslproto?(" · "+AC2.sslproto):"")):"not configured - HTTP only"]},
          {cls:(AC2.indexes.length?"warn":""), cells:["Directory listing", AC2.indexes.length?("Options Indexes in "+AC2.indexes.join(", ")):"off"]},
          {cls:(AC2.statusOn?"warn":""), cells:["mod_status", AC2.statusOn?"enabled":"not enabled"]},
          {cls:"", cells:["Modules", nf(AC2.modules.length)+" enabled: "+trunc(AC2.modules.join(", "),200)]}
        ], total:11, shown:11},
        "Scored CIS-style checks for this configuration are in the Security assessment section.")); }
    wb.push('<h3>Access logs</h3>'+repTable(["Score","When","Client IP","Geo/ASN","Method","Status","URI","User-Agent"],
      repRows(_W, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.epoch?fmtTime(r.epoch,true):"-", r.ip, geoTip(r.ip), r.method, r.status, trunc(r.uri,140), trunc(r.ua,60)]}; }, true),
      WEBCAP.total?("Parsed "+nf(WEBCAP.total)+" request lines"+(WEBCAP.total>WEBCAP.shown?(", "+nf(WEBCAP.shown)+" stored (cap)"):"")+"."):""));
    section("weblogs","Apache Web Server", wb.join(""));
    // --- Audit ---
    section("audit","Audit", repTable(["Score","When","Type","User","Source IP","Detail"],
      repRows(_A, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), fmtTime(r.epoch,true), r.typ, r.user, r.ip, trunc(r.detail,160)]}; }, true)));
    // --- Actions ---
    section("actions","Actions", repTable(["Score","When ("+tzLabel()+")","User","Shell","Command"],
      repRows(_AC, REPORT_ROWCAP, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.epoch?fmtTime(r.epoch,true):"-", r.user, r.shell, trunc(r.cmd,200)]}; }, true),
      ACTIONSCAP.total?("Executed shell commands from user history ("+nf(ACTIONSCAP.total)+" parsed"+(ACTIONSCAP.total>ACTIONSCAP.shown?(", "+nf(ACTIONSCAP.shown)+" stored"):"")+"; highest-signal shown here)."):""));
    // --- Apps (v1.9: containers moved to their own report section) ---
    var ap=[];
    ap.push('<h3>Recent package activity</h3>'+repTable(["When","Action","Package","Requested by"],
      repRows(_K, 5000, function(r){ return {cls:(r.susp?"warn":""), cells:[r.when, r.action, r.pkg+(r.susp?(" [SUS: "+r.susp+"]"):""), (pkgUserRequested(r)?"[USER-REQ] ":"")+(r.by||"-")]}; })));
    section("apps","Apps", ap.join(""));
    // --- Containers (v1.9) ---
    var cs=[];
    if(CTRX&&CTRX.coverage.length){
      cs.push('<h3>Collection coverage</h3>'+repTable(["Evidence","Status","Detail"],
        repRows(CTRX.coverage, 60, function(r){ return {cls:(r.status==="denied"||r.status==="failed")?"warn":"", cells:[r.ev, r.status, trunc(r.detail,180)]}; })));
    }
    if(CTRX&&CTRX.any){
      var rtRows=[], rte;
      function rtLine(eng,rt){ if(!rt||!rt.installed) return;
        rtRows.push({cls:"", cells:[eng+" version", trimStr((rt.server?("server "+rt.server):"")+(rt.client?("  client "+rt.client):""))]});
        if(rt.storage) rtRows.push({cls:"", cells:[eng+" storage / logging", rt.storage+(rt.backingFs?(" ("+rt.backingFs+")"):"")+(rt.logging?(" / "+rt.logging):"")]});
        if(rt.rootDir) rtRows.push({cls:(eng==="docker"&&rt.rootDir!=="/var/lib/docker")?"warn":"", cells:[eng+" root dir", rt.rootDir]});
        if(rt.secOpts.length) rtRows.push({cls:"", cells:[eng+" security options", rt.secOpts.join(", ")]});
        if(rt.total!=="") rtRows.push({cls:"", cells:[eng+" containers / images", rt.total+" ("+rt.running+" running, "+(rt.stopped||0)+" stopped) / "+(rt.images||"?")+" image(s)"]}); }
      rtLine("docker", CTRX.docker); rtLine("podman", CTRX.podman);
      for(rte=0;rte<CTRX.rtFindings.length;rte++) rtRows.push({cls:"warn", cells:["finding ["+CTRX.rtFindings[rte].tag+"]", CTRX.rtFindings[rte].reason]});
      if(CTRX.lxc&&CTRX.lxc.installed) rtRows.push({cls:"", cells:["LXD", "server "+(CTRX.lxc.version||"?")+" · "+nf(CTRX.lxc.instances)+" instance(s)"]});
      if(rtRows.length) cs.push('<h3>Runtime metadata</h3>'+repTable(["Field","Value"], {rows:rtRows, total:rtRows.length, shown:rtRows.length}));
      cs.push('<h3>Container inventory</h3>'+repTable(["Score","Engine","ID","Name","Image","Command","Created","Started","Status","Host PID","Ports","Restart policy"],
        repRows(_C, 200, function(r){ return {cls:repCls(r.score), cells:[repScore(r), r.engine, r.id, r.names, r.image||r.imageRef, trunc(r.cmdCfg||r.cmd,50),
          r.createdEp?fmtTime(r.createdEp,true):(r.created||"-"), r.startedEp?fmtTime(r.startedEp,true):"-", r.status, r.pid||"-", trunc(r.ports||"-",40), r.restartPolicy||"-"]}; }, true)));
      var expoRows=[], xc, xd;
      for(xc=0;xc<CONTAINERS.length;xc++){ var xcc=CONTAINERS[xc];
        for(xd=0;xd<xcc.reasons.length;xd++) expoRows.push({cls:(xcc.score>=5?"flag":(xcc.score>=3?"warn":"")), cells:[xcc.names||xcc.id, xcc.tags[xd]||"", xcc.reasons[xd]]}); }
      if(expoRows.length) cs.push('<h3>Exposure &amp; findings</h3>'+repTable(["Container","Tag","Finding"], {rows:expoRows, total:expoRows.length, shown:expoRows.length}));
      var dfRows=[];
      for(xc=0;xc<CONTAINERS.length;xc++){ var dcc=CONTAINERS[xc]; if(!dcc.diff||!dcc.diff.present) continue;
        dfRows.push({cls:"", cells:[dcc.names||dcc.id, nf(dcc.diff.added)+" added / "+nf(dcc.diff.changed)+" changed / "+nf(dcc.diff.deleted)+" deleted", dcc.diff.susN?nf(dcc.diff.susN)+" suspicious path(s) - see the app/CSV for the list":"none flagged"]}); }
      if(dfRows.length) cs.push('<h3>Filesystem changes (docker diff)</h3>'+repTable(["Container","Changes vs image","Suspicious paths"], {rows:dfRows, total:dfRows.length, shown:dfRows.length},
        "docker diff records path and change type only - the capture holds no contents, ownership or hashes for these paths, no event history, no container logs and no volume contents."));
    } else {
      cs.push('<p class="muted">No container runtime evidence in this capture'+((CTRX&&!CTRX.dirPresent)?' (the containers artifact group was not collected by this profile)':'')+'.</p>');
    }
    section("containers","Containers", cs.join(""));
    // --- Browser ---
    section("browser","Browser", repTable(["Browser","User","Database","Size","WAL sidecar"],
      repRows(BROWSERDBS, 100, function(r){ return {cls:"", cells:[r.browser, r.user, r.name, fmtSize(r.size), r.wal?"present":"absent"]}; }),
      "Analyze these with the SQLECmd wrapper hand-off from the app's Browser tab."));
    // --- Logs ---
    var lo=[];
    lo.push('<h3>Notable log events</h3>'+repTable(["Sev","Kind","Detail"],
      repRows((function(){ var a=LOGEVENTS.slice(0); a.sort(function(x,y){ return (y.sev||0)-(x.sev||0); }); return a; })(), 100,
        function(r){ return {cls:(r.sev>=3?"flag":(r.sev>=2?"warn":"")), cells:[r.sev||0, r.kind, trunc(r.detail,200)]}; })));
    if(JOURNAL) lo.push('<p>systemd journal: '+nf(JOURNAL.sysCount+JOURNAL.userCount)+' archived files, '+nf(JOURNAL.generations)+' generation(s), '+nf(JOURNAL.flagged.length)+' rotation-interval anomal'+(JOURNAL.flagged.length===1?"y":"ies")+'.</p>');
    if(BOOTS.length) lo.push('<p>'+nf(BOOTS.length)+' boot(s) in journalctl --list-boots.</p>');
    section("logs","Logs", lo.join(""));
    // --- IOC hits ---
    section("iochits","IOC hits", repTable(["File","Line","IOC","Excerpt"],
      repRows(IOCHITS, 1000, function(r){ return {cls:"flag", cells:[r.file, r.line, r.ioc, trunc(r.excerpt,200)]}; }),
      IOCS.length?("Swept against "+nf(IOCS.length)+" IOC/keyword term(s)."):"No IOC terms were loaded for this run."));
    // --- assemble ---
    var css='body{margin:0;font:13px/1.5 "Segoe UI",Arial,sans-serif;background:#0d1117;color:#c9d1d9}'
      +'nav{position:fixed;top:0;left:0;bottom:0;width:190px;background:#161b22;border-right:1px solid #30363d;padding:14px;overflow:auto}'
      +'nav h2{font-size:14px;color:#58a6ff;margin:0 0 10px}nav a{display:block;color:#8b949e;text-decoration:none;padding:4px 6px;border-radius:4px;font-size:12px}'
      +'nav a:hover{background:#21262d;color:#c9d1d9}'
      +'main{margin-left:218px;padding:18px 26px;max-width:1400px}'
      +'h1{font-size:20px;color:#e6edf3}h2{font-size:16px;color:#58a6ff;border-bottom:1px solid #30363d;padding-bottom:4px;margin-top:34px}'
      +'h3{font-size:13px;color:#e6edf3;text-transform:uppercase;letter-spacing:.4px}'
      +'table{border-collapse:collapse;width:100%;margin:8px 0;font-size:12px}'
      +'th{background:#161b22;color:#8b949e;text-align:left;padding:5px 8px;border:1px solid #30363d;position:sticky;top:0}'
      +'td{padding:4px 8px;border:1px solid #21262d;font-family:Consolas,monospace;font-size:11.5px;word-break:break-word}'
      +'tr.warn td{background:#2b2411}tr.flag td{background:#3d1d1d}'
      +'table.kv th{width:220px;font-weight:600}'
      +'.muted{color:#8b949e;font-size:11px}.warn-t{color:#e3b341}'
      +'@media print{nav{display:none}main{margin-left:0}}';
    var html='<!DOCTYPE html><html><head><meta charset="utf-8"><title>Linux UAC Capture Analyzer report - '+esc(host)+'</title><style>'+css+'</style></head><body>'
      +'<nav><h2>UAC report</h2>'+NAV.join("")+'</nav>'
      +'<main><h1>Linux UAC Capture Analyzer report - '+esc(host)+(useFilters?' <span style="color:#e3b341">(FILTERED)</span>':'')+'</h1>'
      +(useFilters?('<p class="warn-t"><b>FILTERED report</b> - only rows matching the filters active at generation time: '+esc(afl.join("; "))+'. Generate again and choose Cancel for the full report.</p>'):'')
      +'<p class="muted">Times are '+esc(tzLabel())+' unless a column says otherwise. Scores: 3-4 amber (suspicious), 5+ red (high). '
      +'Heuristic output for triage - verify findings against the raw artifacts before reporting them as fact.</p>'
      +S.join("")+'</main></body></html>';
    // v1.4 filename convention: "<Hostname> - <Full|Filtered> UAC Report - <YYYYMMDD-HHMMSS UTC>"
    var rd=new Date(); function rz(x){ return (x<10?"0":"")+x; }
    var rutc=rd.getUTCFullYear()+""+rz(rd.getUTCMonth()+1)+rz(rd.getUTCDate())+"-"+rz(rd.getUTCHours())+rz(rd.getUTCMinutes())+rz(rd.getUTCSeconds());
    var rlabel=(useFilters?"Filtered":"Full")+" UAC Report";
    var path=String(LASTOUTDIR).replace(/[\\\/]+$/,"")+"\\"+sanitHost(host)+" - "+rlabel+" - "+rutc+".html";
    writeUtf8(path, html);
    appendLog("Report written: "+path);
    setStatus("Report generated → "+path,"ok");
    openManualFile(path);
  }catch(e){ setStatus("Report generation failed: "+e.message,"err"); appendLog("Report generation failed: "+e.message); }
}

function init(){
  try{ window.resizeTo(1360,920); }catch(e){}
  $("appver").innerHTML="&middot; v"+APP_VERSION;
  try{ document.title="Linux UAC Capture Analyzer v"+APP_VERSION; }catch(e){}
  $("maxrowLbl").innerHTML=nf(MAXROWS);
  $("tblScroll").onscroll=applyFreeze;
  resolveTar(); checkTar(); loadColw();

  $("hostName").onkeyup=function(){ HOST_TOUCHED=true; syncOutDir(); };
  $("outDir").onkeyup=function(){ OUT_TOUCHED=true; };
  loadToolkitIoc();

  var zoom=0.9, zContent=$("content");
  function applyZoom(){ zContent.style.zoom=zoom; zContent.style.width=(100/zoom)+"%"; var p=Math.round(zoom*100)+"%";
    $("fup").title="Larger text ("+p+")"; $("fdown").title="Smaller text ("+p+")"; }
  applyZoom();
  $("fup").onclick=function(){ zoom=Math.min(zoom+0.15,2.5); applyZoom(); };
  $("fdown").onclick=function(){ zoom=Math.max(zoom-0.15,0.6); applyZoom(); };

  $("procBtn").onclick=analyze;
  $("openDirBtn").onclick=openDir;
  $("browseBtn").onclick=function(){ $("inPick").click(); };
  $("inPick").onchange=function(){ if(this.value){ $("inPath").value=this.value; hostGuessFrom(this.value); } };
  $("folderBtn").onclick=function(){
    try{ var sha=new ActiveXObject("Shell.Application");
      var fld=sha.BrowseForFolder(0,"Select an already-extracted UAC folder (one containing uac.log).",0x51);
      if(fld){ var p=""; try{ p=fld.Self.Path+""; }catch(e2){}
        if(/^[a-z]:\\|^\\\\/i.test(p)){ $("inPath").value=p; hostGuessFrom(p); }
        else if(p) setStatus("That selection has no filesystem path - pick a real folder.","err"); }
    }catch(e){ setStatus("Folder picker unavailable: "+e.message,"err"); }
  };
  $("logToggle").onclick=function(){ var l=$("log");
    if(l.style.display==="none"||!l.style.display){
      if(!trimStr(l.innerHTML.replace(/<[^>]*>/g,""))){ l.innerHTML='<span class="muted">(empty - extraction / parse output appears here.)</span>'; l.setAttribute("data-ph","1"); }
      l.style.display="block"; this.innerHTML="Hide log";
    } else { l.style.display="none"; this.innerHTML="Show log"; } };

  // tab bar
  var tb=$("tabbar").getElementsByTagName("button");
  for(var i=0;i<tb.length;i++){ tb[i].onclick=function(){ setTab(this.getAttribute("data-tab")); }; }

  $("q").onkeyup=function(){ if(qTimer) window.clearTimeout(qTimer);
    qTimer=window.setTimeout(function(){ QUERY=trimStr($("q").value).toLowerCase(); render(); },150); };
  $("susOnly").onclick=function(){ SUSONLY=this.checked; render(); };
  $("nbhOnly").onclick=function(){ NBHONLY=this.checked; render(); };   // v1.6
  $("evNbh").onclick=function(){ render(); };                           // v1.6
  $("scoreMin").onchange=function(){ SCOREMIN=parseInt(this.value,10)||0; render(); };   // v1.5.1
  function setTz(on){ TZVIEW=on;
    try{ $("tzMain").checked=on; }catch(e1){} try{ $("tzLogs").checked=on; }catch(e2){} try{ $("evTz").checked=on; }catch(e3){}
    try{ $("tzOv").checked=on; }catch(e4){} try{ $("tzPersist").checked=on; }catch(e5){} try{ $("tzApps").checked=on; }catch(e6){}
    try{ $("tzSec").checked=on; }catch(e7){}   // v1.6
    try{ $("tzCtr").checked=on; }catch(e8){}   // v1.9
    render(); }
  $("tzMain").onclick=function(){ setTz(this.checked); };
  $("tzLogs").onclick=function(){ setTz(this.checked); };
  $("tzOv").onclick=function(){ setTz(this.checked); };        // v0.16
  $("tzPersist").onclick=function(){ setTz(this.checked); };   // v0.16
  $("tzApps").onclick=function(){ setTz(this.checked); };      // v0.16
  $("tzSec").onclick=function(){ setTz(this.checked); };       // v1.6
  $("tzCtr").onclick=function(){ setTz(this.checked); };       // v1.9
  $("ctrExport").onclick=exportContainers;                     // v1.9
  $("ctrSelClose").onclick=function(){ CTR_SEL=-1; renderCtrTab(); };
  $("ctrEnvShow").onclick=function(){ CTR_ENV_SHOW=this.checked; renderCtrDetail(); };
  $("ctrDiffSus").onclick=function(){ CTR_DIFF_SUS=this.checked; renderCtrDetail(); };
  $("secExport").onclick=exportSecurity;                       // v1.6
  $("logsExport").onclick=exportLogs;
  $("loadJournal").onclick=loadJournalWsl;
  // Events tab controls
  $("evq").onkeyup=function(){ if(qTimer) window.clearTimeout(qTimer); qTimer=window.setTimeout(function(){ EVQ=trimStr($("evq").value).toLowerCase(); render(); },150); };
  $("evfrom").onchange=function(){ EVFROM=dayNum(this.value); render(); };
  $("evto").onchange=function(){ EVTO=dayNum(this.value); render(); };
  $("evMinScore").onchange=function(){ render(); };
  // v0.17: register the multiselect filters (labels drive the button text)
  mdReg("netLoc","Location"); mdReg("netType","Type"); mdReg("logfUser","User");
  mdReg("logfSrc","Source"); mdReg("logfResult","Result"); mdReg("procSus","Suspicion"); mdReg("evKind","Kind"); mdReg("actUser","User");
  $("evTz").onclick=function(){ setTz(this.checked); };
  $("evExport").onclick=exportEvents;
  $("evToolOnly").onclick=function(){ render(); };
  // v0.11: Logons by-source-IP aggregate view
  $("logonByIpBtn").onclick=function(){ LOGON_BYIP=!LOGON_BYIP; this.className=LOGON_BYIP?"btn on":"btn"; render(); };
  // v0.11: online geo/ASN enrichment - offline.txt overrules the checkbox entirely
  if(offlineMode()){
    $("onlineChk").checked=false; $("onlineChk").disabled=true;
    $("onlineWrap").title="offline.txt is present next to the app - every outbound network feature is disabled, including geo/ASN lookups.";
  }
  $("onlineChk").onclick=function(){
    if(this.checked){ if(LASTROOT){ maybeEnrichGeo(); } setStatus("Online geo/ASN lookups enabled - public IPs enrich after each Analyze (only the bare IP list is sent to ip-api.com).","muted"); }
    else setStatus("Online geo/ASN lookups disabled - no outbound requests during analysis.","muted");
  };
  // Processes: flat table <-> collapsible tree
  $("procTreeBtn").onclick=function(){ PROC_TREE=!PROC_TREE; this.className=PROC_TREE?"btn on":"btn"; this.innerHTML=PROC_TREE?"Table view":"Tree view"; render(); };
  $("netPubOnly").onclick=function(){ render(); };      // v0.13
  $("reportBtn").onclick=generateReport;                // v0.13
  $("evNotable").onclick=function(){ render(); };       // v0.14
  // v0.16: multiselect dropdown replaces the listbox
  $("usersDropBtn").onclick=function(){ var p=$("usersDropPanel"); showEl("usersDropPanel", /\bhide\b/.test(p.className)); };
  $("usersSelClear").onclick=function(){ USERS_SEL={}; renderUsersDropBtn(); render(); };
  $("logfHideLastlog").onclick=function(){ render(); };  // v0.15
  $("bruteOnly").onclick=function(){ render(); };        // v1.3
  $("pfMinScore").onchange=function(){ render(); };      // v0.16
  $("pkgSusOnly").onclick=function(){ render(); };       // v0.17
  $("pkgUserReqOnly").onclick=function(){ render(); };   // v1.6
  $("usersEnabledOnly").onclick=function(){ render(); }; // v0.17
  $("usersByGrpBtn").onclick=function(){ USERS_BYGRP=!USERS_BYGRP; this.className=USERS_BYGRP?"btn on":"btn"; render(); };  // v0.17
  $("dfrom").onchange=function(){ DFROM=dayNum(this.value); if(LASTROOT){ reparseTimeline(); } };
  $("dto").onchange=function(){ DTO=dayNum(this.value); if(LASTROOT){ reparseTimeline(); } };
  $("clearBtn").onclick=function(){ $("q").value=""; QUERY=""; $("susOnly").checked=false; SUSONLY=false;
    NBHONLY=false; try{ $("nbhOnly").checked=false; }catch(e4){}   // v1.6
    SCOREMIN=0; try{ $("scoreMin").value="0"; }catch(e3){}   // v1.5.1
    mdClearAll(); USERS_SEL={}; renderUsersDropBtn();   // v0.17: clears every multiselect filter too
    try{ $("netPubOnly").checked=false; }catch(e){} try{ $("bruteOnly").checked=false; }catch(e2){} render(); };
  $("exportBtn").onclick=exportView;
  $("copyBtn").onclick=copyNotes;

  $("iocBtn2").onclick=function(){ var w=$("iocWrap"); showEl("iocWrap", /\bhide\b/.test(w.className)); };
  $("iocApply").onclick=applyIocs;
  $("iocLoad").onclick=function(){ $("iocPick").click(); };
  $("iocPick").onchange=function(){ if(this.value){ try{ $("iocBox").value=readUtf8(this.value); applyIocs(); }catch(e){ setStatus("Could not read IOC file: "+e.message,"err"); } } };
  // v0.8: browser DBs -> SQLECmd hand-off
  $("bdbAllBtn").onclick=function(){ sendToSqlecmd(-1); };
  $("sqlePick").onchange=function(){ if(!this.value) return;
    var p=this.value;
    if(!/\.hta$/i.test(p) || !fileExists(p)){ setStatus("That is not an .hta file - pick SQLECmd-Wrapper.hta.","err"); return; }
    var sc=sqleSidecarFile();
    if(sc){ try{ writeUtf8(sc,p); appendLog("SQLECmd wrapper location remembered: "+p+" -> "+sc); }catch(e){} }
    SQLE_WRAPPER_CACHED=null;   // force re-resolve now that a wrapper has been picked
    var pend=BDB_PENDING; BDB_PENDING=null;
    try{ renderBrowserDbs(); }catch(e2){}
    if(pend!=null) sendToSqlecmd(pend);
  };
  $("detClose").onclick=closeDetail;
  $("detCopy").onclick=copyDetail;

  // row / persistence / open-folder click delegation
  document.onclick=function(e){ e=e||window.event; var t=e.target||e.srcElement;
    if(t && /\bcgrip\b/.test(t.className+"")) return;
    // element-level actions first (data-open / data-pf can live on a td or span, not the tr)
    // v0.16: users-dropdown - checkbox toggles select; any click outside the panel closes it
    var uSel=attrUp(t,"data-usel");
    if(uSel){ if(USERS_SEL[uSel]) delete USERS_SEL[uSel]; else USERS_SEL[uSel]=1; renderUsersDropBtn(); render(); return; }
    // v0.17: generic multiselect checkbox / clear-link clicks
    var mdk=attrUp(t,"data-md");
    if(mdk){ var mdv2=attrUp(t,"data-mdv"); var mo=mdReg(mdk);
      if(mo.sel[mdv2]) delete mo.sel[mdv2]; else mo.sel[mdv2]=1; mdBtn(mdk); render(); return; }
    var mdc=attrUp(t,"data-mdclear");
    if(mdc){ mdReg(mdc).sel={}; mdBtn(mdc); render(); return; }
    if(!attrUp(t,"data-udrop")){ mdCloseAll(); var udp=$("usersDropPanel"); if(udp && !/\bhide\b/.test(udp.className)) showEl("usersDropPanel",false); }
    // v0.16: click a public remote IP -> VirusTotal (launches the default browser)
    var vt2=attrUp(t,"data-vt"); if(vt2){ openUrl("https://www.virustotal.com/gui/ip-address/"+vt2); return; }
    var op=attrUp(t,"data-open"); if(op){ openInExplorer(op); return; }
    var jmp=attrUp(t,"data-jump"); if(jmp){ var je=$(jmp); if(je && je.scrollIntoView) try{ je.scrollIntoView(true); }catch(ej){} return; }
    var gt2=attrUp(t,"data-gotab"); if(gt2){ setTab(gt2); return; }   // v0.13: stat cards can open a tab
    var bdb=attrUp(t,"data-bdb"); if(bdb!=null && bdb!==""){ sendToSqlecmd(parseInt(bdb,10)); return; }
    var pfa=attrUp(t,"data-pf"); if(pfa!=null && pfa!==""){ openPersistFile(parseInt(pfa,10)); return; }
    // process-tree (v0.7): fold toggle + open detail by pid
    var fold=attrUp(t,"data-fold"); if(fold){ PTREE_COLLAPSED[fold]=!PTREE_COLLAPSED[fold]; renderProcTree(); return; }
    var pep=attrUp(t,"data-ep"); if(pep){ pivotTimeline(pep); return; }   // v0.11: Events When-cell pivot
    var tpid=attrUp(t,"data-pid"); if(tpid){ var pr=PROCBYPID[tpid]; if(pr){ window.__viewRows=[pr]; openRowDetail(0); } return; }
    // v1.9: Containers tab - row select + "find in Timeline" style query jumps
    var ctri=attrUp(t,"data-ctr"); if(ctri!=null&&ctri!==""){ CTR_SEL=(CTR_SEL===parseInt(ctri,10))?-1:parseInt(ctri,10); renderCtrTab(); return; }
    var qtab=attrUp(t,"data-qtab"); if(qtab){ var qv=attrUp(t,"data-q")||""; QUERY=lc(qv); try{ $("q").value=qv; }catch(eq9){} setTab(qtab); return; }
    var n=t; while(n && n.tagName!=="TR"){ n=n.parentNode; if(n&&n.tagName==="TABLE"){ n=null; break; } }
    if(!n||!n.getAttribute) return;
    var pf=n.getAttribute("data-pf");
    if(pf!=null && pf!==""){ openPersistFile(parseInt(pf,10)); return; }
    var di=n.getAttribute("data-i");
    if(di!=null && di!=="" && (TAB==="proc"||TAB==="net"||TAB==="logon"||TAB==="time"||TAB==="web"||TAB==="users"||TAB==="audit"||TAB==="ssh"||TAB==="actions")){ var ix=parseInt(di,10); openRowDetail(ix);
      var trs=$("tbl").getElementsByTagName("tr");
      for(var z=0;z<trs.length;z++){ var zi=trs[z].getAttribute("data-i");
        if(zi!=null&&zi!==""){ var rows=window.__viewRows||[]; var zr=rows[parseInt(zi,10)]; var base=zr?rowCls(zr):"";
          trs[z].className=(parseInt(zi,10)===ix)?((base?base+" ":"")+"sel"):base; } } }
  };

  var cli=parseCli(); var hadCli=false;
  try{ hadCli=applyCli(cli); }catch(e){ appendLog("CLI parse error: "+e.message); }
  if(isNetworkPath(htaFolder())) appendLog("Heads-up: running from a network location - zone policy may force ANSI IO; triage is unaffected. For full fidelity copy the folder local.");
  if(!hadCli) setStatus("Point at a uac-*.tar.gz / .zip archive (or an extracted folder), set the hostname, and click Analyze capture.","muted");
}
/* case window changed after a parse - re-read the bodyfile with the new filter, rescore, redraw */
function reparseTimeline(){
  if(!LASTROOT) return;
  // bodyfile + packages are window-filtered AT PARSE TIME (filter, never scored); logons filter at render
  var t0=new Date().getTime();
  parseBodyfile(LASTROOT); parsePackages(LASTROOT); rescoreAll(); render();
  appendLog("[perf] case-window reparse (bodyfile+packages+rescore): "+nf(new Date().getTime()-t0)+" ms", true);
  appendLog("Case window "+($("dfrom").value||"…")+" .. "+($("dto").value||"…")+" applied - "+nf(TIMEL.length)+" timeline rows, "+nf(PKGS.length)+" package installs.");
}
window.onload=function(){ init(); try{ window.setTimeout(checkSelfUpdate,600); }catch(e){} };
</script>

<div id="profModal" class="modal hide" onclick="if((event.srcElement||{}).id==='profModal')closeProfModal()">
  <div class="mcard" style="max-width:680px">
    <span class="x" onclick="closeProfModal()" title="Close">&times;</span>
    <div id="profBody"></div>
  </div>
</div>

<div id="helpModal" class="modal hide" onclick="if((event.srcElement||{}).id==='helpModal')closeHelp()">
  <div class="mcard">
    <span class="x" onclick="closeHelp()" title="Close">&times;</span>
    <h2>Linux UAC Capture Analyzer <span class="muted" style="font-size:13px;font-weight:400" id="helpVer"></span></h2>
    <div class="gh muted">GitHub: <span class="lnk" onclick="openUrl(GITHUB)">https://github.com/bpmorris22/Linux-UAC-Capture-Analyzer</span></div>
    <p>A single-file GUI for triaging <b>UAC (Unix-like Artifacts Collector)</b> output - the tarball a responder collects from a Linux / macOS / *BSD / Solaris / ESXi host. It extracts the capture with Windows' built-in <code>tar.exe</code> and turns the plain-text process, network, logon, log and filesystem-timeline artifacts into scored, searchable triage views. It never runs UAC and never touches the target - feed it the archive.</p>
    <h3>Quick start</h3>
    <ul>
      <li>On the *nix host: download UAC from <span class="lnk" onclick="openUrl('https://github.com/tclahr/uac/releases')">github.com/tclahr/uac</span>, then <code>cd</code> into it and run <code>./uac -p ir_triage /tmp</code> (must run from its own folder).</li>
      <li>Copy the resulting <code>uac-&lt;host&gt;-&lt;os&gt;-&lt;ts&gt;.tar.gz</code> to this machine, drop its path in the box (or Browse…), and click <b>Analyze capture</b>. Already-extracted folder? Use <b>Pick folder…</b>.</li>
      <li>Review <b>Overview</b> (run metadata, persistence inventory, ATT&amp;CK coverage), then <b>Processes</b>, <b>Network</b>, <b>Logons</b>, <b>Timeline</b>, <b>Events</b> (one unified time-sorted axis), <b>Logs</b>, and <b>IOC hits</b>. A logs-only collection (<code>-a files/logs/*</code>) has empty process/network/timeline tabs by design - its signal lives in <b>Logons</b>, <b>Events</b> and <b>Logs</b>.</li>
    </ul>
    <h3>Scoring (suspicious = score ≥ 3)</h3>
    <ul>
      <li><b>Processes</b> - IOC/keyword or SHA1 hit (+3), exe under /tmp·/var/tmp·/dev/shm·/run/user (+2), hidden path component (+1), interactive/decoder shell one-liner (+2), kernel-thread masquerade (+2), running binary <b>deleted from disk</b> (+3), PID <b>hidden from ps</b> (+3). v0.5 (from <code>top -b -n1</code> + per-pid /proc): <b>%CPU/%MEM column</b>, process seen <b>only in top</b> (+1; +3 when a service account runs an interpreter), sustained ≥50% CPU (+1/+2 miner tell), <b>LD_PRELOAD</b> in environ (+3), HISTFILE disabled (+2), <b>unrecognized memfd</b> fileless descriptor (+3 - desktop-runtime memfds excluded), deleted-file descriptors (+2, cache noise excluded), deleted mapped .so (+1, upgrade-under-running-process caveat stated), comm-vs-cmdline mismatch (+1 informational).</li>
      <li><b>Network</b> - IOC hit (+3), ESTABLISHED to a public IP (+2), LISTEN on a non-standard high port (+1), owning process itself flagged (+2). v0.5: /proc/net/tcp|udp are hex-decoded and cross-checked against ss - a LISTEN socket <b>missing from ss</b> is flagged (+3, rootkit tell), and socket <b>ownership is recovered</b> (uid -&gt; passwd, fd-inode -&gt; pid) on non-root captures where ss shows no process column.</li>
      <li><b>Logons</b> (auth.log/secure - <b>ISO-8601 and classic syslog timestamps</b> - plus wtmp/btmp/lastlog binaries decoded directly, and last/lastb text). Events: SSH accepted/failed, <b>sudo</b>, <b>pkexec</b> (polkit privesc), <b>pam sessions</b> (root-cron noise suppressed), <b>account changes</b> (useradd/passwd), su, and per-account <b>lastlog</b>. Scores: IOC (+3), public-IP source (+2), failed auth (+1), ≥5 failures from one IP i.e. brute/spray (+2), accepted-after-brute (+3), root from public IP (+1), <b>service account with an interactive login</b> (+3), <b>new account with a login shell</b> (+4), privesc running a temp/shell/hidden command (+2), account change (+2).</li>
      <li><b>Timeline</b> - IOC path hit (+3), executable under a temp path (+1), hidden component (+1), setuid/setgid (+1).</li>
      <li><b>Actions</b> (v1.6) - every history line is scored across the attacker playbook. Hostile-on-their-own (3+): reverse-shell/decoder one-liners (nc, socat, sh -i, base64 -d, python -c, /dev/tcp), /etc/shadow access, scanners (nmap, masscan, ...), offensive tools (hydra, sqlmap, linpeas, chisel, ...), account manipulation (useradd/usermod/visudo), authorized_keys appends, web-root script drops, anti-forensics (history -c, shred, log wipes, timestomp), setuid chmod. Breadcrumbs (1-2) that stack into red rows when chained: recon (whoami, id, uname, ps, netstat, ip a), /etc/passwd &amp; sudoers &amp; SSH-key reads, URL fetches (+1 more for raw-IP/explicit-port or script payloads), chmod +x, sudo -l / SUID hunting, remote copy (scp/rsync), outbound ssh, tcpdump, kernel modules, cron/rc-file edits, dual-use tool installs, temp-path references. Hover any tag for the exact reasons.</li>
      <li><b>Persistence &amp; system findings</b> (Overview) - command lines pulled from cron / systemd <code>ExecStart=</code> / authorized_keys forced-commands / rc.local, scored with the process heuristics (IOC, temp path, shell one-liner, pipe-to-shell, URL fetch); a non-empty <code>ld.so.preload</code> is flagged (+3). v0.5 adds: <b>systemd timers</b> (list-timers), <b>account findings</b> (extra UID-0 +3, service account with a shell +2, docker-group members +1), <b>suid/getcap/world-writable/hidden-file sweeps</b> (+2, stock-system entries whitelisted), UAC's <b>null-passphrase SSH private keys</b> (+2), and <b>shell-history</b> one-liners incl. anti-forensics (history -c / shred, +2). v1.7 adds the <b>RAT/C2 sweeps</b> (system profile.d / SSH-login rc &amp; sshrc / periodic-cron dirs / network-event hooks / module-autoload / udev RUN / binfmt / init.d / at jobs) and a <b>C2 tradecraft lens</b> on every command line: reverse-shell &amp; backpipe patterns (<b>REVSHELL</b>/<b>BACKPIPE</b> +3), encoded loaders (<b>ENC-LOADER</b> +2), a known-implant/C2 name watchlist (<b>IMPLANT</b> +3), and hardcoded public callback IPs (<b>C2-ADDR</b> +2, geo-tagged).</li>
      <li><b>IOC hits</b> - a tree-wide line sweep of every texty file &lt; 5 MB against your IOC list (also written to <code>ioc_hits.csv</code>), <em>plus</em> SHA1-shaped IOC terms matched against <code>hash_executables</code> to catch <b>dormant</b> on-disk implants that aren't running.</li>
    </ul>
    <h3>Also parsed</h3>
    <ul>
      <li><b>Rotated <code>.gz</code> logs</b> under <code>[root]/var/log</code> are inflated at parse time, so weeks of rotated auth/syslog/dpkg history are included automatically (a logs-only capture's real activity is usually in the rotated files).</li>
      <li><b>Logs tab</b> (v0.4): <b>systemd journal rotation analysis</b> decoded from archived-journal filenames - unusually long rotation intervals are surfaced as <em>rotation-interval anomalies</em> (v0.10 wording: a quiet host or retention policy also produces them, so they are not called coverage gaps), and a <b>generation change</b> is flagged harder (journal vacuum/clear is an anti-forensics tell); <b>log-integrity</b> checks (utmp record alignment, broken rotation chains, out-of-order timestamps, empty logs, hostname consistency); a <b>syslog service inventory</b> (a poor-man's process list when live_response wasn't collected); <b>notable events</b> (cron executions, new systemd units, OOM kills, promiscuous mode, USB/module loads); a <b>sysstat/sar</b> CPU summary (sustained high %usr = miner tell); and a <b>cloud-init provisioning baseline</b> (first boot, datasource, original IP/MAC, user-data scripts, injected SSH keys).</li>
      <li><b>Overview</b> shows run metadata incl. the host <b>boot time</b> and <b>uptime / load</b>, plus <b>Recent package activity</b> - now from <code>apt/history.log</code> with <b>attribution</b> (Requested-By / commandline) and a <b>suspicious-tooling watchlist</b> (nmap, socat, masscan, xmrig, ...), separating human <code>apt install</code> from unattended-upgrade noise - and <b>Containers</b>, now deep-inspected: <b>privileged</b> (+3), host pid/network namespace (+2), <b>sensitive host mounts</b> incl. docker.sock (+2/+3), 0.0.0.0 port binds (+1), and files added inside a container at persistence paths via <code>docker diff</code> (+2).</li>
      <li><b>Logs tab additions</b> (v0.5): a <b>Boots table</b> from <code>journalctl --list-boots</code> (with between-boot gap checks), kernel-taint flag, and systemd enabled-unit/timer counts.</li>
      <li><b>Collection-profile awareness</b>: empty tabs explain themselves from uac.log's command line, and permission-denied coverage caveats (non-root collection) are surfaced. A <b>host-TZ / UTC</b> time toggle (Logons, Timeline, Events, Logs) uses the collector's offset from uac.log.</li>
      <li><b>Events tab (v0.6):</b> a single time-sorted, scored, case-window-filterable timeline unifying logons, package activity, boots, journal gaps &amp; content, audit/AppArmor denials and timestamped shell history - the "what happened around &lt;time&gt;" view. Exports to CSV.</li>
      <li><b>Process tree (v0.6):</b> the Processes detail pane shows each process's <b>ancestry and children</b>, %CPU/%MEM, open sockets and deleted files (from <code>lsof</code>); an interpreter/shell whose parent is a web/DB server is flagged as a <b>web shell</b> (+3).</li>
      <li><b>Config drift + auth stack (v0.6):</b> risky <code>sshd_config</code> directives (PermitRootLogin, PasswordAuthentication, PermitEmptyPasswords, non-standard Port, forwarding) and <code>pam.d</code> weaknesses (nullok, <code>pam_exec</code>, an always-succeed <code>pam_permit</code>) score into Persistence &amp; system findings. <b>auditd</b> and <b>AppArmor/SELinux DENIED</b> events are counted.</li>
      <li><b>MITRE ATT&amp;CK (v0.6, reworked v0.10):</b> findings carry <em>possible</em> technique mappings derived from their scoring tags (shown in the detail pane); the Overview lists the distinct candidates. These are heuristic leads to investigate, not confirmed behaviour - mappings that overclaimed (IOC hit, external connection, single failed login, AppArmor denial, transient PID) were removed in v0.10.</li>
      <li><b>Journal contents via WSL (v0.6):</b> when <code>wsl.exe</code> and binary journals are present, the Logs tab's <b>Load journal contents (WSL)</b> button runs <code>journalctl -o json</code> against the extracted journal and adds sudo / sshd / unit / seccomp / segfault / audit events to the Events timeline. (Journal <em>coverage/gap</em> analysis needs no WSL.)</li>
      <li><b>Inventory tab</b> - a map of every key artifact (processes, network, logons, accounts, persistence, system, filesystem, logs, containers) showing present/absent, size, and an <b>open folder</b> link that opens the raw file in Explorer. The Persistence &amp; config inventory on Overview has the same open-folder links; click an artifact name there to view its contents inline.</li>
      <li><b>UI (v0.7):</b> the Processes table has a <b>Name</b> column and a <b>Tree view</b> toggle (collapsible parent/child hierarchy - click ▸/▾ to fold, a row for detail). <b>Logons</b> has User / Source / Result filters and a clickable link to each raw source log. <b>Events</b> has a min-score filter and a kind filter. Long tables keep their <b>header row frozen</b> while scrolling, and <b>Persistence &amp; system findings</b> shows a date/time column.</li>
      <li><b>Resizable columns</b> everywhere - drag the right edge of any column header (it highlights on hover); double-click the edge to reset. Widths persist per view.</li>
      <li><b>Containers tab (v1.9.0):</b> a dedicated <b>Containers</b> tab (left of Apache Web Server; the container table moved off Apps) scoped strictly to the evidence a UAC capture holds - point-in-time state, never presented as Docker event history. Opens with a <b>collection-coverage map</b> that distinguishes <em>present / partial / permission denied / command failed / runtime not installed / not collected by this profile</em>. <b>Runtime metadata</b> from docker/podman info+version (versions, storage/logging/cgroup drivers, security options, root dir, registries, proxies, counts) with runtime-level findings (non-loopback <b>insecure registries</b>, non-standard root dir, missing AppArmor/SELinux/seccomp, active swarm, egress proxy). The <b>inventory keeps stopped containers visible</b> (failed malware execution and terminated attacker tooling look exactly like that). Click a container for the <b>inspect deep-dive</b>: lifecycle timestamps (created/started/finished - they pivot the Timeline and join the Events axis, labelled <em>inspect-derived state</em>), exit/OOM/restart/health, execution config, <b>environment with values redacted by default</b> (names always show; LD_PRELOAD / public-endpoint / temp-path values surface as indicators), the C2/implant lens over entrypoint+cmd+health-check, <b>isolation &amp; exposure scoring</b> (privileged +3, docker.sock mount +3, host namespaces +2, sensitive mounts +2/3, dangerous CapAdd +2/3, AppArmor/seccomp unconfined +2, root+privileged/sock combo +2, 0.0.0.0 binds +1), mounts with find-in-Timeline pivots, published ports cross-checked against host <code>ss</code> listeners (corroboration, not ownership proof), and <code>docker top</code> in-container processes with clickable HOST PIDs. <b>docker diff</b> changes are counted, rolled up per top-level dir and scored for credential/PAM/persistence/ld.so/SSH/web-root/temp/hidden paths (log deletions = anti-forensics) - with the explicit caveat that diff carries <em>path + change type only</em>, no contents or hashes. Correlations: inspect <b>State.Pid → host process</b> (a flagged process escalates the container), restart-policy persistence only scores on already-suspicious containers, IOC terms sweep env/entrypoint/mounts/image. Security posture: P9 extended (docker.sock / CapAdd / unconfined) + a new runtime-hardening check; the HTML report gains a Containers section; everything exports to CSV. The tab also states what it can <b>not</b> show with these artifacts: event history, exec history, destroyed containers, container logs, diff-path contents, volume contents, image provenance.</li>
      <li><b>Persistence: structural detection + correctness (v1.8.0):</b> a second external code review drove five fixes. <b>The structural win - correlation:</b> a persistence entry's executable is now followed to a running process and its sockets, so a harmless-looking <code>ExecStart=/usr/local/bin/update-agent</code> becomes high-confidence when that binary is <em>running and holds an established public connection</em> (<b>PERS-C2</b> +3, <b>PERS-RUN</b>/<b>PERS-SUSPROC</b> for the weaker cases). Gated to non-standard-bin paths so legit /usr/sbin services aren't flagged for having a connection. <b>systemd drop-ins</b>: unit dirs are now scanned recursively, so a malicious <code>ExecStart=</code> override in <code>&lt;unit&gt;.service.d/*.conf</code> (which systemd merges over the primary unit) is finally parsed; broader load-path coverage (<code>/run</code>, <code>/usr/local/lib</code>, XDG, <code>~/.local/share</code>); and <code>.path</code>/<code>.automount</code> <code>Unit=</code> + <code>.socket</code> <code>Service=</code> trigger targets. <b>Correctness fixes:</b> the <code>ForceCommand</code> sshd check was broken (tested for the literal word in the value, so it never fired) - now flags any non-<code>none</code> value; the implant-name match was an unbounded substring (fired on <code>orbit</code> in <code>korbit</code>) - now boundary-aware (basename/path = full score, argument text = low); and <b>C2-ADDR validates octets/ports</b> so a version-like or malformed string can't become a callout. <b>SSH auth-source blind spots:</b> <code>AuthorizedKeysCommand</code>, <code>AuthorizedPrincipalsCommand/File</code>, <code>TrustedUserCAKeys</code>, <code>PermitUserEnvironment</code>, <code>~/.ssh/environment</code>. <b>PAM</b> now scans the account/password/<b>session</b> stacks (a <code>session … pam_exec.so /path/payload</code> was previously missed) and flags absolute module paths. <b>cloud-init</b> <code>scripts/per-boot|per-instance|per-once</code> (per-boot runs every boot) and user-data runcmd/bootcmd; <b>D-Bus</b> service-activation <code>Exec=</code>. <b>Tunnels:</b> <code>autossh</code>, <code>ssh -R/-D/-L</code>, cloudflared/ngrok/tailscale/frp (<b>TUNNEL</b>), plus <code>openssl enc -d</code> and <code>eval "$(base64 -d …)"</code> loaders. <b>Transparency:</b> the persistence/config inventory now lists the new sweep locations, and files skipped for exceeding the 1 MB read cap are surfaced on Log Integrity instead of silently dropped.</li>
      <li><b>Persistence C2 detection - deeper coverage (v1.7.1):</b> a review of the v1.7.0 sweeps closed several gaps. <b>The big one:</b> the "hostile-lines-only" content sweeps (profile.d, cron/init.d/network scripts, per-user rc, histories) gated on <code>HIST_PREFILTER</code> alone, so a line the C2 lens <em>would</em> flag - an implant-by-name (<code>nohup /usr/local/bin/kinsing &amp;</code>) or a reverse-shell variant with no HIST_PREFILTER token - was dropped <em>before</em> scoring; the gate now also fires on <code>implantHit</code> and <code>c2Patterns</code>, so those lines surface and score. <b>New reverse-shell variants</b> in the C2 lens: <code>php fsockopen</code>, <code>ruby TCPSocket.new</code>, <code>gawk /inet/tcp</code>, <code>/dev/udp</code>, and a <b>beacon-cadence</b> heuristic (loop + <code>sleep</code> + a network primitive → <b>BEACON</b>). <b>C2-ADDR now covers IPv6 and domains</b> (a hardcoded domain callback in a raw-socket command → <b>C2-DOMAIN</b>; internal-looking names excluded). <b>New persistence vectors:</b> systemd <code>Environment=LD_PRELOAD</code> and <code>EnvironmentFile=</code> from a writable path, a <code>.socket</code> unit's network <code>ListenStream=</code>, systemd <b>generators</b> (<code>/etc/systemd/system-generators</code>), <code>/etc/ld.so.conf.d/*.conf</code> paths outside the standard lib dirs (<b>LDPATH</b>), and <code>authorized_keys</code> <code>environment=</code> injection. The implant watchlist gained DNS/ICMP-tunnel and modern-C2 names (iodine, dns2tcp, ptunnel, pupy, revsocks, villain, hoaxshell, nimplant, …).</li>
      <li><b>RAT / C2 persistence sweeps (v1.7.0):</b> the <b>Persistence</b> tab gained the hiding spots current Linux RAT/C2 write-ups flag that the earlier sweeps missed. <b>System-wide login execution</b>: <code>/etc/profile</code>, <code>/etc/profile.d/*.sh</code>, <code>/etc/bash.bashrc</code>, <code>/etc/zsh/*</code>, <code>/etc/environment</code> (the per-user rc sweep couldn't see these). <b>SSH-login hooks</b>: <code>/etc/ssh/sshrc</code> and per-user <code>~/.ssh/rc</code> - run on <em>every</em> inbound SSH session before the shell (a favourite stealthy trigger). <b>run-parts periodic cron</b>: <code>/etc/cron.{hourly,daily,weekly,monthly}</code> (non-stock scripts) + <code>/etc/anacrontab</code>. <b>Network-event triggers</b> (beacon-on-connectivity, boot-independent): <code>NetworkManager/dispatcher.d</code>, <code>if-up.d/if-post-up.d/if-down.d</code>, <code>dhclient-exit-hooks.d</code>, <code>ppp/ip-up.d</code>. <b>Boot/device autostart</b>: <code>/etc/modules</code> &amp; <code>modules-load.d</code> (kernel-module autoload), <code>udev</code> rules with <code>RUN+=</code>/<code>PROGRAM=</code>, <code>binfmt_misc</code> handlers. <b>Legacy/other</b>: <code>/etc/rc.d/rc.local</code> (RHEL), <code>/etc/init.d</code> scripts, <code>at</code> jobs. On top of the locations, <b>every persistence command line now gets a RAT/C2 tradecraft lens</b>: reverse-shell / <code>mkfifo</code> backpipe / <code>nc -e</code> / <code>socat EXEC</code> / scripting-language connect-backs / openssl-wrapped shells (<b>REVSHELL</b>/<b>BACKPIPE</b> +3), base64/hex payloads piped to a shell (<b>ENC-LOADER</b> +2), a <b>known-implant/RAT/miner/C2 name watchlist</b> (xmrig, kinsing, bpfdoor, sliver, mythic, chisel, frpc, meterpreter, … → <b>IMPLANT</b> +3), and <b>hardcoded public callback IPs</b> baked into a cron job or unit (<b>C2-ADDR</b> +2, geo-tagged). New persistence tags carry ATT&amp;CK mappings; IMPLANT and C2-ADDR are treated as indicators (unmapped), consistent with the no-overclaim doctrine.</li>
      <li><b>Security tab (v1.6.0):</b> a new <b>Security</b> tab runs an automated assessment over everything already parsed - no re-reading, computed fresh each view. Two halves: <b>compromise-indicator correlations</b> that join data across tabs (brute-force that <em>succeeded</em>, interactive/root logins from public IPs or outside business hours, reverse-shell/scanner/offensive-tool execution, the download→chmod+x chain, anti-forensics, account creation from a shell, persistence files modified <em>after</em> the first suspicious logon, data staging/exfil, an SSH key authorized on multiple accounts, null-passphrase private keys, timestomp candidates, logins from multiple countries), and a <b>hardening-posture checklist</b> (sshd root-login / password-auth / empty-passwords, PAM auth-stack weaknesses, extra UID-0 and duplicate-UID accounts, blank-password accounts, password aging (login.defs), service accounts with shells, sudoers NOPASSWD grants, SSH extras (X11Forwarding / MaxAuthTries / PermitUserEnvironment), privileged/host-namespace containers, auditd presence, <b>firewall enabled/disabled</b> (ufw status / ufw.conf / firewalld) plus the ruleset-vs-0.0.0.0-listeners check, <b>non-standard listening services</b> on externally-reachable interfaces (the "why is velociraptor on 8000" check), SELinux/AppArmor state, kernel-hardening sysctls (ASLR, fs.suid_dumpable, SYN cookies, ip_forward-vs-containers), /tmp noexec+nosuid, NTP clock sync (evidence integrity), patch recency, non-baseline SUID/world-writable/capabilities, EOL distro, docker/sudo/wheel membership) - retitled <b>OS Hardening Posture</b> - and a third table, <b>Apache Hardening Posture</b>: CIS Apache 2.4-inspired checks over the ENABLED configuration in /etc/apache2 | /etc/httpd (ServerTokens/ServerSignature, TraceEnable, run-as user, directory listing, mod_status exposure, risky modules incl. WebDAV/CGI/autoindex, TLS presence + deprecated protocols, AllowOverride All, logging). The <b>Apache logs</b> tab is renamed <b>Apache Web Server</b> and opens with an <b>Apache Configuration</b> section - the key effective directives with at-a-glance review chips - above the access logs; the HTML report mirrors both. Every check reads <b>PASS / WARN / FAIL</b>, or <b>N/A</b> when the source artifact wasn't collected (so a logs-only or non-root capture never shows a false all-clear); a banner rolls up the counts, rows sort worst-first, clicking a finding pivots the Timeline or jumps to the source tab, and it exports to CSV and into the HTML report. Findings are heuristic leads to confirm, not verdicts.</li>
      <li><b>Actions scoring overhaul + Logons subheadings + package Action filter (v1.6.0):</b> the <b>Actions</b> tab now scores the whole attacker playbook, not just the outright-hostile one-liners: <b>discovery</b> commands (whoami / id / uname / ps / netstat / ss / ip a / cat /etc/hosts…, +1 RECON), <b>credential access</b> (/etc/shadow +3, /etc/passwd &amp; sudoers +2, SSH key material +2, CRED-ENUM), <b>scanners</b> (nmap / masscan / arp-scan… +3 NET-SCAN) and <b>offensive tools</b> (hydra / sqlmap / linpeas / chisel… +3 OFFTOOL; installing one via apt/pip is +2 TOOL-INSTALL), <b>chmod +x</b> (+2, setuid bits +3), <b>SUID/sudo -l hunting</b> (+2), <b>account manipulation</b> (useradd / usermod / visudo… +3), <b>persistence edits</b> (authorized_keys append +3; cron / rc-file edits +2), broader <b>anti-forensics</b> (history/log wipes, timestomping, now +3) and <b>security-control disabling</b> (setenforce 0 / auditd stop / ufw disable +2), <b>remote copy</b> (scp/rsync/sftp to a host +2 EXFIL), <b>outbound ssh</b> (+1, root@ +2 LATERAL), <b>packet capture</b> (+2 SNIFF), <b>kernel modules</b> (+2 KMOD), <b>web-root script drops</b> (+3 WEBSHELL) and <b>ad-hoc HTTP servers</b> (+2 NET-SERVE); reverse-shell one-liners went to +3 and URL fetches to +2 (+1 more for raw-IP/explicit-port or script payloads). Tag hovers explain every reason, and new tags carry candidate ATT&amp;CK mappings. The <b>Logons</b> tab labels its two halves - <b>Outbound SSH Connections</b> (the lateral-movement table) and <b>Inbound SSH &amp; Interactive Logons</b> (the event grid). <b>Recent package installs</b> (Apps) gets an inline header row with an <b>Action</b> multiselect filter (install / upgrade / remove / purge / …), a <b>User-Requested Only</b> filter, and a green <b>USER-REQ</b> chip on every package a human explicitly asked for (apt <code>Requested-By</code> / typed <code>apt install</code>), separating them at a glance from unattended-upgrade and cron noise (also marked in the report). A <b>Non-Business Hours</b> filter on <b>Logons, Actions, Events, Apache logs and Timeline</b> shows only rows timestamped outside business hours in the collector host's local time - <b>Mon-Fri 08:00-18:00, with the whole weekend treated as out-of-hours</b> (offset from uac.log; treated as UTC when the capture carried none) - untimestamped rows are hidden while it's on, a Timeline row stays if <em>any</em> of its four times is out-of-hours, the Logons By-source-IP view re-aggregates from out-of-hours events only, and the filtered report honours it. Bug fix: a filtered report with the Events <b>Dual-Use Apps</b> filter active no longer dies on an undefined variable (<code>hiT</code>, a leftover of the old hide-TOOLING toggle). <b>Row-cap honesty:</b> the shared display cap was raised (5,000 → <b>10,000</b> rows), the previously-<em>silent</em> caps on the package table (was 300) and the persistence-findings table (2,000) now disclose, and every capped table shows a prominent red <b>⚠ Maximum Rows Exceeded</b> chip (with a tooltip that points at the filters and the uncapped <b>Export → CSV</b>) whenever the filtered set is larger than what's rendered - so a truncated grid can never again read as the complete picture. (Display caps are a render-time performance bound; CSV export always writes every filtered row, and the case window <code>/from /to</code> narrows the timeline at parse time.)</li>
      <li><b>Score filter (v1.5.1):</b> a <b>Score</b> min-score dropdown (any / ≥1 / ≥3 / ≥5) on the Processes, Network, Timeline, Apache logs and Actions tabs - independent of the SUSPICIOUS ONLY flag, and honoured by the filtered report. Also: "Flagged only" is now "SUSPICIOUS ONLY", the Logon chart title is Title-Cased, and a little more breathing room above System Overview.</li>
      <li><b>Charts + polish (v1.5):</b> the <b>Logons</b> tab now opens with a <b>logon-activity-over-time</b> chart (accepted/session green vs failed red, per day - a tall red column is a brute-force day), and the <b>Network</b> tab with a <b>connections-by-country</b> distribution (ss is a point-in-time snapshot, so it's a distribution, not a time series; falls back to service type / socket state without geo). Also: Provisioning baseline (cloud-init) moved to the very top of the Overview; a divider above the sar summary; Log Integrity tab moved next to UAC Inventory; every filter label and dropdown is Title-Cased ("Dual-Use Apps", "Notable Events", "Online Geo/ASN lookups", "Location/Type/User/Source/Result/Suspicion/Accounts"); table headings Title-Cased ("Logon Events", "User Accounts", ...); heading descriptions sentence-capitalized; and the boots Idx column left-aligned.</li>
      <li><b>Presentation pass, cont. (v1.4.1):</b> Generate report is green; all Host-TZ toggles read "Host TZ"; the Events "TOOLING only" filter is now "Dual Use Apps"; the Events and Log-Integrity tabs got violet Export buttons; the Events tab gained a heading + description; the Logs tab is renamed "Log Integrity"; the Actions tab sits left of Events; and the sar %usr/%idle columns are left-aligned.</li>
      <li><b>Presentation pass (v1.4):</b> every table tab now shows a <b>heading and one-line description</b> above the grid; report files follow the convention <code>&lt;Hostname&gt; - Full|Filtered UAC Report - YYYYMMDD-HHMMSS</code> (UTC); the tab bar is reordered (Browser by Users, SSH Keys by Logons, Events before Timeline) and <b>Inventory</b> is now <b>UAC Inventory</b>; <b>System Overview</b> sits at the top of the Overview with sar/boots/cloud-init below it; the sar cards and the cloud-init section gained tooltips/descriptions; the Events <b>hide TOOLING</b> toggle became <b>TOOLING only</b> (spot recently installed dual-use tools directly); <b>Export View → CSV</b> and <b>Copy to Clipboard</b> are violet; and toolbar/heading capitalization was tidied up.</li>
      <li><b>Brute-force filter (v1.3):</b> a <b>brute-force only</b> checkbox on <b>Logons</b> and <b>Audit</b>. On Logons it shows the failures and the eventual success from any source IP with 5+ failed attempts (the SPRAY / BRUTEWIN picture), and on the <b>By source IP</b> view it narrows to just those brute sources. On Audit it shows failed <code>USER_AUTH</code>/<code>USER_LOGIN</code> records from a source that failed 5+ times. One click isolates a password-guessing campaign and the account/IP that eventually got in.</li>
      <li><b>Actions tab (v1.2):</b> the complete <b>executed-command history</b> - every line from each user's bash/zsh/sh history (not just the hostile ones the Persistence tab keeps), <b>timestamped</b> where the shell recorded times (bash <code>HISTTIMEFORMAT</code> "#epoch" lines, zsh extended-history), and scored with the command heuristics (IOC, temp-path exec, decoder/interactive shell, pipe-to-shell, URL fetch, anti-forensics, elevation). Per-user multiselect filter, case-window and host-TZ aware, click a timestamped row to <b>pivot the Timeline ±15 min</b>. Answers "what did they actually type on this box." Exports to CSV and appears in the report.</li>
      <li><b>SSH Keys tab (v1.1):</b> a dedicated inventory of the key material in the capture - <b>authorized_keys</b> entries (who can log IN, with source-restriction and forced-command flags), per-user <b>identity keys</b> (id_* private/public, with passphrase state), and <b>host keys</b> from /etc/ssh. A short key-id (base64 head…tail) lets you match the same key across accounts by eye; a <b>null-passphrase private key</b> is flagged (usable as-is if exfiltrated), as is an <b>unrestricted</b> or <b>forced-command</b> authorized_keys entry. Exports to CSV and appears in the report.</li>
      <li><b>1.0 (2026-07-18):</b> the app is now the <b>Linux UAC Capture Analyzer</b> (file: <code>Linux-UAC-Analyzer.hta</code>, repo: <code>bpmorris22/Linux-UAC-Capture-Analyzer</code>) - the "Linux" in the name is honest scoping: binary utmp decode and several parsers are Linux-specific, and non-Linux captures degrade gracefully to text sources with integrity notes. Sidecar filenames (<code>UAC-Triage-Tool.sqlecmd.txt</code>/<code>.colw.txt</code>) and the <code>_Processed\&lt;host&gt;\UAC</code> output convention are unchanged for continuity. Everything from v0.10-v0.17 ships in this release.</li>
      <li><b>Multiselect release (v0.17):</b> <b>every set-type dropdown filter is now a checkbox multiselect</b> (network location + type, logon user/source/result, process suspicion, events kind - one shared component, counts per value, clear link, active filters highlight the button). Users gains an <b>Enabled column + enabled-only filter</b> (interactive shell AND usable password or SSH keys; "?" when shadow wasn't collected) and a <b>By group view</b> (every group with GID + member accounts; click a group for the full list; per-user memberships stay in the account detail pane). "Boots" renamed <b>Boot history</b>; Network addresses gains a <b>Link UP/DOWN</b> column; <b>Recent package installs</b> gains a suspicious-only filter; every tab button now carries a tooltip; <b>Copy to Clipboard</b> (renamed from "Copy for case notes" in v0.17.1) covers the Users/Apache/Audit/group views too; v0.17.1 also drops the redundant "Run metadata" heading under System overview.</li>
      <li><b>Filters &amp; polish release (v0.16):</b> the Users account filter became a proper <b>multiselect dropdown</b> (checkbox panel); Processes gained a <b>suspicion-category filter</b> (by scoring tag, with counts, works in tree view too); Network gained a <b>Type column + filter</b> (SSH/HTTP/SMB/RDP/... derived from well-known ports) and <b>click-to-VirusTotal</b> on public remote IPs (launches your browser). "Capture overview" is now <b>System overview</b>, with a <b>Network addresses</b> sub-table (friendly adaptor labels: Ethernet / Wi-Fi / Docker bridge / VPN-tunnel...), an explicit <b>Host time zone</b> row, and a <b>host-TZ toggle on every surface that shows times</b> (Overview incl. boots, Persistence, Apps, Users) - all toggles stay in sync. Package-install and boot times now display <b>normalized UTC</b> (raw host-local strings in the tooltip) instead of raw log text. Apps tab: <b>Docker containers</b> renamed and moved to the top; Persistence tab: <b>config inventory first</b>, findings gain a <b>min-score filter</b> (down to "all incl. benign", capped at 2,000 rows). The filtered-report prompt covers the new filters.</li>
      <li><b>Context release (v0.15):</b> the Overview now answers "which box is this and what can the capture speak to": a <b>network identity</b> block (interface IPs + MACs from <code>ip addr</code>/<code>ifconfig</code>), an <b>observable-activity window</b> (earliest→latest plausible timestamp across all datasets - what <code>/from /to</code> can usefully cover), <b>top external IPs</b> (most connections + logons + web requests, geo-tagged), an <b>analysis-performance</b> row (extract + parse durations, failed parser steps), and the <b>cloud-init provisioning baseline</b> (moved from Logs). Logons hides <b>lastlog state rows</b> by default (they're per-account state, shown on Users; a toolbar tick mixes them back in, hidden count disclosed). An empty Processes tab on a logs-only capture now points at Logs → Service inventory as the nearest substitute. The report gains identity / activity / top-talkers / cloud-init context.</li>
      <li><b>Refinement release (v0.14):</b> <b>Lateral movement</b> now lives on the Logons tab (above the logon table - it's the outbound half of the auth story; the Overview stat card jumps there), and the <b>Boots</b> table moved from Logs to the Overview. Tab order: Apps and Users sit left of Logons. <b>Web logs is renamed Apache logs</b> (still parses apache2/nginx/httpd combined format). Network gains a <b>Location column</b> (country + ASN, right of Remote) and a <b>location dropdown filter</b>; Events gains a <b>notable-events</b> filter (OOM / promisc / USB / modules / hosts pins / boots / journal anomalies); Users gains a <b>multiselect account filter</b>. <b>Generate report</b> now detects active UI filters and asks whether to write a <b>FILTERED report</b> (mirroring exactly what's on screen, clearly labelled, <code>_filtered</code> filename suffix) or the full one. Run metadata gains <b>Distribution</b> (/etc/os-release) and <b>Kernel</b> (uname). The processing-time pill moved next to the Instructions button.</li>
      <li><b>Layout &amp; reporting release (v0.13):</b> the tab bar is reorganised (Inventory sits beside Overview) and three sections graduated to their own tabs - <b>Persistence</b> (scored findings + config inventory), <b>Apps</b> (package installs + containers) and <b>Browser</b> (browser DBs + SQLECmd hand-off) - leaving the Overview focused on metadata, stats, top findings and lateral movement, with the <b>sar CPU summary</b> now pinned at its top (a cryptominer tell shouldn't hide on the Logs tab). <b>Generate report</b> (Overview button) writes a self-contained dark-theme HTML report with a navigation pane mirroring the tab names - score-sorted tables capped at the highest-signal rows, caps disclosed, safe to attach to a case. The Network tab gains a <b>public IPs only</b> filter, and <b>every table heading now carries a tooltip</b> explaining the column. Perf: the persistence deep-parse dropped from ~10 s to a fraction via a singleton FSO + fast reads for directory sweeps (found via the new v0.12 [perf] log).</li>
      <li><b>Progress &amp; perf-diagnostics release (v0.12):</b> a <b>processing-time pill</b> in the header ticks m:ss every half-second through extraction and parsing (the parser pipeline now yields to the UI between steps, so the clock genuinely moves - a frozen pill plus a never-changing step name in the status line means a real hang). The status line shows the <b>current step (k/38)</b> by name. Every step's duration is logged as <code>[perf]</code> lines (slow steps inline, full table at the end, incl. the slowest step and extraction time), external commands (bsdtar, robocopy, PowerShell, WSL journalctl) log their run time and exit code, and a failing parser is <b>skipped and logged</b> instead of aborting everything after it. The complete on-screen log (with all <code>[perf]</code> lines) is written to <code>parse_log_&lt;stamp&gt;.txt</code> beside the other outputs after each run - attach that file to any performance/bug report. <code>runinfo.json</code> gains <code>extractMs</code>, <code>parseMs</code> and the per-step timing array.</li>
      <li><b>Triage-workflow release (v0.11):</b> three new tabs - <b>Web logs</b> (apache/nginx/httpd access logs parsed &amp; scored: POSTs to script URIs, traversal/encoded payloads, tool user-agents - the initial-access evidence the live web-shell check can't see), <b>Users</b> (per-account: shell, groups, shadow lock state, authorized_keys count, history size, last login), and <b>Audit</b> (auditd <code>execve</code> args - hex-decoded - plus login records: the closest Linux gets to process-creation telemetry). <b>Logons → By source IP</b> aggregates first/last seen, failures, successes and users tried per source. <b>Pivot ±15 min:</b> click an Events timestamp (or the link in any logon/web/audit detail pane) to jump to the filesystem Timeline windowed around that moment - the anchor-and-expand workflow. <b>Lateral movement panel</b> (Overview): known_hosts destinations + <code>~/.ssh/config</code> + typed ssh/scp/rsync commands, corroboration-tagged. <b>Online geo/ASN enrichment</b> (checkbox, default on; <code>offline.txt</code> overrules): public IPs across logons/network/web/audit get country + ASN chips via ip-api.com - only the bare IP list is sent, never case data. Persistence sweeps extended to <code>update-motd.d</code>, APT <code>Pre/Post-Invoke</code> hooks, <code>modprobe.d install</code> lines, XDG autostart, shell startup files, and <b>PAM module directories</b> (a non-<code>pam_*.so</code> shared object there is the 2025 Plague-backdoor pattern). <code>/etc/hosts</code> pins and known LKM-rootkit module names surface on the Logs tab, and Events gains a <b>hide TOOLING</b> toggle.</li>
      <li><b>Evidence-hygiene &amp; correctness release (v0.10):</b> host-local timestamps (classic syslog, <code>last -F</code>, boot tables, apt/dpkg logs) are normalized to UTC at ingest using the collector's offset, with Dec→Jan year-rollover handling - the host-TZ toggle is now exact for every source. Extracted-<b>folder</b> input is treated as read-only evidence: rotated <code>.gz</code> logs inflate into a per-run <code>gzcache</code> under the output directory instead of the source tree. WSL journal events reset between captures (no cross-case carry-over). A <b>hostname-mismatch gate</b> stops analysis when uac.log disagrees with the typed Target hostname. Dual-use package installs (nmap, tcpdump, …) are tagged <b>TOOLING</b> - context, no longer counted as IOC or auto-flagged. wtmp/btmp/lastlog binary decode is gated to Linux glibc x86-64 captures with per-record timestamp validation, and the host's own <code>last/lastb</code> text output is preferred when present. CSV exports neutralize formula-injection cells. Classic-syslog service inventory and hostname-consistency checks fixed (both silently failed or false-fired on <code>Jul 17 12:34:56</code>-style logs). IPv6 <code>/proc/net</code> sockets are decoded. <b>Offline mode:</b> an <code>offline.txt</code> next to the app disables every outbound network feature. <code>runinfo.json</code> gains run id, capture host, UAC version, profile and TZ offset, and <code>finishedUtc</code> is now really UTC.</li>
    </ul>
    <h3>Command line</h3>
    <p><code>mshta "Linux-UAC-Analyzer.hta" "&lt;archiveOrFolder&gt;" ["&lt;outDir&gt;"] [/auto] [/from:yyyy-MM-dd] [/to:yyyy-MM-dd]</code></p>
    <ul>
      <li><code>/auto</code> - extract + parse immediately. <code>&lt;outDir&gt;</code> - where extraction + runinfo land (optional).</li>
      <li><code>/from /to</code> - case window (UTC): prefilters the <b>timeline</b> (mtime/ctime/crtime), <b>logons</b> and <b>package installs</b>, and is recorded in runinfo; never affects scoring.</li>
      <li><b>Target hostname</b> is required - guessed from the <code>uac-&lt;host&gt;-&lt;os&gt;-&lt;ts&gt;</code> archive name; names the output folder <code>_Processed\&lt;host&gt;\UAC</code> next to this app. A shared <code>IOC.txt</code> next to the app is auto-merged into the IOC box.</li>
    </ul>
    <h3>Notes / limits</h3>
    <ul>
      <li><b>tar.exe exits 1 on UAC tarballs</b> - the archive contains Unix symlinks Windows can't create; the regular files all extract and success is judged by <code>uac.log</code> appearing. Skipped-symlink count is logged.</li>
      <li><b>Encrypted zips</b> (UAC <code>-P</code>) can't be opened by bsdtar - extract with 7-Zip first, then use <b>Pick folder…</b>.</li>
      <li>Collected files mirror under a directory literally named <code>[root]</code>. A full-profile <b>bodyfile</b> can be MFT-scale; the timeline is capped at 50,000 stored rows (the full total is still reported) and pre-filtered by the case window - narrow <code>/from /to</code> on a big capture to see everything in range.</li>
      <li><b>Long paths (v0.5.1):</b> UAC captures nest ~170 chars deep (systemd journal names alone are ~92), so a deep <b>output directory</b> pushes files past Windows' classic 260-char limit. bsdtar extracts them fine, but this app's file layer can't read past the limit - those files vanish from the content parsers and IOC sweep. The app <b>pre-flights the output-dir length and warns before extracting</b>, <b>audits</b> the extracted tree (via robocopy, which is long-path capable) and reports any over-limit files on the Overview and Logs → Log integrity, and journal coverage is computed from filenames so it survives regardless. <b>Fix: set a short Output directory</b> (e.g. <code>C:\Cases\&lt;host&gt;</code>) and re-Analyze to include everything.</li>
      <li>All displayed times are <b>UTC</b> (bodyfile epochs). Collector commands that hung/timed out on the source host show as <em>failed</em> on the Overview and leave empty output files - that's normal.</li>
    </ul>
